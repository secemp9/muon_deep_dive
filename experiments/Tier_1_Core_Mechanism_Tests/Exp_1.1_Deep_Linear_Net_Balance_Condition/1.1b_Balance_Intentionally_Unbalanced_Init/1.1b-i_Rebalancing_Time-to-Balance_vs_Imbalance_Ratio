print("COMPARATIVE SCALING: Muon vs SGD reduction-rate slopes")
print("=" * 100)

# For multiple check steps, compute how reduction rate scales with ln(c)
check_steps_multi = [500, 1000, 2000, 5000]
muon_slopes_multi = []
sgd_slopes_multi = []

for cs in check_steps_multi:
    m_reds = []
    s_reds = []
    c_vals = []
    for c in IMBALANCE_RATIOS:
        traj_m = results[c]['muon']['trajectory']
        traj_s = results[c]['sgd']['trajectory']
        if (len(traj_m) > cs and np.isfinite(traj_m[cs])
                and len(traj_s) > cs and np.isfinite(traj_s[cs])):
            init_m = traj_m[0]
            init_s = traj_s[0]
            m_reds.append((1.0 - traj_m[cs] / init_m) * 100)
            s_reds.append((1.0 - traj_s[cs] / init_s) * 100)
            c_vals.append(c)

    if len(c_vals) >= 3:
        lc = np.log(np.array(c_vals, dtype=float))
        m_fit = np.polyfit(lc, np.array(m_reds), 1)
        s_fit = np.polyfit(lc, np.array(s_reds), 1)
        muon_slopes_multi.append(m_fit[0])
        sgd_slopes_multi.append(s_fit[0])
        print(f"  Step {cs:>5d}: Muon slope={m_fit[0]:+.2f}%/ln(c)  "
              f"SGD slope={s_fit[0]:+.2f}%/ln(c)  "
              f"Muon/SGD ratio={m_fit[0]/s_fit[0]:.2f}" if abs(s_fit[0]) > 0.01 else
              f"  Step {cs:>5d}: Muon slope={m_fit[0]:+.2f}%/ln(c)  SGD slope~0")

# Muon consistently has less negative (or more positive) slope than SGD
if len(muon_slopes_multi) >= 2 and len(sgd_slopes_multi) >= 2:
