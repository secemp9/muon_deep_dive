# MAIN EXPERIMENT
# =============================================================================

print("=" * 100)
print("1.1b-i: REBALANCING — TIME-TO-BALANCE vs IMBALANCE RATIO")
print("=" * 100)
print(f"Setup: 2-layer deep linear net (dim={DIM}), quadratic loss")
print(f"       W1_init = c*I, W2_init = (1/c)*I  =>  Product = I always")
print(f"       Balance metric: |log(||W1||_F / ||W2||_F)|  (0 = balanced)")
print(f"       Absolute threshold: log_imbalance < {BALANCE_THRESHOLD}")
print(f"       Relative measure: halving time (steps to reduce imbalance by 50%)")
print(f"       Max steps: {MAX_STEPS}")
print(f"       SGD:  lr={LR_SGD} (adapted for large c), momentum={MOMENTUM}")
print(f"       Muon: lr={LR_MUON}, momentum={MOMENTUM}, NS_iters={NS_ITERS}")
print("=" * 100)

# Verify initial conditions
print("\nInitial conditions verification:")
print(f"{'c':>6} | {'log_imbalance':>14} | {'bal_ratio(W1TW1/W2TW2)':>22} | {'product=I?':>10} | {'loss':>12}")
print("-" * 80)
for c in IMBALANCE_RATIOS:
    W1_init = c * np.eye(DIM)
    W2_init = (1.0 / c) * np.eye(DIM)
    li = log_imbalance(W1_init, W2_init)
    br = balance_residual_ratio(W1_init, W2_init)
    product = W2_init @ W1_init
    prod_ok = np.allclose(product, np.eye(DIM), atol=1e-10)
    loss = compute_loss(W1_init, W2_init, X_data, W_target)
    print(f"{c:6d} | {li:14.4f} | {br:22.4f} | {'YES' if prod_ok else 'NO':>10} | {loss:12.6f}")

# Run the experiment
print(f"\n{'=' * 100}")
print("TRAINING (this may take a moment for large c values)...")
print(f"{'=' * 100}")

results = {}
for c in IMBALANCE_RATIOS:
    W1_init = c * np.eye(DIM)
    W2_init = (1.0 / c) * np.eye(DIM)

    init_li = log_imbalance(W1_init, W2_init)
    print(f"\n  c = {c:6d} (initial log_imbalance = {init_li:.4f}):")

    # SGD
    np.random.seed(42)
    res_sgd = train_sgd(W1_init, W2_init, c)
    s = res_sgd['steps_to_balance']
    h = res_sgd['steps_to_half']
    div = " [DIVERGED]" if res_sgd.get('diverged', False) else ""
    print(f"    SGD  (lr={res_sgd.get('lr_used', LR_SGD):.5f}): "
          f"balance={s:>6d}{'*' if s>=MAX_STEPS else ' '} "
          f"half={h:>6d}{'*' if h>=MAX_STEPS else ' '}{div}")

    # Muon
    np.random.seed(42)
    res_muon = train_muon(W1_init, W2_init, c)
    s = res_muon['steps_to_balance']
    h = res_muon['steps_to_half']
    div = " [DIVERGED]" if res_muon.get('diverged', False) else ""
    print(f"    Muon (lr={LR_MUON:.5f}): "
          f"balance={s:>6d}{'*' if s>=MAX_STEPS else ' '} "
          f"half={h:>6d}{'*' if h>=MAX_STEPS else ' '}{div}")

    results[c] = {
        'sgd': res_sgd,
        'muon': res_muon,
        'init_log_imbalance': init_li,
    }


# =============================================================================
# RESULTS TABLE: ABSOLUTE BALANCE (log_imbalance < threshold)
# =============================================================================

print("\n\n" + "=" * 100)
print("TABLE 1: TIME TO ABSOLUTE BALANCE (log_imbalance < {:.1f})".format(BALANCE_THRESHOLD))
print("=" * 100)

print(f"\n{'c':>6} | {'log(c)':>7} | {'init_imb':>9} | {'SGD steps':>10} | {'Muon steps':>11} | "
      f"{'Ratio S/M':>10} | {'SGD capped':>10}")
print("-" * 85)

for c in IMBALANCE_RATIOS:
    r = results[c]
    ss = r['sgd']['steps_to_balance']
    sm = r['muon']['steps_to_balance']
    ratio = ss / max(sm, 1)
    print(f"{c:6d} | {np.log(c):7.2f} | {r['init_log_imbalance']:9.2f} | "
          f"{ss:10d}{'*' if ss >= MAX_STEPS else ' '} | "
          f"{sm:11d}{'*' if sm >= MAX_STEPS else ' '} | "
          f"{ratio:10.2f} | {'YES' if ss >= MAX_STEPS else 'no':>10}")


# =============================================================================
# RESULTS TABLE: HALVING TIME (relative measure)
# =============================================================================

print("\n\n" + "=" * 100)
print("TABLE 2: HALVING TIME (steps to reduce log_imbalance by 50%)")
print("=" * 100)
print("(This is the KEY test: relative rebalancing rate independent of absolute scale)")

print(f"\n{'c':>6} | {'log(c)':>7} | {'init_imb':>9} | {'SGD half':>10} | {'Muon half':>11} | "
      f"{'Ratio S/M':>10} | {'SGD lr':>8}")
print("-" * 82)

sgd_halving = []
muon_halving = []
valid_c_sgd = []
valid_c_muon = []

for c in IMBALANCE_RATIOS:
    r = results[c]
    hs = r['sgd']['steps_to_half']
    hm = r['muon']['steps_to_half']
    ratio = hs / max(hm, 1) if hm < MAX_STEPS else float('inf')
    lr_used = r['sgd'].get('lr_used', LR_SGD)
    print(f"{c:6d} | {np.log(c):7.2f} | {r['init_log_imbalance']:9.2f} | "
          f"{hs:10d}{'*' if hs >= MAX_STEPS else ' '} | "
          f"{hm:11d}{'*' if hm >= MAX_STEPS else ' '} | "
          f"{'MAX' if ratio == float('inf') else f'{ratio:.2f}':>10} | {lr_used:8.5f}")

    if hs < MAX_STEPS:
        sgd_halving.append(hs)
        valid_c_sgd.append(c)
    if hm < MAX_STEPS:
        muon_halving.append(hm)
        valid_c_muon.append(c)


# =============================================================================
# TRAJECTORY SNAPSHOTS
# =============================================================================

print("\n\n" + "=" * 100)
print("TRAJECTORY SNAPSHOTS (log_imbalance at selected steps)")
print("=" * 100)

snapshot_steps = [0, 10, 50, 100, 500, 1000, 5000, 10000, 20000]

for optimizer_name, key in [("SGD", "sgd"), ("Muon", "muon")]:
    print(f"\n  {optimizer_name}:")
    header = f"  {'c':>6} |"
    for ss in snapshot_steps:
        header += f" step={ss:>5d} |"
    print(header)
    print("  " + "-" * (len(header) - 2))

    for c in IMBALANCE_RATIOS:
        traj = results[c][key]['trajectory']
        row = f"  {c:6d} |"
        for ss in snapshot_steps:
            if ss < len(traj):
                val = traj[ss]
                if np.isfinite(val):
                    row += f" {val:>10.4f} |"
                else:
                    row += f" {'INF':>10} |"
            else:
                row += f" {'---':>10} |"
        print(row)


# =============================================================================
# SCALING ANALYSIS
# =============================================================================

print("\n\n" + "=" * 100)
print("SCALING ANALYSIS")
print("=" * 100)

# --- Muon halving time analysis ---
print("\n--- MUON HALVING TIME ---")
if len(valid_c_muon) >= 2:
    mc = np.array(valid_c_muon, dtype=float)
    mh = np.array(muon_halving, dtype=float)
    log_mc = np.log(mc)

    # Fit: halving_time vs log(c) — if O(1), slope should be ~0
    muon_fit = np.polyfit(log_mc, mh, 1)
    muon_slope = muon_fit[0]
    muon_intercept = muon_fit[1]
    muon_mean = np.mean(mh)
    muon_std = np.std(mh)
    muon_cv = muon_std / muon_mean if muon_mean > 0 else float('inf')

    # R^2
    pred_mh = np.polyval(muon_fit, log_mc)
    ss_res = np.sum((mh - pred_mh) ** 2)
    ss_tot = np.sum((mh - muon_mean) ** 2)
    r2_muon = 1.0 - ss_res / (ss_tot + 1e-15) if ss_tot > 1e-15 else 0.0

    print(f"  Valid data points: {len(valid_c_muon)}")
    print(f"  c values: {valid_c_muon}")
    print(f"  Halving times: {muon_halving}")
    print(f"  Mean: {muon_mean:.1f}, Std: {muon_std:.1f}, CV: {muon_cv:.4f}")
    print(f"  Fit: halving = {muon_slope:.2f} * ln(c) + {muon_intercept:.2f}  (R^2={r2_muon:.4f})")

    # O(1) test: slope should be negligible compared to mean
    # and CV should be small
    muon_is_O1 = (muon_cv < 0.5) or (abs(muon_slope) < muon_mean * 0.3)
    muon_is_flat = abs(muon_slope) < muon_mean * 0.1  # strict flat

    print(f"  O(1) (loose, CV<0.5 or slope<30% of mean): {'YES' if muon_is_O1 else 'NO'}")
    print(f"  O(1) (strict, slope<10% of mean): {'YES' if muon_is_flat else 'NO'}")
else:
    muon_is_O1 = False
    muon_is_flat = False
    muon_mean = float('nan')
    muon_cv = float('nan')
    muon_slope = float('nan')
    print(f"  Insufficient uncapped data ({len(valid_c_muon)} points, need >= 2).")
    if len(valid_c_muon) == 0:
        print("  Muon never reached halving for any c value within max_steps.")

# --- SGD halving time analysis ---
print("\n--- SGD HALVING TIME ---")
if len(valid_c_sgd) >= 2:
    sc = np.array(valid_c_sgd, dtype=float)
    sh = np.array(sgd_halving, dtype=float)
    log_sc = np.log(sc)

    # Fit log(halving) vs log(c) for power law: halving ~ c^alpha
    log_sh = np.log(sh)
    sgd_power_fit = np.polyfit(log_sc, log_sh, 1)
    sgd_alpha = sgd_power_fit[0]

    # R^2
    pred_lsh = np.polyval(sgd_power_fit, log_sc)
    ss_res_s = np.sum((log_sh - pred_lsh) ** 2)
    ss_tot_s = np.sum((log_sh - np.mean(log_sh)) ** 2)
    r2_sgd = 1.0 - ss_res_s / (ss_tot_s + 1e-15) if ss_tot_s > 1e-15 else 0.0

    # Linear fit
    sgd_lin_fit = np.polyfit(log_sc, sh, 1)
    sgd_lin_slope = sgd_lin_fit[0]

    sgd_grows = sgd_alpha > 0.3 or sgd_lin_slope > 10.0

    print(f"  Valid data points: {len(valid_c_sgd)}")
    print(f"  c values: {valid_c_sgd}")
    print(f"  Halving times: {sgd_halving}")
    print(f"  Power law fit: halving ~ c^{sgd_alpha:.2f}  (R^2={r2_sgd:.4f})")
    print(f"  Linear fit: halving = {sgd_lin_slope:.2f} * ln(c) + {sgd_lin_fit[1]:.2f}")
    print(f"  SGD grows with c: {'YES' if sgd_grows else 'NO'}")
else:
    sgd_alpha = float('nan')
    # Check for cap pattern
    sgd_caps = {c: results[c]['sgd']['steps_to_half'] >= MAX_STEPS for c in IMBALANCE_RATIOS}
    low_c_cap = all(sgd_caps[c] for c in IMBALANCE_RATIOS if c <= 5)
    high_c_cap = all(sgd_caps[c] for c in IMBALANCE_RATIOS if c >= 50)

    if len(valid_c_sgd) == 0:
        sgd_grows = False  # Can't confirm
        print(f"  SGD never reached halving for any c within max_steps.")
        print(f"  Note: SGD LR is adapted (reduced for large c) to prevent divergence.")
        print(f"  The adapted LR may be too small for actual rebalancing within budget.")
    else:
        sgd_grows = False
        print(f"  Only {len(valid_c_sgd)} data point(s), insufficient for fit.")

    # Additional check: look at how much rebalancing happened at a fixed step count
    print("\n  Fallback analysis: imbalance reduction at step 5000:")
    for c in IMBALANCE_RATIOS:
        traj = results[c]['sgd']['trajectory']
        init_val = traj[0]
        if len(traj) > 5000 and np.isfinite(traj[5000]):
            final_val = traj[5000]
            reduction_pct = (1.0 - final_val / init_val) * 100 if init_val > 0 else 0
            print(f"    c={c:>4d}: {init_val:.4f} -> {final_val:.4f} ({reduction_pct:.1f}% reduction)")
        else:
            print(f"    c={c:>4d}: trajectory unavailable or diverged")


