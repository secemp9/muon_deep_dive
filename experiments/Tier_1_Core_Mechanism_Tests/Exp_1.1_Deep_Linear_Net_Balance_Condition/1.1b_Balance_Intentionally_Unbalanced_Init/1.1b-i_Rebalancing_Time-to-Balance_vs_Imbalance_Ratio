print(f"\n{'c':>6} | {'SGD init':>9} | {'SGD @{}'.format(check_step):>10} | {'SGD %red':>8} | "
      f"{'Muon init':>10} | {'Muon @{}'.format(check_step):>11} | {'Muon %red':>9}")
print("-" * 85)

sgd_reductions = []
muon_reductions = []
c_for_rate = []

for c in IMBALANCE_RATIOS:
    traj_s = results[c]['sgd']['trajectory']
    traj_m = results[c]['muon']['trajectory']
    init_s = traj_s[0]
    init_m = traj_m[0]

    if len(traj_s) > check_step and np.isfinite(traj_s[check_step]):
        val_s = traj_s[check_step]
        red_s = (1.0 - val_s / init_s) * 100 if init_s > 0 else 0
    else:
        val_s = float('nan')
        red_s = float('nan')

    if len(traj_m) > check_step and np.isfinite(traj_m[check_step]):
        val_m = traj_m[check_step]
        red_m = (1.0 - val_m / init_m) * 100 if init_m > 0 else 0
    else:
        val_m = float('nan')
        red_m = float('nan')

    print(f"{c:6d} | {init_s:9.4f} | {val_s if np.isfinite(val_s) else 'DIV':>10} | "
          f"{f'{red_s:.1f}%' if np.isfinite(red_s) else 'N/A':>8} | "
          f"{init_m:10.4f} | {val_m if np.isfinite(val_m) else 'DIV':>11} | "
          f"{f'{red_m:.1f}%' if np.isfinite(red_m) else 'N/A':>9}")

    if np.isfinite(red_s) and np.isfinite(red_m):
        sgd_reductions.append(red_s)
        muon_reductions.append(red_m)
        c_for_rate.append(c)

# Analyze rate vs c
if len(c_for_rate) >= 2:
    print(f"\n  Muon % reductions: {[f'{r:.1f}' for r in muon_reductions]}")
    print(f"  SGD  % reductions: {[f'{r:.1f}' for r in sgd_reductions]}")

    muon_red_arr = np.array(muon_reductions)
    sgd_red_arr = np.array(sgd_reductions)
    log_c_rate = np.log(np.array(c_for_rate, dtype=float))

    # Check if Muon reduction rate is constant (O(1)-like)
    muon_rate_cv = np.std(muon_red_arr) / np.mean(muon_red_arr) if np.mean(muon_red_arr) > 0 else float('inf')
    muon_rate_fit = np.polyfit(log_c_rate, muon_red_arr, 1)
    print(f"\n  Muon reduction rate vs ln(c): slope={muon_rate_fit[0]:.2f}, "
          f"intercept={muon_rate_fit[1]:.2f}, CV={muon_rate_cv:.4f}")
    muon_rate_constant = muon_rate_cv < 0.5

    # Check if SGD reduction rate decreases with c
    sgd_rate_fit = np.polyfit(log_c_rate, sgd_red_arr, 1)
    sgd_rate_decreases = sgd_rate_fit[0] < -1.0  # negative slope
    print(f"  SGD  reduction rate vs ln(c): slope={sgd_rate_fit[0]:.2f}, "
          f"intercept={sgd_rate_fit[1]:.2f}")
    print(f"\n  Muon rate is constant across c: {'YES' if muon_rate_constant else 'NO'}")
    print(f"  SGD  rate decreases with c:    {'YES' if sgd_rate_decreases else 'NO'}")
else:
