    sgd_avg_slope = np.mean(sgd_slopes_multi)
    muon_less_sensitive = muon_avg_slope > sgd_avg_slope  # less negative
    print(f"\n  Average reduction-rate slope vs ln(c):")
    print(f"    Muon: {muon_avg_slope:+.2f}%/ln(c)")
    print(f"    SGD:  {sgd_avg_slope:+.2f}%/ln(c)")
