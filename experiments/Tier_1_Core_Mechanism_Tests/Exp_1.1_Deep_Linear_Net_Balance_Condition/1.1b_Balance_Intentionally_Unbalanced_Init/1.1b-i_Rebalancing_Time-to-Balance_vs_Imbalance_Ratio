muon_strict_O1 = (not np.isnan(muon_cv)) and muon_cv < 0.3
if muon_strict_O1:
    evidence_details.append(f"[MUON O(1) CONFIRMED] Halving time CV={muon_cv:.4f} < 0.3")

# Muon O(log c): halving time linear in log(c)
muon_is_Olog = False
if len(valid_c_muon) >= 3 and not np.isnan(muon_slope):
    # Fit halving vs log(c) — R^2 > 0.8 and positive slope means O(log c)
    if r2_muon > 0.8 and muon_slope > 0:
        muon_is_Olog = True
        evidence_details.append(
            f"[MUON O(log c)] Halving time = {muon_slope:.0f}*ln(c) + {muon_intercept:.0f} "
            f"(R^2={r2_muon:.4f})")

# Muon dominance: Muon always faster than SGD
muon_always_faster = True
for c in IMBALANCE_RATIOS:
    traj_m = results[c]['muon']['trajectory']
    traj_s = results[c]['sgd']['trajectory']
    check = min(5000, len(traj_m) - 1, len(traj_s) - 1)
    if check > 0 and np.isfinite(traj_m[check]) and np.isfinite(traj_s[check]):
        # Muon reduced more
        red_m = 1.0 - traj_m[check] / traj_m[0]
        red_s = 1.0 - traj_s[check] / traj_s[0]
        if red_m <= red_s:
            muon_always_faster = False
            break
if muon_always_faster:
    evidence_details.append("[MUON > SGD] Muon reduces imbalance faster than SGD at EVERY c value")

# --- SGD degradation test ---
sgd_rate_drops = False
if len(c_for_rate) >= 3:
    sgd_red_arr_local = np.array(sgd_reductions)
