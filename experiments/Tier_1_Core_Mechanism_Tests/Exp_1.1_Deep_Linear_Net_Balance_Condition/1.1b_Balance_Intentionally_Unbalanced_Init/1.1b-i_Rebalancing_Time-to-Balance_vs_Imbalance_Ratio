#!/usr/bin/env python3
"""
1.1b-i — Rebalancing: Time-to-Balance vs Imbalance Ratio
=========================================================
PREDICTION (from RG gauge-fixing / orthogonal invariance):
  Muon's rebalancing time is O(1) regardless of imbalance ratio c,
  because ortho(c * M) = ortho(M).
  SGD's rebalancing time scales with c due to gradient magnitude
  dependence on scale.

Setup:
  2-layer deep linear net, 32x32.
  Target = random matrix T. Loss = ||W2 W1 x - Tx||^2.
  Initialize: W1 = c * I, W2 = (1/c) * I for each c in {2,5,10,50,100,1000}.
  Product W2 * W1 = I always (same starting product regardless of c).
  But the IMBALANCE between layers varies.

  Balance metric: log_imbalance = |log(||W1||_F / ||W2||_F)|
  At init this equals 2*log(c). At perfect balance it equals 0.
  Threshold: log_imbalance < 1.0 (i.e., norms within factor e of each other).

  We also track the "halving time" — steps for log_imbalance to drop by 50%
  from its initial value — which is a relative measure immune to the absolute
  scale of the problem.
"""

import numpy as np

np.random.seed(42)

# =============================================================================
# CONFIGURATION
# =============================================================================

DIM = 32
BATCH_SIZE = 64
MAX_STEPS = 30000
IMBALANCE_RATIOS = [2, 5, 10, 50, 100, 1000]
BALANCE_THRESHOLD = 1.0  # |log(||W1||/||W2||)| < 1.0

LR_SGD = 0.01
LR_MUON = 0.02
MOMENTUM = 0.9
NS_ITERS = 5

# Random target matrix (fixed)
W_target = np.random.randn(DIM, DIM) * 0.3

# Random input data (fixed batch)
X_data = np.random.randn(DIM, BATCH_SIZE) * 0.3


# =============================================================================
# CORE FUNCTIONS
# =============================================================================

def forward(W1, W2, X):
    """Forward pass: W2 @ W1 @ X."""
    return W2 @ (W1 @ X)


def compute_loss(W1, W2, X, target):
    """Loss = 0.5 * ||W2 W1 X - T X||^2 / N."""
    pred = forward(W1, W2, X)
    target_out = target @ X
    diff = pred - target_out
    return 0.5 * np.mean(np.sum(diff ** 2, axis=0))


def compute_gradients(W1, W2, X, target):
    """Backprop through 2-layer linear net. Returns (grad_W1, grad_W2)."""
    N = X.shape[1]

    # Forward
    h1 = W1 @ X          # (DIM, N)
    h2 = W2 @ h1         # (DIM, N)
    target_out = target @ X

    # Backward
    delta = (h2 - target_out) / N   # (DIM, N)
    grad_W2 = delta @ h1.T          # (DIM, DIM)
    delta1 = W2.T @ delta           # (DIM, N)
    grad_W1 = delta1 @ X.T          # (DIM, DIM)

    return grad_W1, grad_W2


def newton_schulz_orthogonalize(G, num_iters=NS_ITERS):
    """
    Newton-Schulz iteration to approximate the orthogonal polar factor.
    Returns closest orthogonal matrix to G (i.e., U @ V^T from SVD).
    """
    norm = np.linalg.norm(G, ord='fro')
    if norm < 1e-12:
        return G
    X = G / norm

    for _ in range(num_iters):
        A = X.T @ X
        X = 1.5 * X - 0.5 * X @ A

    return X


def log_imbalance(W1, W2):
    """
    Absolute log-ratio of layer Frobenius norms.
    At balance = 0. For W1=c*I, W2=(1/c)*I: = 2*log(c).
    """
    n1 = np.linalg.norm(W1, 'fro')
    n2 = np.linalg.norm(W2, 'fro')
    if n2 < 1e-15 or n1 < 1e-15:
        return float('inf')
    return abs(np.log(n1 / n2))


def balance_residual_ratio(W1, W2):
    """
    ||W1^T W1||_F / ||W2^T W2||_F — the original spec metric.
    Use SVD-based computation for numerical stability.
    """
    sv1 = np.linalg.svd(W1, compute_uv=False)
    sv2 = np.linalg.svd(W2, compute_uv=False)
    # ||W^T W||_F = ||S^2||_F where S are singular values
    norm1 = np.linalg.norm(sv1 ** 2)
    norm2 = np.linalg.norm(sv2 ** 2)
    if norm2 < 1e-15:
        return float('inf')
    return norm1 / norm2


# =============================================================================
# TRAINING FUNCTIONS
# =============================================================================

def train_sgd(W1_init, W2_init, c_val, max_steps=MAX_STEPS):
    """
    Train with SGD + momentum.
    Returns dict with steps_to_balance, steps_to_half, balance trajectory.
    Adapts LR for large c to prevent immediate divergence.
    """
    W1 = W1_init.copy()
    W2 = W2_init.copy()

    # Adapt LR: for large c, the gradient w.r.t. W1 is scaled by W2^T (small)
    # and gradient w.r.t. W2 is scaled by W1 (large). Use LR / c to stabilize.
    lr = LR_SGD / max(1.0, c_val / 10.0)

    v1 = np.zeros_like(W1)
    v2 = np.zeros_like(W2)

    init_imbalance = log_imbalance(W1, W2)
    half_target = init_imbalance * 0.5
    steps_to_balance = max_steps
    steps_to_half = max_steps

    trajectory = [init_imbalance]

    for step in range(1, max_steps + 1):
        g1, g2 = compute_gradients(W1, W2, X_data, W_target)

        # Clip gradients to prevent blowup
        gn1 = np.linalg.norm(g1)
        gn2 = np.linalg.norm(g2)
        max_gnorm = 100.0
        if gn1 > max_gnorm:
            g1 = g1 * (max_gnorm / gn1)
        if gn2 > max_gnorm:
            g2 = g2 * (max_gnorm / gn2)

        v1 = MOMENTUM * v1 + g1
        v2 = MOMENTUM * v2 + g2
        W1 = W1 - lr * v1
        W2 = W2 - lr * v2

        # Check for numerical blowup
        if np.isnan(W1).any() or np.isnan(W2).any():
            # Fill remaining trajectory
            trajectory.extend([float('inf')] * (max_steps - step + 1))
            return {
                'steps_to_balance': max_steps,
                'steps_to_half': steps_to_half,
                'trajectory': trajectory,
                'lr_used': lr,
                'diverged': True,
            }

        imb = log_imbalance(W1, W2)
        trajectory.append(imb)

        if steps_to_half == max_steps and imb < half_target:
            steps_to_half = step
        if steps_to_balance == max_steps and imb < BALANCE_THRESHOLD:
            steps_to_balance = step

    return {
        'steps_to_balance': steps_to_balance,
        'steps_to_half': steps_to_half,
        'trajectory': trajectory,
        'lr_used': lr,
        'diverged': False,
    }


def train_muon(W1_init, W2_init, c_val, max_steps=MAX_STEPS):
    """
    Train with Muon (ortho gradient + momentum).
    Returns dict with steps_to_balance, steps_to_half, balance trajectory.
    """
    W1 = W1_init.copy()
    W2 = W2_init.copy()
    v1 = np.zeros_like(W1)
    v2 = np.zeros_like(W2)

    init_imbalance = log_imbalance(W1, W2)
    half_target = init_imbalance * 0.5
    steps_to_balance = max_steps
    steps_to_half = max_steps

    trajectory = [init_imbalance]

    for step in range(1, max_steps + 1):
        g1, g2 = compute_gradients(W1, W2, X_data, W_target)

        # Orthogonalize gradients — THIS is the key:
        # ortho(c * G) = ortho(G), so the direction is scale-invariant
        o1 = newton_schulz_orthogonalize(g1)
        o2 = newton_schulz_orthogonalize(g2)

        v1 = MOMENTUM * v1 + o1
        v2 = MOMENTUM * v2 + o2
        W1 = W1 - LR_MUON * v1
        W2 = W2 - LR_MUON * v2

        # Check for numerical blowup
        if np.isnan(W1).any() or np.isnan(W2).any():
            trajectory.extend([float('inf')] * (max_steps - step + 1))
            return {
                'steps_to_balance': max_steps,
                'steps_to_half': steps_to_half,
                'trajectory': trajectory,
                'diverged': True,
            }

        imb = log_imbalance(W1, W2)
        trajectory.append(imb)

        if steps_to_half == max_steps and imb < half_target:
            steps_to_half = step
        if steps_to_balance == max_steps and imb < BALANCE_THRESHOLD:
            steps_to_balance = step

    return {
        'steps_to_balance': steps_to_balance,
        'steps_to_half': steps_to_half,
        'trajectory': trajectory,
        'diverged': False,
    }


