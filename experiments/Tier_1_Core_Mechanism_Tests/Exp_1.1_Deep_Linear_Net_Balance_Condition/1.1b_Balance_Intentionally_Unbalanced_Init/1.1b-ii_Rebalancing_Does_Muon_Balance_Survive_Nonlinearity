                    f"but Muon may still outperform SGD")

# Evidence 4: SGD behavior
sgd_never_balances_relu = all(
    results['relu']['sgd'][c]['steps_to_balance'] >= MAX_STEPS
    for c in IMBALANCE_RATIOS
)
if sgd_never_balances_relu:
