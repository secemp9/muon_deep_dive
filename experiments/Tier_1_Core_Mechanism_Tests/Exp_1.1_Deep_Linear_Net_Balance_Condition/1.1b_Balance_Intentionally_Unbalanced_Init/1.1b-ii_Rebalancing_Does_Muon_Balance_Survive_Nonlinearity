#!/usr/bin/env python3
"""
1.1b-ii -- Rebalancing: Does Muon's Balance Survive Nonlinearity?
=================================================================
PREDICTION (from RG gauge-fixing / per-layer spectral structure):
  Muon still rebalances faster than SGD even with ReLU nonlinearity.
  The polar-decomposition orthogonalization acts on each W_i independently,
  so it doesn't depend on the inter-layer symmetry being exact GL(n).
  ReLU breaks the exact GL gauge to permutation+sign symmetry, but the
  spectral per-layer structure remains. The prediction weakens but
  shouldn't disappear.

CONTEXT from 1.1b-i:
  Linear net: Muon rebalances in O(log c), SGD NEVER rebalances
  (converges to imbalanced fixed points / compensates for imbalance).

Setup:
  4-layer net: y = W4 @ relu(W3 @ relu(W2 @ relu(W1 @ x)))
  Width 32, random target regression (100 samples, 32->32).
  Imbalance: W1 *= c, W4 *= 1/c for c in {2, 5, 10, 50}.
  Train 500 steps.
  Balance metric: max(||Wi||_F) / min(||Wi||_F) across all 4 layers.

Comparison axes:
  (a) Linear (no ReLU) vs ReLU -- does nonlinearity slow down rebalancing?
  (b) Muon vs SGD in the nonlinear case -- does Muon still win?
  (c) Ratio of Muon's advantage -- does it change with nonlinearity?
"""

import numpy as np

np.random.seed(42)

# =============================================================================
# CONFIGURATION
# =============================================================================

DIM = 32
N_SAMPLES = 100
N_LAYERS = 4
MAX_STEPS = 500
IMBALANCE_RATIOS = [2, 5, 10, 50]

LR_SGD = 0.005
LR_MUON = 0.01
MOMENTUM = 0.9
NS_ITERS = 5

BALANCE_THRESHOLD = 2.0  # max/min norm ratio < 2.0 means "balanced"

# Fixed data
X_data = np.random.randn(DIM, N_SAMPLES) * 0.3
W_target = np.random.randn(DIM, DIM) * 0.3
Y_target = W_target @ X_data  # (DIM, N_SAMPLES)


# =============================================================================
# NETWORK FUNCTIONS
# =============================================================================

def relu(x):
    return np.maximum(0, x)


def init_weights(c):
    """
    Initialize 4-layer net with Gaussian weights, then apply imbalance:
    W1 *= c, W4 *= 1/c.  Middle layers (W2, W3) untouched.
    All layers DIM x DIM.
    """
    rng = np.random.RandomState(123)  # deterministic init per call
    Ws = [rng.randn(DIM, DIM) * (1.0 / np.sqrt(DIM)) for _ in range(N_LAYERS)]
    Ws[0] = Ws[0] * c
    Ws[N_LAYERS - 1] = Ws[N_LAYERS - 1] * (1.0 / c)
    return Ws


def forward_pass(Ws, X, use_relu=True):
    """
    Forward pass through 4-layer net.
    Returns (output, list_of_pre_activations, list_of_post_activations).
    pre_activations[i] = W_i @ a_{i-1}  (before ReLU)
    post_activations[i] = relu(pre_activations[i]) or pre_activations[i]
    post_activations[-1] is the network output (no ReLU on last layer).
    """
    pre_acts = []
    post_acts = []
    a = X  # input to first layer

    for i in range(N_LAYERS):
        z = Ws[i] @ a               # pre-activation
        pre_acts.append(z)
        if use_relu and i < N_LAYERS - 1:  # ReLU on all but last layer
            a = relu(z)
        else:
            a = z  # linear pass-through (last layer, or linear mode)
        post_acts.append(a)

    return post_acts[-1], pre_acts, post_acts


def compute_loss(Ws, X, Y, use_relu=True):
    """Loss = 0.5 * mean over samples of ||pred - target||^2."""
    pred, _, _ = forward_pass(Ws, X, use_relu)
    diff = pred - Y
    return 0.5 * np.mean(np.sum(diff ** 2, axis=0))


def compute_gradients(Ws, X, Y, use_relu=True):
    """
    Manual backprop through 4-layer net with optional ReLU.
    Returns list of gradients [grad_W1, grad_W2, grad_W3, grad_W4].
    """
    N = X.shape[1]

    # Forward pass: store activations
    # a[0] = X (input)
    # For i = 0..3: z[i] = W[i] @ a[i], a[i+1] = relu(z[i]) or z[i]
    a = [None] * (N_LAYERS + 1)
    z = [None] * N_LAYERS
    a[0] = X

    for i in range(N_LAYERS):
        z[i] = Ws[i] @ a[i]
        if use_relu and i < N_LAYERS - 1:
            a[i + 1] = relu(z[i])
        else:
            a[i + 1] = z[i]

    # Backward pass
    # delta for output layer
    delta = (a[N_LAYERS] - Y) / N  # (DIM, N)

    grads = [None] * N_LAYERS

    for i in range(N_LAYERS - 1, -1, -1):
        # Gradient for W_i: delta @ a[i].T
        grads[i] = delta @ a[i].T  # (DIM, DIM)

        if i > 0:
            # Propagate delta backward through W_i
            delta = Ws[i].T @ delta  # (DIM, N)

            # Apply ReLU derivative if needed
            if use_relu and (i - 1) < N_LAYERS - 1:
                # The activation a[i] came from relu(z[i-1])
                # ReLU derivative: mask where z[i-1] > 0
                mask = (z[i - 1] > 0).astype(float)
                delta = delta * mask

    return grads


def balance_metric(Ws):
    """max(||Wi||_F) / min(||Wi||_F) across all layers."""
    norms = [np.linalg.norm(W, 'fro') for W in Ws]
    mn = min(norms)
    mx = max(norms)
    if mn < 1e-15:
        return float('inf')
    return mx / mn


def newton_schulz_orthogonalize(G, num_iters=NS_ITERS):
    """
    Newton-Schulz iteration to approximate the orthogonal polar factor.
    """
    norm = np.linalg.norm(G, ord='fro')
    if norm < 1e-12:
        return G
    X = G / norm
    for _ in range(num_iters):
        A = X.T @ X
        X = 1.5 * X - 0.5 * X @ A
    return X


# =============================================================================
# TRAINING FUNCTIONS
# =============================================================================

def train_sgd(Ws_init, use_relu=True, max_steps=MAX_STEPS):
    """Train with SGD + momentum."""
    Ws = [W.copy() for W in Ws_init]
    Vs = [np.zeros_like(W) for W in Ws]

    trajectory = [balance_metric(Ws)]
    loss_traj = [compute_loss(Ws, X_data, Y_target, use_relu)]

    for step in range(1, max_steps + 1):
        grads = compute_gradients(Ws, X_data, Y_target, use_relu)

        for i in range(N_LAYERS):
            # Gradient clipping
            gn = np.linalg.norm(grads[i])
            if gn > 100.0:
                grads[i] = grads[i] * (100.0 / gn)

            Vs[i] = MOMENTUM * Vs[i] + grads[i]
            Ws[i] = Ws[i] - LR_SGD * Vs[i]

        # NaN check
        if any(np.isnan(W).any() for W in Ws):
            trajectory.extend([float('inf')] * (max_steps - step + 1))
            loss_traj.extend([float('inf')] * (max_steps - step + 1))
            return {'trajectory': trajectory, 'loss': loss_traj, 'diverged': True}

        trajectory.append(balance_metric(Ws))
        loss_traj.append(compute_loss(Ws, X_data, Y_target, use_relu))

    return {'trajectory': trajectory, 'loss': loss_traj, 'diverged': False}


def train_muon(Ws_init, use_relu=True, max_steps=MAX_STEPS):
    """Train with Muon (orthogonalized gradients + momentum)."""
    Ws = [W.copy() for W in Ws_init]
    Vs = [np.zeros_like(W) for W in Ws]

    trajectory = [balance_metric(Ws)]
    loss_traj = [compute_loss(Ws, X_data, Y_target, use_relu)]

    for step in range(1, max_steps + 1):
        grads = compute_gradients(Ws, X_data, Y_target, use_relu)

        for i in range(N_LAYERS):
            # Orthogonalize: THIS is the key -- ortho(c*G) = ortho(G)
            ortho_g = newton_schulz_orthogonalize(grads[i])

            Vs[i] = MOMENTUM * Vs[i] + ortho_g
            Ws[i] = Ws[i] - LR_MUON * Vs[i]

        # NaN check
        if any(np.isnan(W).any() for W in Ws):
            trajectory.extend([float('inf')] * (max_steps - step + 1))
            loss_traj.extend([float('inf')] * (max_steps - step + 1))
            return {'trajectory': trajectory, 'loss': loss_traj, 'diverged': True}

        trajectory.append(balance_metric(Ws))
        loss_traj.append(compute_loss(Ws, X_data, Y_target, use_relu))

    return {'trajectory': trajectory, 'loss': loss_traj, 'diverged': False}


