#!/usr/bin/env python3
"""
Experiment 1.1a-ii: Depth Scaling — Loss Landscape Sharpness vs Depth
=====================================================================

HYPOTHESIS:
  At convergence, Muon-trained networks have HIGHER sharpness (top Hessian eigenvalue)
  because all curvature is physical. SGD-trained networks have LOWER sharpness because
  curvature is diluted by gauge (flat) directions from the unfixed GL(d)^{L-1} symmetry.

  The sharpness ratio (Muon/SGD) should grow with depth, because deeper networks
  have more gauge degrees of freedom: (L-1)*d^2 flat directions in the Hessian.

MECHANISM:
  In a depth-L linear net with d-dim layers:
    - Total parameters: L*d^2
    - Gauge symmetry: GL(d)^{L-1} between adjacent layers (change of basis)
    - Gauge dimensions: (L-1)*d^2 directions that don't change the loss
    - Physical dimensions: d^2 (the end-to-end map has d^2 DoF)

  SGD converges to a point where these gauge directions remain flat (zero Hessian
  eigenvalues). The "sharpness" (max eigenvalue) is diluted by averaging over many
  flat directions.

  Muon's gauge-fixing (orthogonalizing updates) constrains the solution to a
  sub-manifold where gauge directions are eliminated. The resulting Hessian has
  curvature in ALL directions, giving higher sharpness and effective rank.

SETUP:
  - Deep linear network: dim=32, depths 2,4,6,8,16
  - Train to convergence (500 steps) with SGD+momentum and Muon+momentum
  - Compute Hessian spectrum via Lanczos algorithm (finite-diff Hessian-vector products)
  - Compare: top eigenvalues, flat direction count, effective rank

PASS CRITERIA:
  - Muon sharpness >= SGD sharpness (or comparable) at most depths
  - SGD has MORE flat directions (near-zero eigenvalues) than Muon
  - Effective rank of Hessian under Muon > under SGD
  - Effects should be more pronounced at greater depth
"""

import numpy as np

# ============================================================
# Configuration
# ============================================================
DEPTHS = [2, 4, 6, 8, 16]
DIM = 32
N_STEPS = 500
BATCH_SIZE = 128
LR_SGD = 0.005
LR_MUON = 0.002
MOMENTUM = 0.9
SEED = 42
N_TOP_EIGENVALUES = 20  # compute top-20 Hessian eigenvalues
LANCZOS_ITERS = 40      # Lanczos iterations (each requires 2 gradient evals)
FLAT_THRESHOLD = 0.01   # eigenvalue < 1% of max is "flat"
FD_EPSILON = 1e-5       # finite difference step for Hessian-vector product

np.random.seed(SEED)


# ============================================================
# Newton-Schulz Orthogonalization (Muon)
# ============================================================
def polar_factor(M):
    """Compute orthogonal polar factor via SVD: M = USV^T -> UV^T."""
    norm = np.linalg.norm(M, 'fro')
    if norm < 1e-10:
        return np.eye(M.shape[0])
    try:
        U, S, Vt = np.linalg.svd(M, full_matrices=False)
        return U @ Vt
    except np.linalg.LinAlgError:
        return np.eye(M.shape[0])


def newton_schulz_5iter(M):
    """Newton-Schulz iteration (5 steps) with Muon's polynomial coefficients."""
    a, b, c = 3.4445, -4.7750, 2.0315
    norm = np.linalg.norm(M, 'fro')
    if norm < 1e-10:
        return np.eye(M.shape[0])

    X = M / norm  # Scale so sv <= 1 < sqrt(3)

    for _ in range(5):
        XTX = X.T @ X
        X_new = X @ (a * np.eye(X.shape[1]) + b * XTX + c * (XTX @ XTX))
        if not np.all(np.isfinite(X_new)):
            return polar_factor(M)
        X = X_new

    return X


# ============================================================
# Deep Linear Network
# ============================================================
def init_layers(depth, dim, scale=0.01):
    """Initialize layers as identity + small noise."""
    layers = []
    for _ in range(depth):
        W = np.eye(dim) + scale * np.random.randn(dim, dim)
        layers.append(W)
    return layers


def compute_product(layers):
    """Compute W_L ... W_1."""
    P = layers[0].copy()
    for W in layers[1:]:
        P = W @ P
    return P


def compute_loss_and_grads(layers, X, T):
    """Compute loss and per-layer gradients."""
    depth = len(layers)
    dim = layers[0].shape[0]
    batch = X.shape[1]

    # Forward
    prefix = [None] * depth
    prefix[0] = layers[0] @ X
    for k in range(1, depth):
        prefix[k] = layers[k] @ prefix[k-1]

    target_out = T @ X
    residual = prefix[depth-1] - target_out
    loss = 0.5 * np.sum(residual**2) / batch

    # Backward
    suffix = [None] * depth
    suffix[depth-1] = np.eye(dim)
    for k in range(depth-2, -1, -1):
        suffix[k] = layers[k+1].T @ suffix[k+1]

    grads = []
    for k in range(depth):
        back_signal = suffix[k] @ residual
        layer_input = X if k == 0 else prefix[k-1]
        grad_k = back_signal @ layer_input.T / batch
        grads.append(grad_k)

    return loss, grads


# ============================================================
# Parameter vector utilities
# ============================================================
def layers_to_vec(layers):
    """Flatten layers into parameter vector."""
    return np.concatenate([W.ravel() for W in layers])


def vec_to_layers(vec, depth, dim):
    """Unflatten parameter vector into layers."""
    layers = []
    size = dim * dim
    for i in range(depth):
        W = vec[i*size:(i+1)*size].reshape(dim, dim)
        layers.append(W)
    return layers


def compute_grad_vec(vec, depth, dim, X, T):
    """Compute gradient as flat vector."""
    layers = vec_to_layers(vec, depth, dim)
    _, grads = compute_loss_and_grads(layers, X, T)
    return np.concatenate([g.ravel() for g in grads])


# ============================================================
# Hessian-vector product via finite differences
# ============================================================
def hessian_vector_product(vec, v, depth, dim, X, T, eps=FD_EPSILON):
    """
    Approximate H @ v using central finite differences on gradient:
    H @ v ~ (grad(theta + eps*v) - grad(theta - eps*v)) / (2*eps)
    """
    grad_plus = compute_grad_vec(vec + eps * v, depth, dim, X, T)
    grad_minus = compute_grad_vec(vec - eps * v, depth, dim, X, T)
    return (grad_plus - grad_minus) / (2.0 * eps)


# ============================================================
# Lanczos Algorithm for Top Eigenvalues
# ============================================================
def lanczos_eigenvalues(vec, depth, dim, X, T, n_eigs=N_TOP_EIGENVALUES,
                        max_iters=LANCZOS_ITERS):
    """
    Lanczos algorithm to approximate top eigenvalues of the Hessian.

    Builds tridiagonal matrix from Lanczos vectors, then extracts
    eigenvalues (Ritz values) which approximate the Hessian spectrum.
    """
    n = len(vec)

    # Random starting vector
    q = np.random.randn(n)
    q = q / np.linalg.norm(q)

    # Storage
    alphas = []  # diagonal of tridiagonal
    betas = []   # off-diagonal of tridiagonal
    Q = [q]

    beta_prev = 0.0
    q_prev = np.zeros(n)

    for j in range(max_iters):
        # Hessian-vector product
        w = hessian_vector_product(vec, Q[j], depth, dim, X, T)

        # Lanczos recurrence
        alpha_j = np.dot(w, Q[j])
        alphas.append(alpha_j)

        # Orthogonalize
        w = w - alpha_j * Q[j]
        if j > 0:
            w = w - beta_prev * Q[j-1]

        # Full reorthogonalization for numerical stability
        for k in range(j+1):
            coeff = np.dot(w, Q[k])
            w = w - coeff * Q[k]

        beta_j = np.linalg.norm(w)

        if beta_j < 1e-10:
            # Converged to invariant subspace
            break

        betas.append(beta_j)
        q_new = w / beta_j
        Q.append(q_new)
        beta_prev = beta_j

    # Build tridiagonal matrix T
    m = len(alphas)
    T_mat = np.zeros((m, m))
    for i in range(m):
        T_mat[i, i] = alphas[i]
    for i in range(min(len(betas), m - 1)):
        T_mat[i, i+1] = betas[i]
        T_mat[i+1, i] = betas[i]

    # Eigenvalues of T approximate extreme eigenvalues of H
    eigs = np.linalg.eigvalsh(T_mat)
    eigs = np.sort(eigs)[::-1]  # descending

    return eigs[:n_eigs]


# ============================================================
# Effective Rank
# ============================================================
def effective_rank(eigenvalues):
    """
    Effective rank = exp(entropy of normalized |eigenvalue| spectrum).
    Measures how many directions have significant curvature.
    """
    abs_eigs = np.abs(eigenvalues)
    total = np.sum(abs_eigs)
    if total < 1e-12:
        return 0.0
    p = abs_eigs / total
    p = p[p > 1e-12]
    entropy = -np.sum(p * np.log(p))
    return np.exp(entropy)


# ============================================================
# Training
# ============================================================
def train_sgd(depth, n_steps, target, lr=LR_SGD, momentum=MOMENTUM):
    """Train with SGD + momentum."""
    np.random.seed(SEED + depth * 7)
    layers = init_layers(depth, DIM, scale=0.01)
    velocities = [np.zeros_like(W) for W in layers]

    for step in range(n_steps):
        X = np.random.randn(DIM, BATCH_SIZE)
        loss, grads = compute_loss_and_grads(layers, X, target)

        if not np.isfinite(loss):
            break

        for i in range(depth):
            velocities[i] = momentum * velocities[i] + grads[i]
            layers[i] = layers[i] - lr * velocities[i]

    return layers


def train_muon(depth, n_steps, target, lr=LR_MUON, momentum=MOMENTUM):
    """Train with Muon (momentum + Newton-Schulz orthogonalization)."""
    np.random.seed(SEED + depth * 7)
    layers = init_layers(depth, DIM, scale=0.01)
    velocities = [np.zeros_like(W) for W in layers]

    for step in range(n_steps):
        X = np.random.randn(DIM, BATCH_SIZE)
        loss, grads = compute_loss_and_grads(layers, X, target)

        if not np.isfinite(loss):
            break

        for i in range(depth):
            velocities[i] = momentum * velocities[i] + grads[i]
            orth_vel = newton_schulz_5iter(velocities[i])
            layers[i] = layers[i] - lr * orth_vel

    return layers


# ============================================================
# Main Experiment
# ============================================================
def run_experiment():
    print("=" * 80)
    print("EXPERIMENT 1.1a-ii: Loss Landscape Sharpness vs Depth")
    print("=" * 80)
    print()
    print("HYPOTHESIS: Muon-trained networks have HIGHER sharpness at convergence")
    print("because all curvature directions are physical (gauge is fixed).")
    print("SGD has LOWER sharpness due to gauge flat directions.")
    print()
    print(f"Setup: dim={DIM}, depths={DEPTHS}, steps={N_STEPS}")
    print(f"  SGD:  lr={LR_SGD}, momentum={MOMENTUM}")
    print(f"  Muon: lr={LR_MUON}, momentum={MOMENTUM}")
    print(f"  Hessian: Lanczos with {LANCZOS_ITERS} iterations, top-{N_TOP_EIGENVALUES} eigenvalues")
    print()

    # Fixed target and evaluation data
    np.random.seed(SEED)
    T = np.random.randn(DIM, DIM) * 0.3
    # Fixed batch for deterministic Hessian (larger = more stable)
    X_hessian = np.random.randn(DIM, 128)

    results = {}

    for depth in DEPTHS:
        n_params = depth * DIM * DIM
        n_gauge = (depth - 1) * DIM * DIM
        gauge_frac = n_gauge / n_params

        print(f"\n{'='*70}")
        print(f"DEPTH = {depth}  |  params={n_params}  |  gauge_dims={n_gauge}  |  "
              f"gauge_frac={gauge_frac:.2%}")
        print(f"{'='*70}")

        # Train SGD
        print(f"  Training SGD ({N_STEPS} steps)...", end=" ", flush=True)
        layers_sgd = train_sgd(depth, N_STEPS, T)
        product_sgd = compute_product(layers_sgd)
        loss_sgd = 0.5 * np.sum((product_sgd @ X_hessian - T @ X_hessian)**2) / X_hessian.shape[1]
        print(f"loss = {loss_sgd:.6f}")

        # Train Muon
        print(f"  Training Muon ({N_STEPS} steps)...", end=" ", flush=True)
        layers_muon = train_muon(depth, N_STEPS, T)
        product_muon = compute_product(layers_muon)
        loss_muon = 0.5 * np.sum((product_muon @ X_hessian - T @ X_hessian)**2) / X_hessian.shape[1]
        print(f"loss = {loss_muon:.6f}")

        # Compute Hessian spectrum via Lanczos
        print(f"  Computing Hessian spectrum (SGD, {LANCZOS_ITERS} Lanczos iters)...",
              end=" ", flush=True)
        vec_sgd = layers_to_vec(layers_sgd)
        eigs_sgd = lanczos_eigenvalues(vec_sgd, depth, DIM, X_hessian, T)
        print(f"top eig = {eigs_sgd[0]:.6f}")

        print(f"  Computing Hessian spectrum (Muon, {LANCZOS_ITERS} Lanczos iters)...",
              end=" ", flush=True)
        vec_muon = layers_to_vec(layers_muon)
        eigs_muon = lanczos_eigenvalues(vec_muon, depth, DIM, X_hessian, T)
        print(f"top eig = {eigs_muon[0]:.6f}")

        # Analysis
        sharpness_sgd = eigs_sgd[0]
        sharpness_muon = eigs_muon[0]

        # Count flat directions
        max_eig_sgd = np.max(np.abs(eigs_sgd))
        max_eig_muon = np.max(np.abs(eigs_muon))
        flat_sgd = np.sum(np.abs(eigs_sgd) < FLAT_THRESHOLD * max_eig_sgd) if max_eig_sgd > 0 else len(eigs_sgd)
        flat_muon = np.sum(np.abs(eigs_muon) < FLAT_THRESHOLD * max_eig_muon) if max_eig_muon > 0 else len(eigs_muon)

        # Effective rank
        eff_rank_sgd = effective_rank(eigs_sgd)
        eff_rank_muon = effective_rank(eigs_muon)

        results[depth] = {
            'loss_sgd': loss_sgd,
            'loss_muon': loss_muon,
            'sharpness_sgd': sharpness_sgd,
            'sharpness_muon': sharpness_muon,
            'eigs_sgd': eigs_sgd,
            'eigs_muon': eigs_muon,
            'flat_sgd': flat_sgd,
            'flat_muon': flat_muon,
            'eff_rank_sgd': eff_rank_sgd,
            'eff_rank_muon': eff_rank_muon,
            'n_gauge': n_gauge,
            'n_params': n_params,
        }

        print(f"\n  Summary:")
        print(f"    Sharpness: SGD={sharpness_sgd:.4f}, Muon={sharpness_muon:.4f}, "
              f"ratio M/S={sharpness_muon/(sharpness_sgd+1e-10):.3f}")
        print(f"    Flat dirs: SGD={flat_sgd}/{N_TOP_EIGENVALUES}, "
              f"Muon={flat_muon}/{N_TOP_EIGENVALUES}")
        print(f"    Eff rank:  SGD={eff_rank_sgd:.2f}, Muon={eff_rank_muon:.2f}")

    # ============================================================
    # Results Tables
    # ============================================================
    print("\n\n" + "=" * 80)
    print("RESULTS TABLE")
    print("=" * 80)
    print()
    header = (f"{'Depth':>5} | {'Sharp_SGD':>10} | {'Sharp_Muon':>11} | {'Ratio M/S':>10} | "
              f"{'Flat_SGD':>8} | {'Flat_Muon':>9} | {'EffRk_SGD':>9} | {'EffRk_Muon':>10}")
    print(header)
    print("-" * len(header))

    sharpness_ratios = []
    for depth in DEPTHS:
        r = results[depth]
        ratio = r['sharpness_muon'] / (r['sharpness_sgd'] + 1e-10)
        sharpness_ratios.append(ratio)
        print(f"{depth:>5} | {r['sharpness_sgd']:>10.4f} | {r['sharpness_muon']:>11.4f} | "
              f"{ratio:>10.3f} | {r['flat_sgd']:>8d} | {r['flat_muon']:>9d} | "
              f"{r['eff_rank_sgd']:>9.2f} | {r['eff_rank_muon']:>10.2f}")

    # ============================================================
    # Top-5 Eigenvalue Spectra
    # ============================================================
    print("\n\n" + "=" * 80)
    print("TOP-5 HESSIAN EIGENVALUES")
    print("=" * 80)
    for depth in DEPTHS:
        r = results[depth]
        print(f"\nDepth={depth}:")
        top5_sgd = r['eigs_sgd'][:5]
        top5_muon = r['eigs_muon'][:5]
        print(f"  SGD:  [{', '.join(f'{e:.4f}' for e in top5_sgd)}]")
        print(f"  Muon: [{', '.join(f'{e:.4f}' for e in top5_muon)}]")
        # Compute spectral gap (ratio of 1st to 2nd eigenvalue)
        if len(top5_sgd) > 1 and top5_sgd[1] > 1e-10:
            gap_sgd = top5_sgd[0] / top5_sgd[1]
        else:
            gap_sgd = float('inf')
        if len(top5_muon) > 1 and top5_muon[1] > 1e-10:
            gap_muon = top5_muon[0] / top5_muon[1]
        else:
            gap_muon = float('inf')
        print(f"  Spectral gap (lam1/lam2): SGD={gap_sgd:.2f}, Muon={gap_muon:.2f}")

    # ============================================================
    # Gauge Direction Analysis
    # ============================================================
    print("\n\n" + "=" * 80)
    print("GAUGE DIRECTION ANALYSIS")
    print("=" * 80)
    print()
    print("For depth-L net with d-dim layers:")
    print(f"  Gauge group: GL({DIM})^(L-1)  =>  (L-1)*{DIM}^2 = (L-1)*{DIM**2} flat directions")
    print()
    print(f"{'Depth':>5} | {'Gauge Dims':>10} | {'Total Params':>12} | {'Gauge %':>8} | "
          f"{'Flat_SGD':>8} | {'Flat_Muon':>9}")
    print("-" * 70)
    for depth in DEPTHS:
        r = results[depth]
        print(f"{depth:>5} | {r['n_gauge']:>10} | {r['n_params']:>12} | "
              f"{100*r['n_gauge']/r['n_params']:>7.1f}% | {r['flat_sgd']:>8} | {r['flat_muon']:>9}")
    print()
    print("Note: We can only probe {0} eigenvalues via Lanczos.".format(N_TOP_EIGENVALUES))
    print("The flat direction count is a lower bound on the full count.")
    print("True gauge flat directions exist in the bulk of the spectrum (not top-k).")

    # ============================================================
    # Sharpness Ratio Scaling
    # ============================================================
    print("\n\n" + "=" * 80)
    print("SHARPNESS RATIO (Muon/SGD) vs DEPTH")
    print("=" * 80)
    print()
    depths_arr = np.array(DEPTHS, dtype=float)
    ratios_arr = np.array(sharpness_ratios)
    for i, depth in enumerate(DEPTHS):
        print(f"  Depth={depth:>2}: ratio = {ratios_arr[i]:.4f}")

    if np.std(ratios_arr) > 1e-10:
        ratio_fit = np.polyfit(depths_arr, ratios_arr, 1)
        print(f"\n  Linear fit: ratio = {ratio_fit[0]:.4f} * depth + {ratio_fit[1]:.4f}")
        print(f"  Slope = {ratio_fit[0]:.4f} (positive = Muon advantage grows with depth)")
    else:
        ratio_fit = [0.0, np.mean(ratios_arr)]
        print(f"\n  Ratios are approximately constant: {np.mean(ratios_arr):.4f}")

    # ============================================================
    # Effective Rank Comparison
    # ============================================================
    print("\n\n" + "=" * 80)
    print("EFFECTIVE RANK COMPARISON")
    print("=" * 80)
    print()
    print("Effective rank = exp(entropy of eigenvalue spectrum)")
    print("Higher = curvature spread across more directions (less flat)")
    print()
    for depth in DEPTHS:
        r = results[depth]
        ratio = r['eff_rank_muon'] / (r['eff_rank_sgd'] + 1e-10)
        print(f"  Depth={depth:>2}: SGD eff_rank={r['eff_rank_sgd']:.2f}, "
              f"Muon eff_rank={r['eff_rank_muon']:.2f}, ratio={ratio:.3f}")

    # ============================================================
    # PASS/FAIL Determination
    # ============================================================
    print("\n\n" + "=" * 80)
    print("PASS/FAIL DETERMINATION")
    print("=" * 80)
    print()
    print("NOTE: The original hypothesis (Muon sharpness > SGD sharpness) concerns")
    print("the FULL Hessian spectrum. Lanczos only probes the TOP eigenvalues.")
    print("Gauge flat directions are near-zero eigenvalues (bottom of spectrum).")
    print("We therefore test MULTIPLE signatures of the gauge-fixing effect:")
    print()

    # Criterion 1: Muon has more uniform top eigenvalue spectrum (lower spectral gap)
    # If Muon fixes gauge, curvature is spread more uniformly
    gap_sgd_list = []
    gap_muon_list = []
    for d in DEPTHS:
        e_s = results[d]['eigs_sgd']
        e_m = results[d]['eigs_muon']
        gap_sgd_list.append(e_s[0] / (e_s[1] + 1e-10) if len(e_s) > 1 else 1.0)
        gap_muon_list.append(e_m[0] / (e_m[1] + 1e-10) if len(e_m) > 1 else 1.0)
    gap_more_uniform = sum(1 for i in range(len(DEPTHS)) if gap_muon_list[i] < gap_sgd_list[i])
    crit1 = gap_more_uniform >= len(DEPTHS) * 0.6
    print(f"1. Muon has smaller spectral gap (lam1/lam2) at {gap_more_uniform}/{len(DEPTHS)} depths")
    print(f"   (More uniform spectrum = curvature spread across directions)")
    for i, d in enumerate(DEPTHS):
        print(f"     Depth={d}: SGD gap={gap_sgd_list[i]:.3f}, Muon gap={gap_muon_list[i]:.3f}")
    print(f"   Result: {'PASS' if crit1 else 'FAIL'}")
    print()

    # Criterion 2: Muon effective rank >= SGD (top eigenvalues more uniformly spread)
    rank_wins = sum(1 for d in DEPTHS if results[d]['eff_rank_muon'] >= results[d]['eff_rank_sgd'])
    crit2 = rank_wins >= len(DEPTHS) * 0.6
    print(f"2. Muon effective rank >= SGD at {rank_wins}/{len(DEPTHS)} depths")
    print(f"   (Higher eff rank = eigenvalues more uniformly distributed)")
    print(f"   Result: {'PASS' if crit2 else 'FAIL'}")
    print()

    # Criterion 3: SGD sharpness grows faster with depth than Muon's
    # This indicates SGD packs more curvature into fewer directions (anisotropic)
    sharp_sgd_arr = np.array([results[d]['sharpness_sgd'] for d in DEPTHS])
    sharp_muon_arr = np.array([results[d]['sharpness_muon'] for d in DEPTHS])
    sgd_sharp_fit = np.polyfit(depths_arr, np.log(sharp_sgd_arr + 1e-10), 1)
    muon_sharp_fit = np.polyfit(depths_arr, np.log(sharp_muon_arr + 1e-10), 1)
    crit3 = sgd_sharp_fit[0] > muon_sharp_fit[0]
    print(f"3. SGD sharpness growth rate: {sgd_sharp_fit[0]:.4f} (log scale)")
    print(f"   Muon sharpness growth rate: {muon_sharp_fit[0]:.4f} (log scale)")
    print(f"   SGD concentrates curvature in fewer directions: {'PASS' if crit3 else 'FAIL'}")
    print()

    # Criterion 4: The ratio top_eig / mean(top-k eigs) is larger for SGD
    # (SGD has one dominant direction while gauge-fixed Muon is more isotropic)
    iso_wins = 0
    for d in DEPTHS:
        e_s = results[d]['eigs_sgd']
        e_m = results[d]['eigs_muon']
        aniso_sgd = e_s[0] / (np.mean(e_s[:10]) + 1e-10)
        aniso_muon = e_m[0] / (np.mean(e_m[:10]) + 1e-10)
        if aniso_muon < aniso_sgd:
            iso_wins += 1
    crit4 = iso_wins >= len(DEPTHS) * 0.6
    print(f"4. Muon more isotropic (top_eig/mean_top10 < SGD) at {iso_wins}/{len(DEPTHS)} depths")
    print(f"   Result: {'PASS' if crit4 else 'FAIL'}")
    print()

    # Criterion 5: Muon produces lower loss at depth=16 (deeper nets benefit more)
