            losses = train(model, sweep_configs[name], X_train, Y_train, n_steps=100)
            final = losses[-1]
            if np.isnan(final) or np.isinf(final):
                final = float('inf')
        except (ValueError, FloatingPointError):
            final = float('inf')
        lr_sweep_results[name].append(final)
        if final == float('inf'):
            row += f"  {'DIVERGED':>12s}"
        else:
            row += f"  {final:>12.4f}"
    print(row)

