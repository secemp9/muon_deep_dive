changes_muon = np.diff(results["Pure Muon"][-51:])
changes_hybrid = np.diff(results["Hybrid"][-51:])
std_muon_late = np.std(changes_muon)
std_hybrid_late = np.std(changes_hybrid)

check(std_muon_late > std_hybrid_late,
      f"Pure Muon more oscillatory near convergence (std={std_muon_late:.6f}) "
      f"vs Hybrid (std={std_hybrid_late:.6f})")
print()
print("  Interpretation: When bias gradients become small near the optimum,")
print("  ortho(g_bias) = g_bias/||g_bias|| is still a UNIT VECTOR, causing")
print("  overshooting. Adam adapts its step size based on gradient magnitude,")
print("  allowing fine-grained convergence for biases.")
print()


