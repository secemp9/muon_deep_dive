final_losses = {name: losses[-1] for name, losses in results.items()}

print("  Final losses (lower is better):")
for name, loss in sorted(final_losses.items(), key=lambda x: x[1]):
    print(f"    {name:>12s}: {loss:.6f}")
print()

# Key comparisons
subsep("Key comparisons")

# 1. Muon-based methods (Pure Muon and Hybrid) dominate Pure SGD
# This confirms Muon on matrices is the key factor
check(final_losses["Pure Muon"] < final_losses["Pure SGD"],
      f"Pure Muon < Pure SGD ({final_losses['Pure Muon']:.6f} < {final_losses['Pure SGD']:.6f})")
print("    -> Muon on matrices is the dominant advantage")
