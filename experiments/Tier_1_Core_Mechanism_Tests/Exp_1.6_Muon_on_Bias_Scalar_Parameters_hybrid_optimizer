subsep("Loss change statistics (last 50 steps -- near convergence)")
for name in ["Pure SGD", "Pure Muon", "Hybrid", "Pure Adam"]:
    changes = np.diff(results[name][-51:])
    n_increases = np.sum(changes > 0)
    std_changes = np.std(changes)
    print(f"  {name:>12s}: std of changes = {std_changes:.6f}, "
