check(final_losses["Hybrid"] < final_losses["Pure SGD"],
      f"Hybrid < Pure SGD ({final_losses['Hybrid']:.6f} < {final_losses['Pure SGD']:.6f})")
print("    -> Even with Adam on biases, Muon on matrices adds clear value")
print()

# 2. Both Muon-based methods beat Pure Adam
check(final_losses["Pure Muon"] < final_losses["Pure Adam"],
      f"Pure Muon < Pure Adam ({final_losses['Pure Muon']:.6f} < {final_losses['Pure Adam']:.6f})")
check(final_losses["Hybrid"] < final_losses["Pure Adam"],
      f"Hybrid < Pure Adam ({final_losses['Hybrid']:.6f} < {final_losses['Pure Adam']:.6f})")
print("    -> Muon on matrices outperforms Adam everywhere")
print()

# 3. Hybrid vs Pure Muon -- which is better depends on regime
# In early/mid training, normalizing bias gradients is actually helpful
# (acts like a large learning rate). Near convergence, it may oscillate.
hybrid_vs_muon = final_losses["Hybrid"] < final_losses["Pure Muon"]
print(f"    [INFO]  Hybrid vs Pure Muon: {'Hybrid wins' if hybrid_vs_muon else 'Pure Muon wins'} "
