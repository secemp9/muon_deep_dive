#!/usr/bin/env python3
"""
Experiment 1.6 -- Muon on Bias/Scalar Parameters: Hybrid Optimizer

Key question: Muon (ortho of gradient) works beautifully on matrix parameters.
What happens when applied to bias vectors and scalars?

  - ortho of a matrix M: polar factor UV^T (all singular values -> 1)
  - ortho of a vector v: v / ||v|| (unit vector -- loses all magnitude info)
  - ortho of a scalar s: sign(s) = +/- 1 (loses everything except sign)

For bias gradients (vectors), orthogonalization = normalization to unit length.
This removes ALL magnitude information -- maybe too aggressive for biases
which need fine-grained magnitude control?

Setup: 2-layer MLP  y = W2 * relu(W1 * x + b1) + b2
  - W1: 10x10 matrix, W2: 10x5 matrix (Muon makes sense)
  - b1: 10-vector, b2: 5-vector (Muon = normalize, questionable)

Compare 4 configurations:
  1. Pure SGD everywhere
  2. Pure Muon everywhere (including ortho on bias gradients = normalize)
  3. Hybrid: Muon on matrices, Adam on biases
  4. Pure Adam everywhere

Prediction: Hybrid (Muon matrices + Adam biases) works best because:
  - Matrices benefit from scale-invariant ortho updates
  - Biases need magnitude-aware updates (Adam provides this)
"""

import numpy as np

# ---------------------------------------------------------------------------
#  Helpers
# ---------------------------------------------------------------------------

def sep(title: str) -> None:
    print(f"\n{'=' * 76}")
    print(f"  {title}")
    print(f"{'=' * 76}\n")


def subsep(title: str) -> None:
    print(f"\n  {'-' * 70}")
    print(f"    {title}")
    print(f"  {'-' * 70}\n")


def pf(ok: bool) -> str:
    return "PASS" if ok else "FAIL"


# Global tracking
all_pass = True
total_checks = 0
total_failures = 0


def check(condition: bool, label: str) -> bool:
    global all_pass, total_checks, total_failures
    total_checks += 1
    if not condition:
        all_pass = False
        total_failures += 1
    print(f"    [{pf(condition)}]  {label}")
    return condition


rng = np.random.default_rng(2024)


# ---------------------------------------------------------------------------
#  Orthogonalization for different parameter shapes
# ---------------------------------------------------------------------------

def ortho_matrix(M: np.ndarray) -> np.ndarray:
    """Polar factor UV^T for matrix parameters."""
    U, _s, Vt = np.linalg.svd(M, full_matrices=False)
    return U @ Vt


def ortho_vector(v: np.ndarray) -> np.ndarray:
    """'Ortho' for vector parameters = normalize to unit length."""
    norm = np.linalg.norm(v)
    if norm < 1e-30:
        return v
    return v / norm


def ortho_any(param_grad: np.ndarray) -> np.ndarray:
    """Apply ortho based on parameter shape."""
    if param_grad.ndim == 2:
        return ortho_matrix(param_grad)
    elif param_grad.ndim == 1:
        return ortho_vector(param_grad)
    else:
        # scalar or 0-d
        return np.sign(param_grad)


# ---------------------------------------------------------------------------
#  Simple 2-layer MLP
# ---------------------------------------------------------------------------

def relu(x):
    return np.maximum(0, x)


def relu_deriv(x):
    return (x > 0).astype(np.float64)


class MLP:
    """Simple 2-layer MLP: y = W2 * relu(W1 * x + b1) + b2"""

    def __init__(self, d_in=10, d_hidden=10, d_out=5):
        self.d_in = d_in
        self.d_hidden = d_hidden
        self.d_out = d_out

        # Xavier initialization
        self.W1 = rng.standard_normal((d_hidden, d_in)) * np.sqrt(2.0 / d_in)
        self.W2 = rng.standard_normal((d_out, d_hidden)) * np.sqrt(2.0 / d_hidden)
        self.b1 = np.zeros(d_hidden)
        self.b2 = np.zeros(d_out)

    def forward(self, X):
        """X: (batch, d_in) -> (batch, d_out)"""
        self.X = X
        self.Z1 = X @ self.W1.T + self.b1  # (batch, d_hidden)
        self.H1 = relu(self.Z1)             # (batch, d_hidden)
        self.Y = self.H1 @ self.W2.T + self.b2  # (batch, d_out)
        return self.Y

    def backward(self, Y_true):
        """Compute gradients for MSE loss = (1/N) ||Y - Y_true||^2_F"""
        batch_size = self.X.shape[0]
        # dL/dY = (2/N) * (Y - Y_true)
        dY = (2.0 / batch_size) * (self.Y - Y_true)  # (batch, d_out)

        # Gradients for W2, b2
        # Y = H1 @ W2^T + b2
        self.grad_W2 = dY.T @ self.H1       # (d_out, d_hidden)
        self.grad_b2 = np.sum(dY, axis=0)   # (d_out,)

        # Backprop through W2
        dH1 = dY @ self.W2                   # (batch, d_hidden)

        # Backprop through ReLU
        dZ1 = dH1 * relu_deriv(self.Z1)     # (batch, d_hidden)

        # Gradients for W1, b1
        self.grad_W1 = dZ1.T @ self.X       # (d_hidden, d_in)
        self.grad_b1 = np.sum(dZ1, axis=0)  # (d_hidden,)

        return {
            "W1": self.grad_W1,
            "W2": self.grad_W2,
            "b1": self.grad_b1,
            "b2": self.grad_b2,
        }

    def loss(self, Y_true):
        """MSE loss"""
        batch_size = self.X.shape[0]
        return np.sum((self.Y - Y_true) ** 2) / batch_size

    def get_params(self):
        return {"W1": self.W1.copy(), "W2": self.W2.copy(),
                "b1": self.b1.copy(), "b2": self.b2.copy()}

    def set_params(self, params):
        self.W1 = params["W1"].copy()
        self.W2 = params["W2"].copy()
        self.b1 = params["b1"].copy()
        self.b2 = params["b2"].copy()


# ---------------------------------------------------------------------------
#  Optimizer configurations
# ---------------------------------------------------------------------------

class SGDOptimizer:
    """Pure SGD on all parameters."""
    def __init__(self, lr=0.01):
        self.lr = lr

    def step(self, params, grads):
        new_params = {}
        for key in params:
            new_params[key] = params[key] - self.lr * grads[key]
        return new_params


class MuonEverywhereOptimizer:
    """Pure Muon: apply ortho to ALL gradients (matrices and vectors)."""
    def __init__(self, lr=0.01):
        self.lr = lr

    def step(self, params, grads):
        new_params = {}
        for key in params:
            g_ortho = ortho_any(grads[key])
            new_params[key] = params[key] - self.lr * g_ortho
        return new_params


class AdamOptimizer:
    """Pure Adam on all parameters."""
    def __init__(self, lr=0.001, beta1=0.9, beta2=0.999, eps=1e-8):
        self.lr = lr
        self.beta1 = beta1
        self.beta2 = beta2
        self.eps = eps
        self.m = {}
        self.v = {}
        self.t = 0

    def step(self, params, grads):
        self.t += 1
        new_params = {}
        for key in params:
            if key not in self.m:
                self.m[key] = np.zeros_like(params[key])
                self.v[key] = np.zeros_like(params[key])
            self.m[key] = self.beta1 * self.m[key] + (1 - self.beta1) * grads[key]
            self.v[key] = self.beta2 * self.v[key] + (1 - self.beta2) * grads[key] ** 2
            m_hat = self.m[key] / (1 - self.beta1 ** self.t)
            v_hat = self.v[key] / (1 - self.beta2 ** self.t)
            new_params[key] = params[key] - self.lr * m_hat / (np.sqrt(v_hat) + self.eps)
        return new_params


class HybridOptimizer:
    """Hybrid: Muon on matrices (W1, W2), Adam on biases (b1, b2)."""
    def __init__(self, lr_muon=0.01, lr_adam=0.001, beta1=0.9, beta2=0.999, eps=1e-8):
        self.lr_muon = lr_muon
        self.lr_adam = lr_adam
        self.beta1 = beta1
        self.beta2 = beta2
        self.eps = eps
        self.m = {}
        self.v = {}
        self.t = 0
        self.matrix_keys = {"W1", "W2"}
        self.bias_keys = {"b1", "b2"}

    def step(self, params, grads):
        self.t += 1
        new_params = {}
        for key in params:
            if key in self.matrix_keys:
                # Muon for matrices
                g_ortho = ortho_matrix(grads[key])
                new_params[key] = params[key] - self.lr_muon * g_ortho
            else:
                # Adam for biases
                if key not in self.m:
                    self.m[key] = np.zeros_like(params[key])
                    self.v[key] = np.zeros_like(params[key])
                self.m[key] = self.beta1 * self.m[key] + (1 - self.beta1) * grads[key]
                self.v[key] = self.beta2 * self.v[key] + (1 - self.beta2) * grads[key] ** 2
                m_hat = self.m[key] / (1 - self.beta1 ** self.t)
                v_hat = self.v[key] / (1 - self.beta2 ** self.t)
                new_params[key] = params[key] - self.lr_adam * m_hat / (np.sqrt(v_hat) + self.eps)
        return new_params


# ---------------------------------------------------------------------------
#  Training loop
# ---------------------------------------------------------------------------

def train(model, optimizer, X_train, Y_train, n_steps=200):
    """Train model for n_steps, return loss history."""
    losses = np.zeros(n_steps + 1)

    # Initial forward pass to compute initial loss
    model.forward(X_train)
    losses[0] = model.loss(Y_train)

    for step in range(n_steps):
        # Forward
        model.forward(X_train)
        loss_val = model.loss(Y_train)

        # Backward
        grads = model.backward(Y_train)

        # Get current params
        params = model.get_params()

        # Optimizer step
        new_params = optimizer.step(params, grads)

        # Set new params
        model.set_params(new_params)

        # Record loss AFTER update
        model.forward(X_train)
        losses[step + 1] = model.loss(Y_train)

    return losses


# ---------------------------------------------------------------------------
#  SECTION 1: Setup
# ---------------------------------------------------------------------------

sep("SETUP: 2-layer MLP regression task")

d_in, d_hidden, d_out = 10, 10, 5
n_samples = 100
n_steps = 200

# Generate random regression data
X_train = rng.standard_normal((n_samples, d_in))
# True relationship with some noise
W_true1 = rng.standard_normal((d_hidden, d_in)) * 0.5
b_true1 = rng.standard_normal(d_hidden) * 0.1
W_true2 = rng.standard_normal((d_out, d_hidden)) * 0.5
b_true2 = rng.standard_normal(d_out) * 0.1
Y_train = relu(X_train @ W_true1.T + b_true1) @ W_true2.T + b_true2
Y_train += rng.standard_normal(Y_train.shape) * 0.1  # add noise

print(f"  Architecture: {d_in} -> {d_hidden} (ReLU) -> {d_out}")
print(f"  Training samples: {n_samples}")
print(f"  Training steps: {n_steps}")
print(f"  Data X shape: {X_train.shape}")
print(f"  Data Y shape: {Y_train.shape}")
print()

# Store initial parameters (same for all configs)
init_model = MLP(d_in, d_hidden, d_out)
init_params = init_model.get_params()

print(f"  Parameter shapes:")
print(f"    W1: {init_params['W1'].shape}  (matrix -- Muon suitable)")
print(f"    W2: {init_params['W2'].shape}  (matrix -- Muon suitable)")
print(f"    b1: {init_params['b1'].shape}  (vector -- Muon = normalize)")
print(f"    b2: {init_params['b2'].shape}  (vector -- Muon = normalize)")
print()


# ---------------------------------------------------------------------------
#  SECTION 2: What does ortho mean for biases?
# ---------------------------------------------------------------------------

sep("SECTION 2: What 'ortho' means for vectors and scalars")

print("  For a gradient vector g (e.g., bias gradient):")
print("    ortho(g) = g / ||g||")
print()
print("  This means:")
print("    - Direction is preserved")
print("    - ALL magnitude information is lost")
print("    - The update is ALWAYS a unit vector, regardless of loss curvature")
print("    - No adaptation to the scale of the bias gradient")
print()

# Demonstrate with an example
g_example = rng.standard_normal(10)
g_ortho_example = ortho_vector(g_example)
print(f"  Example bias gradient: norm = {np.linalg.norm(g_example):.6f}")
print(f"  After ortho:          norm = {np.linalg.norm(g_ortho_example):.6f} (always 1)")
print(f"  Cosine similarity:    {np.dot(g_example, g_ortho_example) / np.linalg.norm(g_example):.6f} (always 1)")
print()
print("  For MATRICES, ortho equalizes singular values (direction-wise normalization).")
print("  For VECTORS, ortho is just scalar normalization -- more aggressive.")
print("  For SCALARS, ortho = sign() -- extreme: only +1 or -1.")
print()

# Show what happens to matrix gradient vs vector gradient under ortho
g_mat = rng.standard_normal((10, 10))
g_mat_ortho = ortho_matrix(g_mat)
sv_before = np.linalg.svd(g_mat, compute_uv=False)
sv_after = np.linalg.svd(g_mat_ortho, compute_uv=False)
print(f"  Matrix gradient SVs (before ortho): [{', '.join(f'{s:.3f}' for s in sv_before[:5])}...]")
print(f"  Matrix gradient SVs (after ortho):  [{', '.join(f'{s:.3f}' for s in sv_after[:5])}...]")
print(f"  Matrix: preserves n-1 DOF of direction information (rotation structure)")
print()
print(f"  Vector gradient norm (before): {np.linalg.norm(g_example):.3f}")
print(f"  Vector gradient norm (after):  {np.linalg.norm(g_ortho_example):.3f}")
print(f"  Vector: preserves ONLY direction, loses the 1 DOF of magnitude")
print()


# ---------------------------------------------------------------------------
#  SECTION 3: Training comparison
# ---------------------------------------------------------------------------

sep("SECTION 3: Training comparison (4 configurations, 200 steps)")

# Learning rates tuned for fair comparison
configs = {
    "Pure SGD": SGDOptimizer(lr=0.005),
    "Pure Muon": MuonEverywhereOptimizer(lr=0.02),
    "Hybrid": HybridOptimizer(lr_muon=0.02, lr_adam=0.005),
    "Pure Adam": AdamOptimizer(lr=0.01),
}

results = {}
for name, optimizer in configs.items():
    # Reset model to same initial params
    model = MLP(d_in, d_hidden, d_out)
    model.set_params(init_params)

    # Train
    losses = train(model, optimizer, X_train, Y_train, n_steps)
    results[name] = losses
    print(f"  {name:>12s}: initial loss = {losses[0]:.4f}, final loss = {losses[-1]:.4f}, "
          f"reduction = {(1 - losses[-1]/losses[0])*100:.1f}%")

print()

# Show loss at key steps
subsep("Loss at key training steps")
print(f"  {'Step':>6s}  {'Pure SGD':>12s}  {'Pure Muon':>12s}  {'Hybrid':>12s}  {'Pure Adam':>12s}")
print(f"  {'-' * 6}  {'-' * 12}  {'-' * 12}  {'-' * 12}  {'-' * 12}")
for s in [0, 25, 50, 100, 150, 200]:
