# =============================================================================
print("\n\n" + "=" * 70)
print("RESULTS: Recovery of Muon Advantage by Orthogonality Penalty")
print("=" * 70)

header = (f"{'Act':<8} {'SGD Loss':<12} {'Muon Loss':<12} {'Best Pen':<12} "
          f"{'lam':<8} {'lr':<8} {'Recov%':<8} {'Muon adv':<12} "
          f"{'Gap(S)':<8} {'Gap(M)':<8} {'Gap(P)':<8}")
print(f"\n{header}")
print("-" * 110)

recovery_results = {}

for act_name in ['linear', 'tanh', 'relu']:
    sgd_loss = results[(act_name, 'sgd')]['final_loss']
    muon_loss = results[(act_name, 'muon')]['final_loss']
    pen_loss = results[(act_name, 'best_penalty')]['final_loss']
    best_lam = results[(act_name, 'best_lambda')]
    best_lr = results[(act_name, 'best_lr_pen')]

    muon_advantage = sgd_loss - muon_loss
    if muon_advantage > 1e-8:
        penalty_recovery = (sgd_loss - pen_loss) / muon_advantage
    else:
        penalty_recovery = 0.0

    recovery_pct = max(penalty_recovery * 100, -999)
    recovery_results[act_name] = penalty_recovery * 100

    sgd_gap = results[(act_name, 'sgd')]['mean_gap']
    muon_gap = results[(act_name, 'muon')]['mean_gap']
    pen_gap = results[(act_name, 'best_penalty')]['mean_gap']

    print(f"{act_name:<8} {sgd_loss:<12.6f} {muon_loss:<12.6f} {pen_loss:<12.6f} "
          f"{best_lam:<8.4f} {best_lr:<8.4f} {recovery_pct:<8.1f} {muon_advantage:<12.6f} "
          f"{sgd_gap:<8.2f} {muon_gap:<8.2f} {pen_gap:<8.2f}")

# =============================================================================
# Lambda sweep details
# =============================================================================
print("\n\n" + "=" * 70)
print("LAMBDA SWEEP DETAILS (at SGD base LR)")
print("=" * 70)

for act_name in ['linear', 'tanh', 'relu']:
    sgd_loss = results[(act_name, 'sgd')]['final_loss']
    muon_loss = results[(act_name, 'muon')]['final_loss']
    muon_adv = sgd_loss - muon_loss

    print(f"\n  {act_name.upper()} (SGD={sgd_loss:.6f}, Muon={muon_loss:.6f}, adv={muon_adv:.6f}):")
    print(f"  {'Lambda':<10} {'Loss':<14} {'Gap':<10} {'kappa':<10} {'Recov%':<10}")
    print(f"  {'-'*55}")

    for lam in LAMBDA_SWEEP:
        key = (act_name, f'pen_lam_{lam}')
        if key in results:
            res = results[key]
            if muon_adv > 1e-8:
                rec = (sgd_loss - res['final_loss']) / muon_adv * 100
            else:
                rec = 0.0
            kappa_final = res['kappas'][-1] if res['kappas'] and not np.isnan(res['kappas'][-1]) else float('nan')
            print(f"  {lam:<10.5f} {res['final_loss']:<14.6f} {res['mean_gap']:<10.3f} "
                  f"{kappa_final:<10.2f} {rec:<10.1f}")

# =============================================================================
# Condition number analysis
# =============================================================================
print("\n\n" + "=" * 70)
print("CONDITION NUMBER ANALYSIS")
print("=" * 70)

for act_name in ['linear', 'tanh', 'relu']:
    sgd_kappa = results[(act_name, 'sgd')]['kappas'][-1] if results[(act_name, 'sgd')]['kappas'] else 'N/A'
    muon_kappa = results[(act_name, 'muon')]['kappas'][-1] if results[(act_name, 'muon')]['kappas'] else 'N/A'
    pen_kappa = results[(act_name, 'best_penalty')]['kappas'][-1] if results[(act_name, 'best_penalty')]['kappas'] else 'N/A'
    print(f"  {act_name.upper():8s}: SGD kappa={sgd_kappa:<10.2f}  Muon kappa={muon_kappa:<10.2f}  Penalty kappa={pen_kappa:<10.2f}")

# =============================================================================
# Verdict
# =============================================================================
print("\n\n" + "=" * 70)
print("VERDICT")
print("=" * 70)

relu_recovery = recovery_results.get('relu', 0)
tanh_recovery = recovery_results.get('tanh', 0)
linear_recovery = recovery_results.get('linear', 0)

print(f"\n  Linear recovery:  {linear_recovery:.1f}%  (target: ~96% per P16)")
print(f"  Tanh recovery:    {tanh_recovery:.1f}%")
print(f"  ReLU recovery:    {relu_recovery:.1f}%")

# Check if Muon actually has an advantage
for act_name in ['linear', 'tanh', 'relu']:
    sgd_l = results[(act_name, 'sgd')]['final_loss']
    muon_l = results[(act_name, 'muon')]['final_loss']
    if muon_l >= sgd_l:
        print(f"\n  NOTE: For {act_name}, Muon ({muon_l:.6f}) >= SGD ({sgd_l:.6f}).")
        print(f"        No Muon advantage to recover. SGD already converges well.")

print()

# Linear baseline check
if linear_recovery > 85:
    print("  [PASS] Linear: penalty recovers >85% (consistent with P16).")
elif linear_recovery > 50:
    print("  [PARTIAL] Linear: 50-85% recovery. Different penalty type than P16.")
elif results[(('linear', 'muon'))]['final_loss'] >= results[('linear', 'sgd')]['final_loss']:
    print("  [BASELINE] Linear: SGD already matches/beats Muon in this config.")
