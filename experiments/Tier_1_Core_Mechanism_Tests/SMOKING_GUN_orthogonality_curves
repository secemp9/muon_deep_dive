print(f"Spearman rho = {rho:.4f}, rho² = {rho_squared:.4f} (p={p_spearman:.2e})")
print(f"Log-log Pearson r = {r_log:.4f}, R² = {r_log_squared:.4f} (p={p_log:.2e})")
print(f"\nPrediction: R² > 0.9 (linear or log-log)")
best_r2 = max(r_squared, rho_squared, r_log_squared)
