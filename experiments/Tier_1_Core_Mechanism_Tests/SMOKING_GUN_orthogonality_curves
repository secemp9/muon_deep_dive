#!/usr/bin/env python3
"""
SMOKING GUN: Orthogonality Gap Predicts Loss — The ONE Figure That Tells the Story.

Shows that distance from the Stiefel manifold (||W^T W - I||_F) is THE mechanism
behind Muon's advantage. A tight correlation between orthogonality gap and loss
across all optimizers and all training steps demonstrates that the gap IS the
mechanism, regardless of how it is reduced.

Key prediction: Pearson R² > 0.9 between orthogonality_gap and loss (pooled).
"""

import numpy as np
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
from scipy.stats import pearsonr

np.random.seed(42)

# =============================================================================
# Configuration
# =============================================================================
N_LAYERS = 6
DIM = 32
N_STEPS = 500
LR_SGD = 0.01
LR_MUON = 0.005
MOMENTUM = 0.9
PENALTY_LAMBDA = 0.003
BATCH_SIZE = 64
NS_ITERS = 5

# =============================================================================
# Data generation: target matrix approximation task
# =============================================================================
# The network product W_6...W_1 should approximate W_target.
# This is the standard deep linear net benchmark.
W_target = np.random.randn(DIM, DIM) * 0.5
X_data = np.random.randn(DIM, BATCH_SIZE) * 0.3


# =============================================================================
# Network utilities
# =============================================================================
def init_weights(n_layers, dim, seed=123):
    """Initialize weights near identity (small perturbation) for stability."""
    rng = np.random.RandomState(seed)
    weights = []
    for _ in range(n_layers):
        W = np.eye(dim) + rng.randn(dim, dim) * 0.1
        weights.append(W.copy())
    return weights


def forward(weights, X):
    """Forward pass: W_L @ ... @ W_1 @ X."""
    out = X.copy()
    for W in weights:
        out = W @ out
    return out


def compute_loss(weights, X, target):
    """Loss = 0.5 * ||W_product @ X - T @ X||^2 / N."""
    pred = forward(weights, X)
    target_out = target @ X
    diff = pred - target_out
    return 0.5 * np.mean(np.sum(diff ** 2, axis=0))


def compute_gradients(weights, X, target):
    """Backprop through deep linear net."""
    n_layers = len(weights)
    N = X.shape[1]

    # Forward pass storing activations
    activations = [X.copy()]
    out = X.copy()
    for W in weights:
        out = W @ out
        activations.append(out.copy())

    # Backward pass
    target_out = target @ X
    delta = (activations[-1] - target_out) / N

    grads = []
    for i in range(n_layers - 1, -1, -1):
        G = delta @ activations[i].T
        grads.insert(0, G)
        if i > 0:
            delta = weights[i].T @ delta

    return grads


def orthogonality_gap(W):
    """||W^T W - I||_F — distance from Stiefel manifold."""
    WtW = W.T @ W
    return np.linalg.norm(WtW - np.eye(W.shape[1]), 'fro')


def condition_number(W):
    """Condition number of W."""
    s = np.linalg.svd(W, compute_uv=False)
    if s[-1] < 1e-10:
        return 1e10
    return s[0] / s[-1]


def newton_schulz_orthogonalize(G, num_iters=NS_ITERS):
    """
    Newton-Schulz iteration to approximate the orthogonal polar factor.
    Returns closest orthogonal matrix to G (i.e., U @ V^T from SVD).
    """
    norm = np.linalg.norm(G, ord='fro')
    if norm < 1e-12:
        return G
    X = G / norm
    for _ in range(num_iters):
        A = X.T @ X
        X = 1.5 * X - 0.5 * X @ A
    return X


def orthogonality_penalty_grad(W, lam):
    """Gradient of lam * ||W^T W - I||_F^2 w.r.t. W (= 4*lam*W*(W^TW - I))."""
    WtW = W.T @ W
    return 4.0 * lam * W @ (WtW - np.eye(W.shape[1]))


# =============================================================================
# Find stable SGD learning rate
# =============================================================================
def find_stable_lr():
    """Find a stable SGD learning rate."""
    candidates = [0.03, 0.02, 0.015, 0.01, 0.007, 0.005, 0.003]
    for lr in candidates:
        weights = init_weights(N_LAYERS, DIM)
        velocities = [np.zeros((DIM, DIM)) for _ in range(N_LAYERS)]
        initial_loss = compute_loss(weights, X_data, W_target)
        stable = True
        for step in range(100):
            grads = compute_gradients(weights, X_data, W_target)
            for i in range(N_LAYERS):
                velocities[i] = MOMENTUM * velocities[i] + grads[i]
                weights[i] -= lr * velocities[i]
            loss = compute_loss(weights, X_data, W_target)
            if np.isnan(loss) or loss > initial_loss * 50:
                stable = False
                break
        if stable:
            return lr
    return 0.003


# =============================================================================
# Training loops
# =============================================================================
def train_sgd(n_steps, lr):
    """Standard SGD with momentum."""
    weights = init_weights(N_LAYERS, DIM)
    velocities = [np.zeros((DIM, DIM)) for _ in range(N_LAYERS)]

    losses = []
    gaps = []  # mean orthogonality gap over layers
    kappas = []  # mean condition number

    for step in range(n_steps):
        loss = compute_loss(weights, X_data, W_target)
        grads = compute_gradients(weights, X_data, W_target)

        # Metrics
        gap = np.mean([orthogonality_gap(W) for W in weights])
        kappa = np.mean([condition_number(W) for W in weights])
        losses.append(loss)
        gaps.append(gap)
        kappas.append(kappa)

        if np.isnan(loss) or loss > 1e10:
            # Fill remaining with last valid or nan
            losses.extend([float('nan')] * (n_steps - step - 1))
            gaps.extend([float('nan')] * (n_steps - step - 1))
            kappas.extend([float('nan')] * (n_steps - step - 1))
            break

        # SGD + momentum update
        for i in range(N_LAYERS):
            velocities[i] = MOMENTUM * velocities[i] + grads[i]
            weights[i] -= lr * velocities[i]

    return losses, gaps, kappas


def train_muon(n_steps):
    """Muon-style optimizer: orthogonalize gradient, then momentum on ortho gradient."""
    weights = init_weights(N_LAYERS, DIM)
    velocities = [np.zeros((DIM, DIM)) for _ in range(N_LAYERS)]

    losses = []
    gaps = []
    kappas = []

    for step in range(n_steps):
        loss = compute_loss(weights, X_data, W_target)
        grads = compute_gradients(weights, X_data, W_target)

        gap = np.mean([orthogonality_gap(W) for W in weights])
        kappa = np.mean([condition_number(W) for W in weights])
        losses.append(loss)
        gaps.append(gap)
        kappas.append(kappa)

        if np.isnan(loss) or loss > 1e10:
            losses.extend([float('nan')] * (n_steps - step - 1))
            gaps.extend([float('nan')] * (n_steps - step - 1))
            kappas.extend([float('nan')] * (n_steps - step - 1))
            break

        # Muon update: orthogonalize the gradient, then momentum on that
        for i in range(N_LAYERS):
            ortho_grad = newton_schulz_orthogonalize(grads[i])
            velocities[i] = MOMENTUM * velocities[i] + ortho_grad
            weights[i] -= LR_MUON * velocities[i]

    return losses, gaps, kappas


def train_sgd_penalty(n_steps, lr, lam):
    """SGD + momentum + orthogonality penalty ||W^TW - I||^2."""
    weights = init_weights(N_LAYERS, DIM)
    velocities = [np.zeros((DIM, DIM)) for _ in range(N_LAYERS)]

    losses = []
    gaps = []
    kappas = []

    for step in range(n_steps):
        loss = compute_loss(weights, X_data, W_target)
        grads = compute_gradients(weights, X_data, W_target)

        gap = np.mean([orthogonality_gap(W) for W in weights])
        kappa = np.mean([condition_number(W) for W in weights])
        losses.append(loss)
        gaps.append(gap)
        kappas.append(kappa)

        if np.isnan(loss) or loss > 1e10:
            losses.extend([float('nan')] * (n_steps - step - 1))
            gaps.extend([float('nan')] * (n_steps - step - 1))
            kappas.extend([float('nan')] * (n_steps - step - 1))
            break

        # SGD + momentum + penalty gradient
        for i in range(N_LAYERS):
            penalty_g = orthogonality_penalty_grad(weights[i], lam)
            velocities[i] = MOMENTUM * velocities[i] + grads[i] + penalty_g
            weights[i] -= lr * velocities[i]

    return losses, gaps, kappas


# =============================================================================
# Run experiments
# =============================================================================
print("=" * 70)
print("SMOKING GUN: Orthogonality Gap Predicts Loss")
print("=" * 70)
