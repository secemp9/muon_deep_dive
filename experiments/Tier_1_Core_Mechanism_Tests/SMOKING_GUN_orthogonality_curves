    for lr_factor in [1.0, 0.7, 0.5, 0.3]:
        lr_try = LR_SGD * lr_factor
        p_losses, p_gaps, p_kappas = train_sgd_penalty(N_STEPS, lr_try, lam)
        final = p_losses[-1] if not np.isnan(p_losses[-1]) else float('inf')
        key = (lam, lr_try)
        penalty_results[key] = (p_losses, p_gaps, p_kappas)
        if final < best_pen_loss:
            best_pen_loss = final
            best_lam = lam
            best_lr_pen = lr_try

print(f"  Best penalty config: lambda={best_lam}, lr={best_lr_pen:.4f}")
