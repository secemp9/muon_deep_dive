#!/usr/bin/env python3
"""
1.3a-ii: Effective Rank -- Momentum vs Weight Spectrum
======================================================
PREDICTION (from RG gauge-fixing model):
  Muon orthogonalizes the GRADIENT, then accumulates into MOMENTUM buffer M.
  Since ortho(G) has all singular values = 1, its effective rank is exactly n.
  With momentum beta=0.9, M is a running average of ortho(G) terms, so M
  should also stay near-full-rank.

  The key question: does this high rank of M *transfer* to the weight matrix W?
  W is updated by W <- W - lr * M, so W accumulates orthogonalized directions
  over training. This MIGHT keep W full-rank, or W might still specialize
  toward the target's spectrum.

  HYPOTHESIS:
    - erank(M_Muon) stays near n (by construction: ortho makes each update full rank)
    - erank(M_SGD) degrades over training (gradients concentrate)
    - erank(W_Muon) > erank(W_SGD) (high-rank momentum transfers to weights)
    - sigma_max(M)/||M||_F increases over training (reconstruction quality from H1)

  CRITICAL CONTEXT:
    - H1 confirmed: momentum rescues NS convergence (sigma_max/||M||_F > 0.3)
    - Wave 7: momentum = online PCA of gradient covariance
    - 1.3a-i: per-layer erank maintained (93.3%) but product kappa can grow
    - 1.2b-i: Muon is more chaotic in weight space

Setup: 4-layer deep linear net, 32x32, quadratic loss, 300 steps.
"""

import numpy as np
import os

np.random.seed(42)

# =============================================================================
# CONFIGURATION
# =============================================================================

DIM = 32
NUM_LAYERS = 4
NUM_STEPS = 300
BATCH_SIZE = 64
LR_MUON = 0.005
MOMENTUM = 0.9
NS_ITERS = 5
MEASURE_EVERY = 10
REPORT_STEPS = [0, 50, 100, 200, 300]

# Random target matrix (fixed)
W_target = np.random.randn(DIM, DIM) * 0.5

# Random input data (fixed batch)
X_data = np.random.randn(DIM, BATCH_SIZE) * 0.3

# Output directory
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))


# =============================================================================
# CORE FUNCTIONS
# =============================================================================

def init_weights(num_layers, seed=42):
    """Initialize layers near identity for stability."""
    rng = np.random.RandomState(seed)
    weights = []
    for _ in range(num_layers):
        W = np.eye(DIM) + rng.randn(DIM, DIM) * 0.1
        weights.append(W.copy())
    return weights


def forward(weights, X):
    """Forward pass: W_L @ ... @ W_1 @ X."""
    out = X.copy()
    for W in weights:
        out = W @ out
    return out


def compute_loss(weights, X, target):
    """Loss = 0.5 * ||W_product @ X - T @ X||^2 / N."""
    pred = forward(weights, X)
    target_out = target @ X
    diff = pred - target_out
    return 0.5 * np.mean(np.sum(diff ** 2, axis=0))


def compute_gradients(weights, X, target):
    """Backprop through deep linear net."""
    num_layers = len(weights)
    N = X.shape[1]

    # Forward pass storing activations
    activations = [X.copy()]
    out = X.copy()
    for W in weights:
        out = W @ out
        activations.append(out.copy())

    # Backward pass
    target_out = target @ X
    delta = (activations[-1] - target_out) / N

    grads = []
    for i in range(num_layers - 1, -1, -1):
        G = delta @ activations[i].T
        grads.insert(0, G)
        if i > 0:
            delta = weights[i].T @ delta

    return grads


def newton_schulz_orthogonalize(G, num_iters=NS_ITERS):
    """
    Newton-Schulz iteration to approximate the orthogonal polar factor.
    Returns closest orthogonal matrix to G (i.e., U @ V^T from SVD).
    """
    norm = np.linalg.norm(G, ord='fro')
    if norm < 1e-12:
        return G
    X = G / norm

    for _ in range(num_iters):
        A = X.T @ X
        X = 1.5 * X - 0.5 * X @ A

    return X


def effective_rank(M):
    """
    Compute effective rank of matrix M.
    erank = exp(H) where H = Shannon entropy of normalized singular values.
    """
    sv = np.linalg.svd(M, compute_uv=False)
    sv = sv[sv > 1e-15]
    if len(sv) == 0:
        return 1.0
    p = sv / np.sum(sv)
    H = -np.sum(p * np.log(p))
    return np.exp(H)


def condition_number(M):
    """Compute condition number kappa = sigma_max / sigma_min."""
    sv = np.linalg.svd(M, compute_uv=False)
    if sv[-1] < 1e-15:
        return np.inf
    return sv[0] / sv[-1]


def normalized_max_sv(M):
    """Compute sigma_max(M) / ||M||_F -- the reconstruction threshold metric from H1."""
    sv = np.linalg.svd(M, compute_uv=False)
    frob = np.linalg.norm(M, 'fro')
    if frob < 1e-15:
        return 0.0
    return sv[0] / frob


# =============================================================================
# OPTIMIZER STEP FUNCTIONS
# =============================================================================

def find_stable_lr_sgd():
    """Find maximum stable SGD learning rate."""
    candidates = [0.05, 0.03, 0.02, 0.015, 0.01, 0.007, 0.005, 0.003, 0.001]
    for lr in candidates:
        np.random.seed(42)
        weights = init_weights(NUM_LAYERS)
        velocities = [np.zeros((DIM, DIM)) for _ in range(NUM_LAYERS)]
        initial_loss = compute_loss(weights, X_data, W_target)
        stable = True
        for step in range(100):
            grads = compute_gradients(weights, X_data, W_target)
            for i in range(NUM_LAYERS):
                velocities[i] = MOMENTUM * velocities[i] + grads[i]
                weights[i] -= lr * velocities[i]
            loss = compute_loss(weights, X_data, W_target)
            if np.isnan(loss) or loss > initial_loss * 50:
                stable = False
                break
        if stable:
            return lr
    return 0.001


def sgd_step(weights, velocities, grads, lr):
    """One step of SGD with momentum. Returns (weights, velocities, grads_used)."""
    for i in range(len(weights)):
        velocities[i] = MOMENTUM * velocities[i] + grads[i]
        weights[i] = weights[i] - lr * velocities[i]
    return weights, velocities


def muon_step(weights, velocities, grads, lr):
    """One step of Muon with momentum. Returns (weights, velocities, ortho_grads)."""
    ortho_grads = []
    for i in range(len(weights)):
        ortho_grad = newton_schulz_orthogonalize(grads[i])
        ortho_grads.append(ortho_grad)
        velocities[i] = MOMENTUM * velocities[i] + ortho_grad
        weights[i] = weights[i] - lr * velocities[i]
    return weights, velocities, ortho_grads


# =============================================================================
# MEASUREMENT ENGINE
# =============================================================================

def run_and_measure(optimizer_name, is_muon, lr, num_steps):
    """
    Run optimizer for num_steps and measure:
      - erank(M_i), erank(W_i), erank(ortho(M_i)), erank(G_i) for each layer
      - kappa(M_i), kappa(W_i)
      - sigma_max(M_i)/||M_i||_F
    """
    np.random.seed(42)
    weights = init_weights(NUM_LAYERS)
    velocities = [np.zeros((DIM, DIM)) for _ in range(NUM_LAYERS)]

    record = {
        'steps': [],
        'erank_M': [],        # (num_meas, NUM_LAYERS)
        'erank_W': [],        # (num_meas, NUM_LAYERS)
        'erank_ortho_M': [],  # (num_meas, NUM_LAYERS) -- erank of ortho(M_i)
        'erank_G': [],        # (num_meas, NUM_LAYERS) -- erank of gradient
        'kappa_M': [],        # (num_meas, NUM_LAYERS)
        'kappa_W': [],        # (num_meas, NUM_LAYERS)
        'norm_max_sv_M': [],  # (num_meas, NUM_LAYERS) -- sigma_max(M)/||M||_F
        'losses': [],
    }

    def measure(step, grads_used):
        record['steps'].append(step)

        layer_erank_M = []
        layer_erank_W = []
        layer_erank_ortho_M = []
        layer_erank_G = []
        layer_kappa_M = []
        layer_kappa_W = []
        layer_norm_max_sv_M = []

        for i in range(NUM_LAYERS):
            # Momentum buffer metrics
            M_i = velocities[i]
            if np.linalg.norm(M_i, 'fro') > 1e-15:
                layer_erank_M.append(effective_rank(M_i))
                layer_kappa_M.append(condition_number(M_i))
                layer_norm_max_sv_M.append(normalized_max_sv(M_i))
                # erank of ortho(M_i) -- should be exactly n for any non-zero matrix
                ortho_M = newton_schulz_orthogonalize(M_i)
                layer_erank_ortho_M.append(effective_rank(ortho_M))
            else:
                layer_erank_M.append(1.0)
                layer_kappa_M.append(1.0)
                layer_norm_max_sv_M.append(0.0)
                layer_erank_ortho_M.append(DIM)

            # Weight matrix metrics
            layer_erank_W.append(effective_rank(weights[i]))
            layer_kappa_W.append(condition_number(weights[i]))

            # Gradient erank
            if grads_used is not None and np.linalg.norm(grads_used[i], 'fro') > 1e-15:
                layer_erank_G.append(effective_rank(grads_used[i]))
            else:
                layer_erank_G.append(1.0)

        record['erank_M'].append(layer_erank_M)
        record['erank_W'].append(layer_erank_W)
        record['erank_ortho_M'].append(layer_erank_ortho_M)
        record['erank_G'].append(layer_erank_G)
        record['kappa_M'].append(layer_kappa_M)
        record['kappa_W'].append(layer_kappa_W)
        record['norm_max_sv_M'].append(layer_norm_max_sv_M)
        record['losses'].append(compute_loss(weights, X_data, W_target))

    # Measure at step 0 (before any update; momentum is zero)
    grads_init = compute_gradients(weights, X_data, W_target)
    measure(0, grads_init)

    for step in range(1, num_steps + 1):
        grads = compute_gradients(weights, X_data, W_target)

        if is_muon:
            weights, velocities, ortho_grads = muon_step(weights, velocities, grads, lr)
            grads_used = ortho_grads  # the ortho'd gradients are what Muon "sees"
        else:
            sgd_step(weights, velocities, grads, lr)
            grads_used = grads

        # Check for divergence
        loss = compute_loss(weights, X_data, W_target)
        if np.isnan(loss) or loss > 1e10:
            print(f"    WARNING: {optimizer_name} diverged at step {step}!")
            break

        if step % MEASURE_EVERY == 0:
            measure(step, grads_used)

    # Convert lists to arrays
    for key in record:
        record[key] = np.array(record[key])

    return record


