# Test 1: erank(M_Muon) significantly higher than erank(M_SGD)
# NOTE: We originally hypothesized erank(M) ~ n, but NS preserves input rank.
# The correct test: does Muon maintain HIGHER erank(M) than SGD?
# (Muon equalizes nonzero SVs, which increases erank at given rank.)
test1_pass = muon_eM_final > 1.5 * sgd_eM_final
test1_label = "erank(M_Muon) > 1.5 * erank(M_SGD) (SV equalization effect)"

# Test 2: erank(M_Muon) > erank(M_SGD) -- Muon keeps momentum higher rank
test2_pass = muon_eM_final > sgd_eM_final
test2_label = "erank(M_Muon) > erank(M_SGD)"

# Test 3: erank(W_Muon) > erank(W_SGD) -- rank transfers from M to W
test3_pass = muon_eW_final > sgd_eW_final
test3_label = "erank(W_Muon) > erank(W_SGD) (rank transfer M->W)"

# Test 4: sigma_max(M)/||M||_F increases or stays stable for Muon
# Compare step 50 to step 300 (skip step 0 since M is zero)
