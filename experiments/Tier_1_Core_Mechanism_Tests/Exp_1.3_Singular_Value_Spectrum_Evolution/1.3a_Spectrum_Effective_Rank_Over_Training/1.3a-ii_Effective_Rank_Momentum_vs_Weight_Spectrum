test5_label = "kappa(M_Muon) < kappa(M_SGD)"

# Test 6: Gradient erank for Muon is higher than SGD (NS equalizes nonzero SVs)
# NOTE: ortho does NOT inflate rank. rank-k -> rank-k. But erank at given rank
