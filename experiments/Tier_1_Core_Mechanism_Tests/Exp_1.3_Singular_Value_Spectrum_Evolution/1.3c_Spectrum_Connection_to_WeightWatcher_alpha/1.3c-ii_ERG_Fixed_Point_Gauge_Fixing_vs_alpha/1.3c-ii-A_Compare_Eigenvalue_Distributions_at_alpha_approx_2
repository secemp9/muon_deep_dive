def run_training(optimizer_name, optimizer_fn, lr, num_steps, snapshot_steps):
    """
    Run training and return weight snapshots at specified steps.
    Returns: dict of step -> list of weight matrices (one per layer).
    """
    np.random.seed(42)
    weights = init_weights(NUM_LAYERS)
    velocities = [np.zeros((DIM, DIM)) for _ in range(NUM_LAYERS)]

    snapshots = {}
    losses = {}

    # Step 0
    if 0 in snapshot_steps:
        snapshots[0] = [W.copy() for W in weights]
        losses[0] = compute_loss(weights, X_data, W_target)

    for step in range(1, num_steps + 1):
        weights, velocities = optimizer_fn(weights, velocities, lr)
        loss = compute_loss(weights, X_data, W_target)
        if np.isnan(loss) or loss > 1e10:
            print(f"    WARNING: {optimizer_name} diverged at step {step}!")
            break
        if step in snapshot_steps:
            snapshots[step] = [W.copy() for W in weights]
            losses[step] = loss

    return snapshots, losses


snapshot_steps = {0, SNAPSHOT_STEP, NUM_STEPS}

print("\n  Running SGD...", flush=True)
sgd_snapshots, sgd_losses = run_training('SGD', sgd_step, lr_sgd, NUM_STEPS, snapshot_steps)
print(f"    SGD final loss: {sgd_losses.get(NUM_STEPS, float('nan')):.6e}")

print("  Running Muon...", flush=True)
muon_snapshots, muon_losses = run_training('Muon', muon_step, LR_MUON, NUM_STEPS, snapshot_steps)
print(f"    Muon final loss: {muon_losses.get(NUM_STEPS, float('nan')):.6e}")


