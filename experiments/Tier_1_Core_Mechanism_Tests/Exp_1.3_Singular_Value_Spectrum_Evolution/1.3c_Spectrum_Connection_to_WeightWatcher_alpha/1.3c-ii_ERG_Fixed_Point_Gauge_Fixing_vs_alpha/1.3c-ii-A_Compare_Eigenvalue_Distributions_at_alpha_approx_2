#!/usr/bin/env python3
"""
1.3c-ii-A: Compare Eigenvalue DISTRIBUTIONS at Matched Steps (SGD vs Muon)
===========================================================================

CONTEXT from 1.3c-i:
  - Muon alpha decreases to 0.76 (flatter), SGD alpha increases to 1.12 (heavier tail)
  - SGD's heavy tail is WHOLE-SPECTRUM, not just lambda_max
  - They may never both reach alpha~2, so we compare at MATCHED TRAINING STEPS

GOAL: At step 500 (after convergence), compare the FULL eigenvalue distribution
shape for SGD vs Muon.  Plot log(lambda) vs log(rank), compute KS test,
Wasserstein distance, and compare with Marchenko-Pastur baseline.

QUESTION: How different are the spectral shapes beyond just alpha?

Setup: 4-layer deep linear net, 32x32, 1000 steps, SGD vs Muon.
       Snapshot at step 500 for detailed comparison.
"""

import numpy as np
import os

np.random.seed(42)

# =============================================================================
# CONFIGURATION
# =============================================================================

DIM = 32
NUM_LAYERS = 4
NUM_STEPS = 1000
BATCH_SIZE = 64
LR_MUON = 0.005
MOMENTUM = 0.9
NS_ITERS = 5
MEASURE_EVERY = 25
SNAPSHOT_STEP = 500

W_target = np.random.randn(DIM, DIM) * 0.5
X_data = np.random.randn(DIM, BATCH_SIZE) * 0.3

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))


# =============================================================================
# CORE FUNCTIONS (shared with 1.3c-i)
# =============================================================================

def init_weights(num_layers, seed=42):
    rng = np.random.RandomState(seed)
    weights = []
    for _ in range(num_layers):
        W = np.eye(DIM) + rng.randn(DIM, DIM) * 0.1
        weights.append(W.copy())
    return weights


def forward(weights, X):
    out = X.copy()
    for W in weights:
        out = W @ out
    return out


def compute_loss(weights, X, target):
    pred = forward(weights, X)
    target_out = target @ X
    diff = pred - target_out
    return 0.5 * np.mean(np.sum(diff ** 2, axis=0))


def compute_gradients(weights, X, target):
    num_layers = len(weights)
    N = X.shape[1]
    activations = [X.copy()]
    out = X.copy()
    for W in weights:
        out = W @ out
        activations.append(out.copy())
    target_out = target @ X
    delta = (activations[-1] - target_out) / N
    grads = []
    for i in range(num_layers - 1, -1, -1):
        G = delta @ activations[i].T
        grads.insert(0, G)
        if i > 0:
            delta = weights[i].T @ delta
    return grads


def newton_schulz_orthogonalize(G, num_iters=NS_ITERS):
    norm = np.linalg.norm(G, ord='fro')
    if norm < 1e-12:
        return G
    X = G / norm
    for _ in range(num_iters):
        A = X.T @ X
        X = 1.5 * X - 0.5 * X @ A
    return X


def find_stable_lr_sgd():
    candidates = [0.05, 0.03, 0.02, 0.015, 0.01, 0.007, 0.005, 0.003, 0.001]
    for lr in candidates:
        np.random.seed(42)
        weights = init_weights(NUM_LAYERS)
        velocities = [np.zeros((DIM, DIM)) for _ in range(NUM_LAYERS)]
        initial_loss = compute_loss(weights, X_data, W_target)
        stable = True
        for step in range(200):
            grads = compute_gradients(weights, X_data, W_target)
            for i in range(NUM_LAYERS):
                velocities[i] = MOMENTUM * velocities[i] + grads[i]
                weights[i] -= lr * velocities[i]
            loss = compute_loss(weights, X_data, W_target)
            if np.isnan(loss) or loss > initial_loss * 50:
                stable = False
                break
        if stable:
            return lr
    return 0.001


def sgd_step(weights, velocities, lr):
    grads = compute_gradients(weights, X_data, W_target)
    for i in range(len(weights)):
        velocities[i] = MOMENTUM * velocities[i] + grads[i]
        weights[i] = weights[i] - lr * velocities[i]
    return weights, velocities


def muon_step(weights, velocities, lr):
    grads = compute_gradients(weights, X_data, W_target)
    for i in range(len(weights)):
        ortho_grad = newton_schulz_orthogonalize(grads[i])
        velocities[i] = MOMENTUM * velocities[i] + ortho_grad
        weights[i] = weights[i] - lr * velocities[i]
    return weights, velocities


def fit_power_law_alpha(eigenvalues):
    eigs = np.sort(eigenvalues)[::-1]
    eigs = eigs[eigs > 1e-30]
    n = len(eigs)
    if n < 3:
        return np.nan
    ranks = np.arange(1, n + 1).astype(float)
    log_rank = np.log(ranks)
    log_eig = np.log(eigs)
    A = np.vstack([log_rank, np.ones(n)]).T
    result = np.linalg.lstsq(A, log_eig, rcond=None)
    slope = result[0][0]
    return -slope


# =============================================================================
# STATISTICAL TESTS (numpy-only implementations)
# =============================================================================

def ks_test_two_sample(x, y):
    """
    Two-sample Kolmogorov-Smirnov test.
    Returns (D_statistic, approximate_p_value).
    """
    n1 = len(x)
    n2 = len(y)
    combined = np.concatenate([x, y])
    combined_sorted = np.sort(combined)

    cdf1 = np.searchsorted(np.sort(x), combined_sorted, side='right') / n1
    cdf2 = np.searchsorted(np.sort(y), combined_sorted, side='right') / n2

    D = np.max(np.abs(cdf1 - cdf2))

    # Approximate p-value using asymptotic formula
    n_eff = np.sqrt(n1 * n2 / (n1 + n2))
    lam = (n_eff + 0.12 + 0.11 / n_eff) * D
    # Kolmogorov distribution approximation (first terms)
    j = np.arange(1, 101)
    p_val = 2.0 * np.sum((-1.0) ** (j - 1) * np.exp(-2.0 * j ** 2 * lam ** 2))
    p_val = max(0.0, min(1.0, p_val))

    return D, p_val


def wasserstein_distance_1d(x, y):
    """
    1D Wasserstein (Earth Mover's) distance between two distributions.
    = integral of |CDF_x - CDF_y|
    """
    xs = np.sort(x)
    ys = np.sort(y)
    # If same length, simple:
    if len(xs) == len(ys):
        return np.mean(np.abs(xs - ys))
    # General case: merge sorted values, compute CDF difference area
    all_vals = np.sort(np.concatenate([xs, ys]))
    cdf_x = np.searchsorted(xs, all_vals, side='right') / len(xs)
    cdf_y = np.searchsorted(ys, all_vals, side='right') / len(ys)
    # Trapezoidal integration of |CDF_x - CDF_y|
    diffs = np.abs(cdf_x - cdf_y)
    deltas = np.diff(all_vals)
    return np.sum(0.5 * (diffs[:-1] + diffs[1:]) * deltas)


def marchenko_pastur_eigenvalues(n, gamma=1.0, sigma=1.0):
    """
    Generate eigenvalues from the Marchenko-Pastur distribution.
    For a random matrix W of shape (n, n) (gamma=1), the eigenvalues of
    W^T W / n follow MP.  We generate n samples.

    For gamma=1: lambda_+ = (1+1)^2 * sigma^2 = 4*sigma^2
                 lambda_- = (1-1)^2 * sigma^2 = 0
    Density: f(x) = sqrt(4*sigma^2 - x) * sqrt(x) / (2*pi*sigma^2*x)
    """
    # Use inverse CDF sampling via sorted uniform
    # For gamma=1, MP simplifies.  We'll just use a random Gaussian matrix.
    rng = np.random.RandomState(999)
    W_rand = rng.randn(n, n) / np.sqrt(n)
    eigs = np.linalg.eigvalsh(W_rand.T @ W_rand)
    return np.sort(eigs)[::-1]


def shannon_entropy(eigenvalues):
    """Shannon entropy of normalized eigenvalue distribution."""
    eigs = np.maximum(eigenvalues, 0.0)
    total = np.sum(eigs)
    if total < 1e-30:
        return 0.0
    p = eigs / total
    p = p[p > 1e-30]
    return -np.sum(p * np.log(p))


