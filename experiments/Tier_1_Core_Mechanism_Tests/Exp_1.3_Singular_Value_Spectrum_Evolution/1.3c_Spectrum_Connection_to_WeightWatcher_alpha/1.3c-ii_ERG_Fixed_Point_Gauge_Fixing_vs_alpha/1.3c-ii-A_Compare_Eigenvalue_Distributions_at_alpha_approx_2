mean_ks = np.mean(ks_stats)
mean_ks_p = np.mean(ks_pvals)
test1_different = mean_ks > 0.15  # KS > 0.15 is substantial difference

# T2: Wasserstein distance is non-trivial
mean_wd = np.mean(w_dists)
test2_wasserstein = mean_wd > 0.001  # non-trivial distance

# T3: Muon spectrum is flatter (lower alpha, higher entropy)
mean_alpha_sgd = np.mean(sgd_alphas)
mean_alpha_muon = np.mean(muon_alphas)
test3_muon_flatter = mean_alpha_muon < mean_alpha_sgd

# T4: Muon is closer to MP baseline (more random-like) OR both deviate similarly
# (Either outcome is informative)
