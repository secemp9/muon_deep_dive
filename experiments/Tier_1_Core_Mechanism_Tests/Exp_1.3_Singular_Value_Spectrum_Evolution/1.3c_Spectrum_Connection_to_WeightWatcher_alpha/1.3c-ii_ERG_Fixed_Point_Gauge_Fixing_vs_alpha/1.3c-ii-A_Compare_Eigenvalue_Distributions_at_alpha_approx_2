mean_ks_muon_mp = np.mean(ks_muon_mp_list)
# We just report this -- both optimizers should deviate from MP since they're trained
test4_muon_closer_mp = mean_ks_muon_mp < mean_ks_sgd_mp

# T5: Spectral shape differs beyond just scale (log-eigenvalue difference varies with rank)
log_diffs_std = []
for layer_idx in range(NUM_LAYERS):
    eigs_sgd = sgd_eigs_per_layer[layer_idx]
    eigs_muon = muon_eigs_per_layer[layer_idx]
    n = min(len(eigs_sgd), len(eigs_muon))
