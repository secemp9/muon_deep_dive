    diff = np.log(eigs_sgd[:n][mask]) - np.log(eigs_muon[:n][mask])
    log_diffs_std.append(np.std(diff))
mean_log_diff_std = np.mean(log_diffs_std)
test5_shape_differs = mean_log_diff_std > 0.05  # non-uniform difference = shape difference

print(f"""
