        eigs_muon = muon_eigs_per_layer[layer_idx]
        n = min(len(eigs_sgd), len(eigs_muon))
        mask = (eigs_sgd[:n] > 1e-30) & (eigs_muon[:n] > 1e-30)
        diff = np.log(eigs_sgd[:n][mask]) - np.log(eigs_muon[:n][mask])
        ranks = np.arange(1, np.sum(mask) + 1)
        ax.plot(ranks, diff, 'o-', markersize=3, linewidth=1.5,
                label=f'Layer {layer_idx}', alpha=0.7)

    ax.axhline(y=0, color='k', linestyle=':', linewidth=1)
    ax.set_xlabel('Rank')
    ax.set_ylabel('log(lambda_SGD) - log(lambda_Muon)')
    ax.legend(fontsize=10)
    ax.grid(True, alpha=0.3)

