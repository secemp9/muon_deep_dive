def run_and_measure_entropy(optimizer_name, optimizer_fn, lr, num_steps):
    """
    Run optimizer and track entropy metrics at every MEASURE_EVERY steps.
    """
    np.random.seed(42)
    weights = init_weights(NUM_LAYERS)
    velocities = [np.zeros((DIM, DIM)) for _ in range(NUM_LAYERS)]

    measure_steps = list(range(0, num_steps + 1, MEASURE_EVERY))
    if num_steps not in measure_steps:
        measure_steps.append(num_steps)
    measure_steps = sorted(set(measure_steps))
    n_measures = len(measure_steps)

    # Storage: per-layer and mean
    entropy_per_layer = np.zeros((n_measures, NUM_LAYERS))
    eff_rank_per_layer = np.zeros((n_measures, NUM_LAYERS))
    alpha_per_layer = np.zeros((n_measures, NUM_LAYERS))
    losses = np.zeros(n_measures)

    measure_idx = 0

    def measure_at(step_weights, idx):
        for layer_idx in range(NUM_LAYERS):
            W = step_weights[layer_idx]
            eigs = np.linalg.eigvalsh(W.T @ W)[::-1]
            eigs = np.maximum(eigs, 0.0)
            entropy_per_layer[idx, layer_idx] = shannon_entropy(eigs)
            eff_rank_per_layer[idx, layer_idx] = effective_rank(eigs)
            alpha_per_layer[idx, layer_idx] = fit_power_law_alpha(eigs)

    # Step 0
    if measure_steps[0] == 0:
        measure_at(weights, 0)
        losses[0] = compute_loss(weights, X_data, W_target)
        measure_idx = 1

    for step in range(1, num_steps + 1):
        weights, velocities = optimizer_fn(weights, velocities, lr)
        loss = compute_loss(weights, X_data, W_target)

        if np.isnan(loss) or loss > 1e10:
            print(f"    WARNING: {optimizer_name} diverged at step {step}!")
            for mi in range(measure_idx, n_measures):
                entropy_per_layer[mi] = np.nan
                eff_rank_per_layer[mi] = np.nan
                alpha_per_layer[mi] = np.nan
                losses[mi] = np.nan
            break

        if measure_idx < n_measures and step == measure_steps[measure_idx]:
            measure_at(weights, measure_idx)
            losses[measure_idx] = loss
            measure_idx += 1

    return {
        'measure_steps': np.array(measure_steps),
        'entropy': entropy_per_layer,        # (n_measures, NUM_LAYERS)
        'effective_rank': eff_rank_per_layer,
        'alpha': alpha_per_layer,
        'losses': losses,
    }


print("\n  Running SGD...", flush=True)
results_sgd = run_and_measure_entropy('SGD', sgd_step, lr_sgd, NUM_STEPS)
print(f"    SGD final loss: {results_sgd['losses'][-1]:.6e}")

