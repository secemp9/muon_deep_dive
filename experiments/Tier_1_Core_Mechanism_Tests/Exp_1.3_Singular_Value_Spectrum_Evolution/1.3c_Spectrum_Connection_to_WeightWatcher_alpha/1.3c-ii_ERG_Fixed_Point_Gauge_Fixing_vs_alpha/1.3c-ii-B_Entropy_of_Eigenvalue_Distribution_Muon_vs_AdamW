#!/usr/bin/env python3
"""
1.3c-ii-B: Entropy of Eigenvalue Distribution -- Muon vs SGD
=============================================================

CONTEXT from 1.3c-i:
  - Muon alpha decreases to 0.76 (flatter), SGD alpha increases to 1.12 (heavier tail)
  - SGD's heavy tail is WHOLE-SPECTRUM, not just lambda_max

GOAL: Track Shannon entropy of normalized eigenvalue spectrum over training.
  H = -sum(p_i * log(p_i))  where  p_i = lambda_i / sum(lambda_j)

HYPOTHESIS:
  - Muon should maintain HIGHER entropy (flatter, more uniform spectrum)
  - Maximum entropy = log(n) for a perfectly uniform spectrum
  - Effective rank = exp(H) connects to 1.3a-i condition number results

Setup: 4-layer deep linear net, 32x32, 1000 steps, SGD vs Muon.
       Measure every 25 steps.
"""

import numpy as np
import os

np.random.seed(42)

# =============================================================================
# CONFIGURATION
# =============================================================================

DIM = 32
NUM_LAYERS = 4
NUM_STEPS = 1000
BATCH_SIZE = 64
LR_MUON = 0.005
MOMENTUM = 0.9
NS_ITERS = 5
MEASURE_EVERY = 25

W_target = np.random.randn(DIM, DIM) * 0.5
X_data = np.random.randn(DIM, BATCH_SIZE) * 0.3

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))

TABLE_STEPS = [0, 25, 50, 100, 200, 300, 400, 500, 750, 1000]


# =============================================================================
# CORE FUNCTIONS (shared with 1.3c-i)
# =============================================================================

def init_weights(num_layers, seed=42):
    rng = np.random.RandomState(seed)
    weights = []
    for _ in range(num_layers):
        W = np.eye(DIM) + rng.randn(DIM, DIM) * 0.1
        weights.append(W.copy())
    return weights


def forward(weights, X):
    out = X.copy()
    for W in weights:
        out = W @ out
    return out


def compute_loss(weights, X, target):
    pred = forward(weights, X)
    target_out = target @ X
    diff = pred - target_out
    return 0.5 * np.mean(np.sum(diff ** 2, axis=0))


def compute_gradients(weights, X, target):
    num_layers = len(weights)
    N = X.shape[1]
    activations = [X.copy()]
    out = X.copy()
    for W in weights:
        out = W @ out
        activations.append(out.copy())
    target_out = target @ X
    delta = (activations[-1] - target_out) / N
    grads = []
    for i in range(num_layers - 1, -1, -1):
        G = delta @ activations[i].T
        grads.insert(0, G)
        if i > 0:
            delta = weights[i].T @ delta
    return grads


def newton_schulz_orthogonalize(G, num_iters=NS_ITERS):
    norm = np.linalg.norm(G, ord='fro')
    if norm < 1e-12:
        return G
    X = G / norm
    for _ in range(num_iters):
        A = X.T @ X
        X = 1.5 * X - 0.5 * X @ A
    return X


def find_stable_lr_sgd():
    candidates = [0.05, 0.03, 0.02, 0.015, 0.01, 0.007, 0.005, 0.003, 0.001]
    for lr in candidates:
        np.random.seed(42)
        weights = init_weights(NUM_LAYERS)
        velocities = [np.zeros((DIM, DIM)) for _ in range(NUM_LAYERS)]
        initial_loss = compute_loss(weights, X_data, W_target)
        stable = True
        for step in range(200):
            grads = compute_gradients(weights, X_data, W_target)
            for i in range(NUM_LAYERS):
                velocities[i] = MOMENTUM * velocities[i] + grads[i]
                weights[i] -= lr * velocities[i]
            loss = compute_loss(weights, X_data, W_target)
            if np.isnan(loss) or loss > initial_loss * 50:
                stable = False
                break
        if stable:
            return lr
    return 0.001


def sgd_step(weights, velocities, lr):
    grads = compute_gradients(weights, X_data, W_target)
    for i in range(len(weights)):
        velocities[i] = MOMENTUM * velocities[i] + grads[i]
        weights[i] = weights[i] - lr * velocities[i]
    return weights, velocities


def muon_step(weights, velocities, lr):
    grads = compute_gradients(weights, X_data, W_target)
    for i in range(len(weights)):
        ortho_grad = newton_schulz_orthogonalize(grads[i])
        velocities[i] = MOMENTUM * velocities[i] + ortho_grad
        weights[i] = weights[i] - lr * velocities[i]
    return weights, velocities


# =============================================================================
# ENTROPY AND EFFECTIVE RANK
# =============================================================================

def shannon_entropy(eigenvalues):
    """
    Shannon entropy of normalized eigenvalue distribution.
    H = -sum(p_i * log(p_i))  where  p_i = lambda_i / sum(lambda_j)
    """
    eigs = np.maximum(eigenvalues, 0.0)
    total = np.sum(eigs)
    if total < 1e-30:
        return 0.0
    p = eigs / total
    p = p[p > 1e-30]  # avoid log(0)
    return -np.sum(p * np.log(p))


def effective_rank(eigenvalues):
    """
    Effective rank = exp(H) where H is Shannon entropy.
    For uniform spectrum: effective_rank = n
    For single dominant eigenvalue: effective_rank = 1
    """
    H = shannon_entropy(eigenvalues)
    return np.exp(H)


def fit_power_law_alpha(eigenvalues):
    eigs = np.sort(eigenvalues)[::-1]
    eigs = eigs[eigs > 1e-30]
    n = len(eigs)
    if n < 3:
        return np.nan
    ranks = np.arange(1, n + 1).astype(float)
    log_rank = np.log(ranks)
    log_eig = np.log(eigs)
    A = np.vstack([log_rank, np.ones(n)]).T
    result = np.linalg.lstsq(A, log_eig, rcond=None)
    slope = result[0][0]
    return -slope


