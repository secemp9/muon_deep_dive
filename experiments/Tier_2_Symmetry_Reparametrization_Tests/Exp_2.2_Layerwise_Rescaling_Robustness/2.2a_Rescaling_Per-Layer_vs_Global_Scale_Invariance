#!/usr/bin/env python3
"""
Exp 2.2a: Per-Layer vs Global Scale Invariance
================================================

KEY QUESTION: If we rescale a deep linear network so that layer 1 is
multiplied by c and layer 4 by 1/c (keeping the product W4*W3*W2*W1
unchanged), does Muon remain invariant while SGD degrades?

From Axiom 0.4: ortho(c*G) = ortho(G) for any scalar c > 0.
So Muon's step DIRECTION is invariant to per-layer rescaling.
However, the momentum buffer accumulates at different scales for
different layers, and the learning rate is shared.

Protocol:
  - 4-layer deep linear network, 32x32 matrices.
  - Standard init: each W_l ~ N(0, 1/32) so ||W_l||_F ~ 1.
  - Rescaled init: W_1 *= c, W_4 *= 1/c. Product W4*W3*W2*W1 unchanged.
  - Train 300 steps with SGD and Muon from each rescaled init.
  - Sweep c in {1, 2, 5, 10, 50, 100}.
  - Compare final loss across c values.

Prediction:
  - Muon: nearly invariant final loss (from scale invariance of ortho).
  - SGD: degrades significantly with c (gradient scale varies per layer).
"""

import numpy as np
import os

# =============================================================================
# CONFIGURATION
# =============================================================================

DIM = 32
N_LAYERS = 4
N_STEPS = 300
LR_MUON = 0.02
LR_SGD = 0.001
MOMENTUM_BETA = 0.9
NS_ITERS = 5
N_SAMPLES = 128
C_VALUES = [1, 2, 5, 10, 50, 100]
BASE_SEED = 42

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))


# =============================================================================
# NEWTON-SCHULZ ORTHOGONALIZATION
# =============================================================================

def newton_schulz(M, n_iters=NS_ITERS):
    """Newton-Schulz iteration: converges to polar factor of M."""
    norm = np.linalg.norm(M, ord='fro')
    if norm < 1e-15:
        return M
    X = M / norm
    for _ in range(n_iters):
        A = X.T @ X
        X = 1.5 * X - 0.5 * X @ A
    return X


# =============================================================================
# DEEP LINEAR NETWORK
# =============================================================================

def init_weights(dim, n_layers, rng, c=1.0):
    """
    Initialize a deep linear network with n_layers square matrices.
    Standard init: each W_l ~ N(0, 1/dim).
    Then rescale: W_1 *= c, W_{n_layers} *= 1/c.
    """
    weights = []
    for l in range(n_layers):
        W = rng.randn(dim, dim) / np.sqrt(dim)
        weights.append(W)
    # Rescale: layer 0 (first) by c, layer -1 (last) by 1/c
    weights[0] = weights[0] * c
    weights[-1] = weights[-1] / c
    return weights


def forward(weights, X):
    """Forward pass: y = W_L ... W_2 W_1 x."""
    out = X
    for W in weights:
        out = W @ out
    return out


def compute_product(weights):
    """Compute the effective weight product W_L ... W_1."""
    P = weights[0]
    for W in weights[1:]:
        P = W @ P
    return P


def compute_loss(weights, X, Y):
    """MSE loss: ||W_L...W_1 x - y||^2 / N."""
    pred = forward(weights, X)
    return np.mean((pred - Y) ** 2)


def compute_gradients(weights, X, Y):
    """
    Backprop for deep linear net. For layer l:
      dL/dW_l = (W_{l+1}...W_L)^T (pred - y) x^T (W_1...W_{l-1})^T / N
    """
    n_layers = len(weights)
    N = X.shape[1]

    # Forward pass: store activations
    activations = [X]
    for W in weights:
        activations.append(W @ activations[-1])

    # Output error
    pred = activations[-1]
    delta = 2.0 * (pred - Y) / N  # dL/d(output)

    # Backward pass
    grads = [None] * n_layers
    for l in range(n_layers - 1, -1, -1):
        grads[l] = delta @ activations[l].T
        if l > 0:
            delta = weights[l].T @ delta

    return grads


# =============================================================================
# TRAINING FUNCTIONS
# =============================================================================

def train_sgd(weights_init, X, Y, n_steps, lr):
    """Train with vanilla SGD + momentum."""
    weights = [W.copy() for W in weights_init]
    mom = [np.zeros_like(W) for W in weights]
    losses = []

    for step in range(n_steps):
        loss = compute_loss(weights, X, Y)
        losses.append(loss)
        grads = compute_gradients(weights, X, Y)
        for l in range(len(weights)):
            mom[l] = MOMENTUM_BETA * mom[l] + (1 - MOMENTUM_BETA) * grads[l]
            weights[l] = weights[l] - lr * mom[l]

    losses.append(compute_loss(weights, X, Y))
    return weights, losses


def train_muon(weights_init, X, Y, n_steps, lr):
    """Train with Muon (Newton-Schulz orthogonalized momentum)."""
    weights = [W.copy() for W in weights_init]
    mom = [np.zeros_like(W) for W in weights]
    losses = []

    for step in range(n_steps):
        loss = compute_loss(weights, X, Y)
        losses.append(loss)
        grads = compute_gradients(weights, X, Y)
        for l in range(len(weights)):
            mom[l] = MOMENTUM_BETA * mom[l] + (1 - MOMENTUM_BETA) * grads[l]
            ortho_mom = newton_schulz(mom[l])
            weights[l] = weights[l] - lr * ortho_mom

    losses.append(compute_loss(weights, X, Y))
    return weights, losses


# =============================================================================
# MAIN EXPERIMENT
# =============================================================================

print("=" * 90)
print("Exp 2.2a: PER-LAYER vs GLOBAL SCALE INVARIANCE")
print("=" * 90)
print(f"Network: {N_LAYERS}-layer deep linear, {DIM}x{DIM}")
print(f"Rescaling: W_1 *= c, W_4 *= 1/c (product preserved)")
print(f"Training: {N_STEPS} steps, momentum={MOMENTUM_BETA}")
print(f"LR: SGD={LR_SGD}, Muon={LR_MUON}")
print(f"c values: {C_VALUES}")
print()
print("PREDICTION:")
print("  Muon: nearly invariant (ortho(cG) = ortho(G))")
print("  SGD:  degrades with c (gradient scale varies per layer)")
print("=" * 90)

# Generate fixed data
rng_data = np.random.RandomState(BASE_SEED)
X = rng_data.randn(DIM, N_SAMPLES) * 0.3
# Target: a random linear map
W_target = rng_data.randn(DIM, DIM) / np.sqrt(DIM)
Y = W_target @ X + rng_data.randn(DIM, N_SAMPLES) * 0.01

# Store results
sgd_results = {}
muon_results = {}

for c in C_VALUES:
    # Same random seed for weights at each c (then rescale)
    rng_w = np.random.RandomState(BASE_SEED + 1000)
    weights_init = init_weights(DIM, N_LAYERS, rng_w, c=c)

    # Verify product is approximately the same
    product = compute_product(weights_init)
    init_loss = compute_loss(weights_init, X, Y)

    # Train SGD
    _, sgd_losses = train_sgd(weights_init, X, Y, N_STEPS, LR_SGD)
    sgd_results[c] = sgd_losses

    # Train Muon
    _, muon_losses = train_muon(weights_init, X, Y, N_STEPS, LR_MUON)
    muon_results[c] = muon_losses

    # Per-layer norms at init
    norms = [np.linalg.norm(W, 'fro') for W in weights_init]

    print(f"\nc = {c:>3}:")
    print(f"  Init layer norms: {['%.3f' % n for n in norms]}")
    print(f"  Product Frobenius norm: {np.linalg.norm(product, 'fro'):.4f}")
    print(f"  Init loss:  {init_loss:.6f}")
    print(f"  SGD  final: {sgd_losses[-1]:.6f}")
    print(f"  Muon final: {muon_losses[-1]:.6f}")


# =============================================================================
# INVARIANCE ANALYSIS
# =============================================================================

print(f"\n\n{'=' * 90}")
print("INVARIANCE ANALYSIS")
print(f"{'=' * 90}")

# Reference: c=1 final losses
sgd_ref = sgd_results[1][-1]
muon_ref = muon_results[1][-1]

print(f"\n{'c':>5}  {'SGD final':>12}  {'SGD ratio':>10}  {'Muon final':>12}  {'Muon ratio':>11}")
print("-" * 58)

for c in C_VALUES:
    sgd_final = sgd_results[c][-1]
    muon_final = muon_results[c][-1]
    sgd_ratio = sgd_final / max(sgd_ref, 1e-30)
    muon_ratio = muon_final / max(muon_ref, 1e-30)
    print(f"{c:>5}  {sgd_final:>12.6f}  {sgd_ratio:>10.3f}x  {muon_final:>12.6f}  {muon_ratio:>11.3f}x")


# =============================================================================
# LEARNING CURVES AT KEY c VALUES
# =============================================================================

print(f"\n\n{'=' * 90}")
print("LEARNING CURVES (loss at steps 0, 50, 100, 150, 200, 250, 300)")
print(f"{'=' * 90}")

checkpoints = [0, 50, 100, 150, 200, 250, 300]

print(f"\nSGD:")
header = f"{'c':>5}" + "".join(f"  {'s'+str(s):>10}" for s in checkpoints)
print(header)
print("-" * (5 + 12 * len(checkpoints)))
for c in C_VALUES:
    row = f"{c:>5}"
    for s in checkpoints:
        row += f"  {sgd_results[c][s]:>10.5f}"
    print(row)

print(f"\nMuon:")
print(header)
print("-" * (5 + 12 * len(checkpoints)))
for c in C_VALUES:
    row = f"{c:>5}"
    for s in checkpoints:
        row += f"  {muon_results[c][s]:>10.5f}"
    print(row)


# =============================================================================
# GRADIENT NORM ANALYSIS AT INIT
# =============================================================================

print(f"\n\n{'=' * 90}")
print("GRADIENT NORM ANALYSIS AT INIT (per layer)")
print(f"{'=' * 90}")

print(f"\n{'c':>5}  {'||G_1||':>10}  {'||G_2||':>10}  {'||G_3||':>10}  {'||G_4||':>10}  {'ratio max/min':>14}")
print("-" * 68)

for c in C_VALUES:
    rng_w = np.random.RandomState(BASE_SEED + 1000)
    weights_init = init_weights(DIM, N_LAYERS, rng_w, c=c)
    grads = compute_gradients(weights_init, X, Y)
    gnorms = [np.linalg.norm(g, 'fro') for g in grads]
    ratio = max(gnorms) / max(min(gnorms), 1e-30)
    print(f"{c:>5}  {gnorms[0]:>10.4f}  {gnorms[1]:>10.4f}  {gnorms[2]:>10.4f}  {gnorms[3]:>10.4f}  {ratio:>14.2f}")


# =============================================================================
# ORTHO GRADIENT ANALYSIS (Muon step directions)
# =============================================================================

print(f"\n\n{'=' * 90}")
print("ORTHO GRADIENT ANALYSIS: Does ortho(cG) = ortho(G)?")
print(f"{'=' * 90}")
print("Verify Axiom 0.4: NS(cM) = NS(M) for scalar c > 0.")

rng_w = np.random.RandomState(BASE_SEED + 1000)
weights_base = init_weights(DIM, N_LAYERS, rng_w, c=1.0)
grads_base = compute_gradients(weights_base, X, Y)

print(f"\n  For layer 1 gradient (most affected by rescaling):")
G1 = grads_base[0]
ortho_G1 = newton_schulz(G1)

for scale in [1, 2, 5, 10, 50, 100, 1000]:
    ortho_scaled = newton_schulz(G1 * scale)
    diff = np.linalg.norm(ortho_scaled - ortho_G1) / np.linalg.norm(ortho_G1)
    print(f"    c={scale:>4}: ||NS(cG) - NS(G)|| / ||NS(G)|| = {diff:.2e}")


# =============================================================================
# LOSS VARIANCE ACROSS c (key metric)
# =============================================================================

print(f"\n\n{'=' * 90}")
print("LOSS VARIANCE ACROSS c VALUES (invariance metric)")
print(f"{'=' * 90}")

sgd_finals = [sgd_results[c][-1] for c in C_VALUES]
muon_finals = [muon_results[c][-1] for c in C_VALUES]

sgd_cv = np.std(sgd_finals) / max(np.mean(sgd_finals), 1e-30)
muon_cv = np.std(muon_finals) / max(np.mean(muon_finals), 1e-30)

sgd_range = max(sgd_finals) / max(min(sgd_finals), 1e-30)
muon_range = max(muon_finals) / max(min(muon_finals), 1e-30)

print(f"\n  SGD:")
print(f"    Final losses:  {['%.6f' % l for l in sgd_finals]}")
print(f"    CV (std/mean): {sgd_cv:.4f}")
print(f"    Range (max/min): {sgd_range:.3f}x")

print(f"\n  Muon:")
print(f"    Final losses:  {['%.6f' % l for l in muon_finals]}")
print(f"    CV (std/mean): {muon_cv:.4f}")
print(f"    Range (max/min): {muon_range:.3f}x")


# =============================================================================
# HYPOTHESIS TESTS
# =============================================================================

print(f"\n\n{'=' * 90}")
print("HYPOTHESIS TESTS")
print(f"{'=' * 90}")

# H1: Muon's final loss is nearly invariant to c (CV < 0.1)
h1 = muon_cv < 0.1
print(f"\nH1: Muon final loss nearly invariant (CV < 0.1)?")
print(f"    CV = {muon_cv:.4f}")
print(f"    --> {'PASS' if h1 else 'FAIL'}")

# H2: SGD's final loss degrades significantly (CV > 0.3 or range > 2x)
h2 = sgd_cv > 0.3 or sgd_range > 2.0
print(f"\nH2: SGD final loss degrades with c (CV > 0.3 or range > 2x)?")
print(f"    CV = {sgd_cv:.4f}, range = {sgd_range:.3f}x")
print(f"    --> {'PASS' if h2 else 'FAIL'}")

# H3: Muon is more invariant than SGD (Muon CV < SGD CV)
h3 = muon_cv < sgd_cv
print(f"\nH3: Muon more invariant than SGD (Muon CV < SGD CV)?")
print(f"    Muon CV={muon_cv:.4f}, SGD CV={sgd_cv:.4f}")
print(f"    --> {'PASS' if h3 else 'FAIL'}")

# H4: ortho(cG) = ortho(G) verified (from Axiom 0.4)
ortho_test_errors = []
G_test = grads_base[0]
ortho_base = newton_schulz(G_test)
for s in [2, 5, 10, 50, 100]:
    err = np.linalg.norm(newton_schulz(G_test * s) - ortho_base) / np.linalg.norm(ortho_base)
    ortho_test_errors.append(err)
h4 = max(ortho_test_errors) < 1e-12
print(f"\nH4: ortho(cG) = ortho(G) exact (max error < 1e-12)?")
print(f"    Max error: {max(ortho_test_errors):.2e}")
print(f"    --> {'PASS' if h4 else 'FAIL'}")

# H5: Muon outperforms SGD at high c (c=100)
h5 = muon_results[100][-1] < sgd_results[100][-1]
print(f"\nH5: Muon beats SGD at c=100?")
print(f"    Muon: {muon_results[100][-1]:.6f}, SGD: {sgd_results[100][-1]:.6f}")
print(f"    --> {'PASS' if h5 else 'FAIL'}")

# H6: Muon at c=100 matches Muon at c=1 (within 2x)
muon_ratio_100 = muon_results[100][-1] / max(muon_results[1][-1], 1e-30)
h6 = muon_ratio_100 < 2.0
print(f"\nH6: Muon at c=100 within 2x of c=1?")
print(f"    Ratio: {muon_ratio_100:.3f}x")
print(f"    --> {'PASS' if h6 else 'FAIL'}")

total_pass = sum([h1, h2, h3, h4, h5, h6])


# =============================================================================
# FINAL VERDICT
# =============================================================================

print(f"\n\n{'=' * 90}")
print("FINAL VERDICT: Exp 2.2a PER-LAYER vs GLOBAL SCALE INVARIANCE")
print(f"{'=' * 90}")

print(f"""
  Rescaling: W_1 *= c, W_4 *= 1/c (product preserved)
  Network: {N_LAYERS}-layer deep linear, {DIM}x{DIM}
  Training: {N_STEPS} steps

  Muon invariance (CV across c): {muon_cv:.4f}
  SGD  invariance (CV across c): {sgd_cv:.4f}
  Invariance ratio (SGD_CV / Muon_CV): {sgd_cv / max(muon_cv, 1e-30):.1f}x

  Final losses at c=1 vs c=100:
    Muon: {muon_results[1][-1]:.6f} -> {muon_results[100][-1]:.6f} ({muon_ratio_100:.2f}x)
    SGD:  {sgd_results[1][-1]:.6f} -> {sgd_results[100][-1]:.6f} ({sgd_results[100][-1] / max(sgd_results[1][-1], 1e-30):.2f}x)

  Tests passed: {total_pass}/6
""")

if h1 and h3 and h4:
    print("  CONFIRMED: Muon is scale-invariant under per-layer rescaling.")
    print("  The Newton-Schulz orthogonalization normalizes away the scale")
    print("  imbalance that cripples SGD. This is a PRACTICAL consequence")
    print("  of Axiom 0.4: ortho(cG) = ortho(G).")
elif h3:
    print("  PARTIALLY CONFIRMED: Muon more invariant than SGD,")
    print("  but not perfectly invariant (momentum buffer effects).")
else:
    print("  SURPRISING: Muon not more invariant than SGD.")
    print("  Momentum buffer dynamics may dominate the NS normalization.")

print(f"\n{'=' * 90}")
