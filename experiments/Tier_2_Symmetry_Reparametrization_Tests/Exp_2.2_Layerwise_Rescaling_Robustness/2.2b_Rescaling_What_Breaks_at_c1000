# =============================================================================
# NEWTON-SCHULZ ORTHOGONALIZATION (with diagnostics)
# =============================================================================

def newton_schulz(M, n_iters=NS_ITERS, return_diagnostics=False):
    """Newton-Schulz iteration with optional convergence diagnostics."""
    norm = np.linalg.norm(M, ord='fro')
    if norm < 1e-15:
        if return_diagnostics:
            return M, {'input_norm': norm, 'converged': False, 'ortho_error': float('nan')}
        return M
    X = M / norm
    for _ in range(n_iters):
        A = X.T @ X
        X = 1.5 * X - 0.5 * X @ A

    if return_diagnostics:
        ortho_err = np.linalg.norm(X.T @ X - np.eye(X.shape[1]), 'fro')
        has_nan = np.any(np.isnan(X))
        has_inf = np.any(np.isinf(X))
        diag = {
            'input_norm': norm,
            'ortho_error': ortho_err,
            'has_nan': has_nan,
            'has_inf': has_inf,
            'output_norm': np.linalg.norm(X, 'fro'),
        }
        return X, diag

    return X


# =============================================================================
# DEEP LINEAR NETWORK
# =============================================================================

def init_weights(dim, n_layers, rng, c=1.0):
    """Init deep linear net, rescale layer 0 by c, layer -1 by 1/c."""
    weights = []
    for l in range(n_layers):
        W = rng.randn(dim, dim) / np.sqrt(dim)
        weights.append(W)
    weights[0] = weights[0] * c
    weights[-1] = weights[-1] / c
    return weights


def forward(weights, X):
    out = X
    for W in weights:
        out = W @ out
    return out


def compute_loss(weights, X, Y):
    pred = forward(weights, X)
    return np.mean((pred - Y) ** 2)


def compute_gradients(weights, X, Y):
    n_layers = len(weights)
    N = X.shape[1]
    activations = [X]
    for W in weights:
        activations.append(W @ activations[-1])
    pred = activations[-1]
    delta = 2.0 * (pred - Y) / N
    grads = [None] * n_layers
    for l in range(n_layers - 1, -1, -1):
        grads[l] = delta @ activations[l].T
        if l > 0:
            delta = weights[l].T @ delta
    return grads


# =============================================================================
# TRAINING WITH FULL DIAGNOSTICS
# =============================================================================

def train_with_diagnostics(weights_init, X, Y, n_steps, lr, optimizer='muon'):
    """
    Train and record comprehensive diagnostics at every step.
    """
    weights = [W.copy() for W in weights_init]
    mom = [np.zeros_like(W) for W in weights]
    n_layers = len(weights)

    history = {
        'loss': [],
        'grad_norms': [[] for _ in range(n_layers)],
        'weight_norms': [[] for _ in range(n_layers)],
        'mom_norms': [[] for _ in range(n_layers)],
        'ns_ortho_errors': [[] for _ in range(n_layers)],
        'ns_input_norms': [[] for _ in range(n_layers)],
        'has_nan': [],
        'has_inf': [],
    }

    for step in range(n_steps):
        loss = compute_loss(weights, X, Y)
        history['loss'].append(loss)

        # Check for numerical issues
        any_nan = any(np.any(np.isnan(W)) for W in weights) or np.isnan(loss)
        any_inf = any(np.any(np.isinf(W)) for W in weights) or np.isinf(loss)
        history['has_nan'].append(any_nan)
        history['has_inf'].append(any_inf)

        if any_nan or any_inf:
            # Fill remaining steps with NaN
            for s in range(step + 1, n_steps):
                history['loss'].append(float('nan'))
                history['has_nan'].append(True)
                history['has_inf'].append(True)
                for l in range(n_layers):
                    history['grad_norms'][l].append(float('nan'))
                    history['weight_norms'][l].append(float('nan'))
                    history['mom_norms'][l].append(float('nan'))
                    history['ns_ortho_errors'][l].append(float('nan'))
                    history['ns_input_norms'][l].append(float('nan'))
            history['loss'].append(float('nan'))
            break

        grads = compute_gradients(weights, X, Y)

        for l in range(n_layers):
            history['grad_norms'][l].append(np.linalg.norm(grads[l], 'fro'))
            history['weight_norms'][l].append(np.linalg.norm(weights[l], 'fro'))

            mom[l] = MOMENTUM_BETA * mom[l] + (1 - MOMENTUM_BETA) * grads[l]
            history['mom_norms'][l].append(np.linalg.norm(mom[l], 'fro'))

            if optimizer == 'muon':
                ortho_mom, diag = newton_schulz(mom[l], return_diagnostics=True)
                history['ns_ortho_errors'][l].append(diag['ortho_error'])
                history['ns_input_norms'][l].append(diag['input_norm'])
                weights[l] = weights[l] - lr * ortho_mom
            else:
                history['ns_ortho_errors'][l].append(0.0)
                history['ns_input_norms'][l].append(np.linalg.norm(mom[l], 'fro'))
                weights[l] = weights[l] - lr * mom[l]

    # Final loss
    if not (history['has_nan'][-1] if history['has_nan'] else False):
        history['loss'].append(compute_loss(weights, X, Y))

    return weights, history


