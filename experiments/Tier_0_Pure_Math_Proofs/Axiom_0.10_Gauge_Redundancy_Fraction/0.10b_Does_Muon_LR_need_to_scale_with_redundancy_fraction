def convergence_rate(n_W, n_cols_W, n_steps=100):
    """
    Run SGD and Muon with near-optimal LR and measure convergence rate.
    Sweeps LR for both methods to find best.
    """
    np.random.seed(42)
    m_A = max(n_W, n_cols_W) + 5
    # Well-conditioned A with condition number ~ 3
    A_raw = np.random.randn(m_A, n_W) / np.sqrt(m_A)
    # Compute spectral norm for LR calibration
    AtA = A_raw.T @ A_raw
    eigvals = np.linalg.eigvalsh(AtA)
    max_eig = eigvals[-1]

    A = A_raw
    B = np.random.randn(m_A, n_cols_W)
    W_init = np.random.randn(n_W, n_cols_W) * 0.01
    init_loss = quadratic_loss(W_init, A, B)

    # Sweep SGD LR
    best_rate_sgd = 0
    best_lr_sgd = 0
    for lr_frac in np.logspace(-1.5, -0.05, 10):
        lr = lr_frac / max_eig  # scale by spectral radius
        W = W_init.copy()
        diverged = False
        for _ in range(n_steps):
            g = quadratic_grad(W, A, B)
            W = W - lr * g
            if np.any(np.isnan(W)) or quadratic_loss(W, A, B) > init_loss * 10:
                diverged = True
                break
        if not diverged:
            final = quadratic_loss(W, A, B)
            if final < init_loss:
                rate = -np.log(max(final / init_loss, 1e-30)) / n_steps
                if rate > best_rate_sgd:
                    best_rate_sgd = rate
                    best_lr_sgd = lr

    # Sweep Muon LR
    best_rate_muon = 0
    best_lr_muon = 0
    for lr in np.logspace(-3.5, -0.5, 10):
        W = W_init.copy()
        diverged = False
        for _ in range(n_steps):
            g = quadratic_grad(W, A, B)
            W = W - lr * muon_update(g)
            if np.any(np.isnan(W)) or quadratic_loss(W, A, B) > init_loss * 10:
                diverged = True
                break
        if not diverged:
            final = quadratic_loss(W, A, B)
            if final < init_loss:
                rate = -np.log(max(final / init_loss, 1e-30)) / n_steps
                if rate > best_rate_muon:
                    best_rate_muon = rate
                    best_lr_muon = lr

    return best_rate_sgd, best_rate_muon, best_lr_sgd, best_lr_muon


