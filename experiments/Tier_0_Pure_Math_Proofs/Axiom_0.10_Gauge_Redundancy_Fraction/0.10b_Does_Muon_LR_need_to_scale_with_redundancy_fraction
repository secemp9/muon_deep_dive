"""
Axiom 0.10b — Does Muon's optimal LR scale with gauge redundancy fraction?

Theory: If gauge_fraction of the SGD step is wasted on gauge directions,
then the effective learning rate in physical directions is:

    eta_effective = eta / (1 - gauge_fraction)

Muon removes ALL gauge waste, so its full step is physical. Therefore:
    LR_Muon_optimal = LR_SGD_optimal * (1 - gauge_fraction)

For square (50% gauge): LR_Muon ~ 0.5 * LR_SGD
For tall (small gauge):  LR_Muon ~ LR_SGD (barely different)

This experiment verifies this prediction by:
  1. Showing G is 100% gauge at ortho(G) (the key identity)
  2. Measuring physical step fractions at random Stiefel points
  3. Comparing loss reduction per unit step for SGD vs Muon
  4. Verifying the speedup scales with gauge fraction

Builds on 0.10a: uses the gauge_fraction formula to predict the split.
"""

import numpy as np

np.random.seed(42)

# ─── Utilities ───────────────────────────────────────────────────────────────

def muon_update(G):
    """Muon update: polar projection of gradient G -> UV^T."""
    U, S, Vt = np.linalg.svd(G, full_matrices=False)
    return U @ Vt


def random_stiefel(m, n):
    """Random point on St(m,n)."""
    A = np.random.randn(m, n)
    Q, R = np.linalg.qr(A)
    Q = Q @ np.diag(np.sign(np.diag(R)))
    return Q


def project_tangent_normal(Q, X):
    """Project X into tangent/normal of St(m,n) at Q."""
    QtX = Q.T @ X
    S = (QtX + QtX.T) / 2
    N = Q @ S
    Z = X - N
    return Z, N


def gauge_fraction(rows, cols):
    """Compute gauge fraction for a rows x cols matrix."""
    n = min(rows, cols)
    m = max(rows, cols)
    return (n + 1) / (2 * m)


def quadratic_loss(W, A, B):
    """f(W) = ||AW - B||^2_F."""
    R = A @ W - B
    return np.sum(R**2)


def quadratic_grad(W, A, B):
    """Gradient: 2 * A^T (AW - B)."""
    return 2.0 * A.T @ (A @ W - B)


