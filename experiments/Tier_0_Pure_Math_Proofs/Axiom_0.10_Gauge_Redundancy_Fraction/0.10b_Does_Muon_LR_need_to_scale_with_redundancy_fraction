def measure_relative_reduction(n_W, n_cols_W, n_trials=200):
    """
    Measure loss reduction from one small SGD step vs one small Muon step.
    Uses infinitesimal step to stay in linear regime.
    Returns ratio of reductions (Muon / SGD) normalized by step norms.
    """
    m_A = max(n_W, n_cols_W) + 5

    sgd_reductions = []
    muon_reductions = []

    for trial in range(n_trials):
        np.random.seed(trial + 2000)
        A = np.random.randn(m_A, n_W) / np.sqrt(n_W)
        B = np.random.randn(m_A, n_cols_W)
        W = np.random.randn(n_W, n_cols_W) * 0.5

        G = quadratic_grad(W, A, B)
        g_norm = np.linalg.norm(G, 'fro')
        if g_norm < 1e-10:
            continue

        loss_init = quadratic_loss(W, A, B)

        # Small step size (linear regime)
        eta = 1e-4 / g_norm

        # SGD: step in -G direction, normalized
        W_sgd = W - eta * G
        loss_sgd = quadratic_loss(W_sgd, A, B)
        red_sgd = (loss_init - loss_sgd) / (eta * g_norm)  # reduction per unit step

        # Muon: step in -UV^T direction
        muon_dir = muon_update(G)
        muon_norm = np.linalg.norm(muon_dir, 'fro')
        W_muon = W - eta * muon_dir
        loss_muon = quadratic_loss(W_muon, A, B)
        red_muon = (loss_init - loss_muon) / (eta * muon_norm)  # reduction per unit step

        if red_sgd > 0:
            sgd_reductions.append(red_sgd)
            muon_reductions.append(red_muon)

    return np.mean(sgd_reductions), np.mean(muon_reductions)


