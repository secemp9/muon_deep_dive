#!/usr/bin/env python3
"""
Axiom 0.10c — Count gauge degrees of freedom in a full transformer.

For each weight matrix in a transformer, the gauge DOF count is:
    gauge_DOF = n(n+1)/2  where n = min(rows, cols)

This script computes the full "gauge budget" of GPT-2 Small, GPT-2 Medium,
and GPT-3, showing:
  1. Total parameters
  2. Total gauge DOF
  3. Overall gauge fraction
  4. Weighted average gauge fraction
  5. Predicted overall Muon speedup

Builds on 0.10a: uses the same gauge_fraction formula applied to every
weight matrix in the architecture.
"""

import numpy as np

# ─── Architecture Definitions ────────────────────────────────────────────────

def build_transformer_arch(name, n_layers, d_model, d_ff, n_heads, vocab_size):
    """
    Build a list of all weight matrices in a transformer.
    Returns list of (layer_name, rows, cols, count).
    """
    d_head = d_model // n_heads
    layers = []

    # Embedding
    layers.append(("Embedding", vocab_size, d_model, 1))

    # Per-block layers (repeated n_layers times)
    # Attention: Q, K, V projections (each d_model -> d_model)
    # These are often represented as d_model x d_model matrices
    # (combining all heads: each head is d_model x d_head, but stored as one big matrix)
    layers.append(("Attn Q proj", d_model, d_model, n_layers))
    layers.append(("Attn K proj", d_model, d_model, n_layers))
    layers.append(("Attn V proj", d_model, d_model, n_layers))
    layers.append(("Attn Out proj", d_model, d_model, n_layers))

    # MLP
    layers.append(("MLP Up proj", d_model, d_ff, n_layers))
    layers.append(("MLP Down proj", d_ff, d_model, n_layers))

    # LM Head (often tied with embedding, but we count it separately for analysis)
    layers.append(("LM Head", d_model, vocab_size, 1))

    # Layer norms and biases are NOT matrices — they have no gauge redundancy
    # We note them for completeness but don't include in gauge count
    # (LayerNorm: 2 * d_model params per layer, biases: various)

    return {"name": name, "n_layers": n_layers, "d_model": d_model,
            "d_ff": d_ff, "n_heads": n_heads, "vocab_size": vocab_size,
            "layers": layers}


# Define architectures
architectures = [
    build_transformer_arch("GPT-2 Small",  12, 768,   3072,  12, 50257),
    build_transformer_arch("GPT-2 Medium", 24, 1024,  4096,  16, 50257),
    build_transformer_arch("GPT-3 175B",   96, 12288, 49152, 96, 50257),
]

# ─── Gauge DOF Computation ───────────────────────────────────────────────────

def compute_gauge_stats(rows, cols):
    """Compute gauge DOF and fraction for a rows x cols matrix."""
    n = min(rows, cols)
    m = max(rows, cols)
    total_params = rows * cols
    gauge_dof = n * (n + 1) // 2
    gauge_frac = gauge_dof / total_params  # = (n+1)/(2m)
    physical_dof = total_params - gauge_dof
    return {
        "params": total_params,
        "gauge_dof": gauge_dof,
        "physical_dof": physical_dof,
        "gauge_frac": gauge_frac,
        "n": n,
        "m": m,
    }


# ─── Main Computation ───────────────────────────────────────────────────────

print("=" * 80)
print("AXIOM 0.10c: Gauge DOF Budget for Full Transformer Architectures")
print("=" * 80)
