        param_str = f"{total_params/1e9:.1f}B"
    elif total_params > 1e6:
        param_str = f"{total_params/1e6:.1f}M"
    else:
        param_str = f"{total_params:,}"

    print(f"{arch['name']:<18} {param_str:<16} {total_gauge:>14,} "
          f"{gauge_frac:<14.4%} {speedup:<14.4f}x")

print()

