        total_params += stats["params"] * count
        total_gauge += stats["gauge_dof"] * count

    gauge_frac = total_gauge / total_params
    weighted_avg = sum(
        compute_gauge_stats(rows, cols)["params"] * count *
        compute_gauge_stats(rows, cols)["gauge_frac"]
        for _, rows, cols, count in arch["layers"]
    ) / total_params
    speedup = 1.0 / (1.0 - weighted_avg)

    summary_data.append((arch["name"], total_params, total_gauge, gauge_frac, speedup))

    # Format large numbers
