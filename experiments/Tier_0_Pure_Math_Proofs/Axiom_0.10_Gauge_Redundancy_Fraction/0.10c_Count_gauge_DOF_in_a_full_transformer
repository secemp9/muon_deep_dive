    print("-" * 95)

    total_params = 0
    total_gauge = 0
    total_physical = 0
    layer_data = []

    for layer_name, rows, cols, count in arch["layers"]:
        stats = compute_gauge_stats(rows, cols)

        # Multiply by count (number of such layers in the model)
        layer_params = stats["params"] * count
        layer_gauge = stats["gauge_dof"] * count
        layer_physical = stats["physical_dof"] * count

        total_params += layer_params
        total_gauge += layer_gauge
        total_physical += layer_physical

        layer_data.append((layer_name, rows, cols, count, layer_params,
                           layer_gauge, layer_physical, stats["gauge_frac"]))

        print(f"{layer_name:<18} {rows}x{cols:<10} {count:<7} "
              f"{layer_params:<14,} {layer_gauge:<14,} "
              f"{stats['gauge_frac']:<12.4%} {layer_physical:<14,}")

    print("-" * 95)
    print(f"{'TOTAL':<18} {'—':<16} {'—':<7} "
          f"{total_params:<14,} {total_gauge:<14,} "
          f"{'—':<12} {total_physical:<14,}")
    print()

    # ─── Summary Statistics ──────────────────────────────────────────────────

    overall_gauge_frac = total_gauge / total_params
    weighted_avg_gauge = sum(lp * gf for _, _, _, _, lp, _, _, gf in layer_data) / total_params
    predicted_speedup = 1.0 / (1.0 - weighted_avg_gauge)

    print(f"  Summary for {arch['name']}:")
    print(f"    Total parameters:          {total_params:>14,}")
    print(f"    Total gauge DOF:           {total_gauge:>14,}")
    print(f"    Total physical DOF:        {total_physical:>14,}")
    print(f"    Overall gauge fraction:    {overall_gauge_frac:>14.4%}")
    print(f"    Weighted avg gauge frac:   {weighted_avg_gauge:>14.4%}")
    print(f"    Predicted Muon speedup:    {predicted_speedup:>14.4f}x")
    print()

    # ─── Gauge Budget Breakdown ──────────────────────────────────────────────

    print(f"  Gauge Budget (where the gauge DOF live):")
    print(f"  {'Layer Type':<18} {'% of total gauge':<20} {'% of total params':<20}")
    print(f"  {'-'*60}")

    for layer_name, rows, cols, count, lp, lg, lphys, gf in layer_data:
        pct_gauge = lg / total_gauge * 100
        pct_params = lp / total_params * 100
        print(f"  {layer_name:<18} {pct_gauge:>15.2f}%     {pct_params:>15.2f}%")

    print()

# ─── Cross-Architecture Comparison ──────────────────────────────────────────

