#!/usr/bin/env python3
"""
Experiment 0.3b -- Which symmetries does Adam PRESERVE?
========================================================

Axiom 0.3a showed that Adam breaks O(n) x O(n) equivariance.
But Adam is NOT symmetry-blind -- it respects a DISCRETE subgroup.

Adam's symmetry group: Perm(n) x {+/-1}^n  (the "signed permutation" group)
---------------------------------------------------------------------------
- Permutation matrices P:  Adam(P M P^T) = P Adam(M) P^T
  Why: permuting rows/cols just reorders entries; element-wise ops are
  order-independent.

- Diagonal sign matrices D = diag(+/-1,...,+/-1):
  Adam(D M D^T) = D Adam(M) D^T
  Why: (D M D^T)_{ij} = d_i * M_{ij} * d_j, so (D M D^T)^2_{ij} = M^2_{ij}
  (the signs cancel in the square).  Then Adam = G / (sqrt(G^2) + eps),
  and the signs factor out of numerator + denominator.

Combined: the "signed permutation" group has order 2^n * n!.  This is
a DISCRETE group.  For n = 768, it has ~10^(1900) elements -- huge, but
still discrete.

Muon's symmetry group: O(n) x O(n) (the full orthogonal group)
---------------------------------------------------------------
This is a CONTINUOUS Lie group of dimension n(n-1)/2 for each factor.
It strictly contains the signed permutation group.

The key insight: Muon removes MORE redundancy from the loss landscape
because its symmetry group is strictly larger (and continuous).

Hypothesis
----------
Adam's symmetry group is exactly Perm(n) x {+/-1}^n (signed permutations),
which has order 2^n * n!.  O(n) has dimension n(n-1)/2 and is continuous.
Adam fixes a discrete gauge; Muon fixes a continuous gauge.
The continuous group removes more redundancy.
"""

import numpy as np
from math import factorial, log10, lgamma

# ---------------------------------------------------------------------------
# Reproducibility
# ---------------------------------------------------------------------------
RNG = np.random.default_rng(42)

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
EPS = 1e-8

def adam_step(G, eps=EPS):
    """Simplified Adam step: G / (sqrt(G**2) + eps)."""
    return G / (np.sqrt(G ** 2) + eps)

def muon_step(G):
    """Muon step: UV^T from SVD (orthogonal projection)."""
    U, _, Vt = np.linalg.svd(G, full_matrices=False)
    return U @ Vt

def random_orthogonal(n, rng=RNG):
    """Uniformly random element of O(n) via QR of Gaussian."""
    A = rng.standard_normal((n, n))
    Q, R_qr = np.linalg.qr(A)
    Q = Q @ np.diag(np.sign(np.diag(R_qr)))
    return Q

def random_permutation_matrix(n, rng=RNG):
    """Random n x n permutation matrix."""
    perm = rng.permutation(n)
    P = np.zeros((n, n))
    P[np.arange(n), perm] = 1.0
    return P

def random_sign_matrix(n, rng=RNG):
    """Random diagonal matrix with +/-1 on the diagonal."""
    signs = rng.choice([-1.0, 1.0], size=n)
    return np.diag(signs)

def random_signed_permutation(n, rng=RNG):
    """Random signed permutation = D @ P (sign-flip then permute)."""
    P = random_permutation_matrix(n, rng)
    D = random_sign_matrix(n, rng)
    return D @ P

def equivariance_violation(step_fn, M, L, R_right=None):
    """
    Compute ||f(L M R^T) - L f(M) R^T||_F for square (L = R) case
    or ||f(L M L^T) - L f(M) L^T||_F when R_right is None.
    """
    if R_right is None:
        R_right = L
    left = step_fn(L @ M @ R_right.T)
    right = L @ step_fn(M) @ R_right.T
    return np.linalg.norm(left - right, 'fro')


