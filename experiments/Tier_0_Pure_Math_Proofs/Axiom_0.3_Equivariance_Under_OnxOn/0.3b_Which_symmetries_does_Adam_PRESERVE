print(f"  adam(D M D^T):\n{adam_of_signed}\n")
print(f"  D adam(M) D^T:\n{signed_adam}\n")
print(f"  Difference (should be ~0):\n{diff_sign}\n")
print(f"  ||adam(D M D^T) - D adam(M) D^T||_F = {frob_sign:.2e}")
print()
print("  Why this works:")
print("  ---------------")
print("  For diagonal D with d_i in {+1, -1}:")
print("    (D M D^T)_{ij} = d_i * M_{ij} * d_j")
print()
print("  The element-wise square:")
print("    [(D M D^T)^2]_{ij} = (d_i * M_{ij} * d_j)^2 = M_{ij}^2")
print("  because d_i^2 = d_j^2 = 1.  The signs cancel in the denominator!")
print()
print("  So adam(D M D^T)_{ij} = (d_i M_{ij} d_j) / (sqrt(M_{ij}^2) + eps)")
print("                        = d_i * d_j * [M_{ij} / (|M_{ij}| + eps)]")
print("                        = d_i * adam(M)_{ij} * d_j")
print("                        = (D adam(M) D^T)_{ij}")
print()

part2_pass = frob_sign < 1e-12
print(f"  {'PASS' if part2_pass else 'FAIL'}: "
      f"violation = {frob_sign:.2e} {'<' if part2_pass else '>='} 1e-12 (machine epsilon)")
print()


