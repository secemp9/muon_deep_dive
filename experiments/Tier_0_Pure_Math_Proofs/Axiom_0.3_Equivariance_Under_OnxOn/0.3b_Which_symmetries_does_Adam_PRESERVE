# PART 1: Permutation equivariance proof
# ===================================================================
print("=" * 72)
print("PART 1: Permutation equivariance -- Adam(P M P^T) = P Adam(M) P^T")
print("=" * 72)
print()

M = RNG.standard_normal((5, 5))
P = random_permutation_matrix(5)

adam_of_permuted = adam_step(P @ M @ P.T)
