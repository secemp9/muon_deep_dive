diff_perm = adam_of_permuted - permuted_adam
frob_perm = np.linalg.norm(diff_perm, 'fro')

print(f"  M (5x5 random):\n{M}\n")
print(f"  P (permutation matrix):\n{P}\n")
print(f"  adam(P M P^T):\n{adam_of_permuted}\n")
print(f"  P adam(M) P^T:\n{permuted_adam}\n")
print(f"  Difference (should be ~0):\n{diff_perm}\n")
print(f"  ||adam(P M P^T) - P adam(M) P^T||_F = {frob_perm:.2e}")
print()
print("  Why this works:")
print("  ---------------")
print("  A permutation matrix P just reorders rows and columns.")
print("  (P M P^T)_{ij} = M_{sigma(i), sigma(j)} for some permutation sigma.")
print("  Element-wise operations (squaring, division, sqrt) act on each")
print("  entry independently -- they don't care what ORDER entries appear in.")
print("  So adam(P M P^T)_{ij} = adam(M)_{sigma(i), sigma(j)} = (P adam(M) P^T)_{ij}.")
print()

part1_pass = frob_perm < 1e-12
print(f"  {'PASS' if part1_pass else 'FAIL'}: "
      f"violation = {frob_perm:.2e} {'<' if part1_pass else '>='} 1e-12 (machine epsilon)")
print()


