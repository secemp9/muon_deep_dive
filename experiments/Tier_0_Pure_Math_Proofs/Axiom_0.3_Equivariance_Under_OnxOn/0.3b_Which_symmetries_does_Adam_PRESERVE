adam_of_signed = adam_step(D @ M @ D.T)
signed_adam    = D @ adam_step(M) @ D.T
diff_sign = adam_of_signed - signed_adam
frob_sign = np.linalg.norm(diff_sign, 'fro')

print(f"  D = diag({np.diag(D).astype(int)})")
