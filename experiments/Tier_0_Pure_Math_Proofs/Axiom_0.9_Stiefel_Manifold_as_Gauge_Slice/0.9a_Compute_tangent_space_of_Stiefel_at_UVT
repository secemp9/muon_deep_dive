#!/usr/bin/env python3
"""
Axiom 0.9a — Compute tangent space of Stiefel manifold at UV^T:
             what directions are 'physical'?

The tangent space T_Q St(m,n) at Q = UV^T consists of matrices Z such that
Q^T Z + Z^T Q = 0 (skew-symmetric constraint).

    dim St(m,n) = mn - n(n+1)/2
    dim normal  = n(n+1)/2

Physical directions (tangent) change the orbit.
Gauge directions (normal) stay within the same orbit (fiber).

For square n×n matrices, gauge fraction → 1/2 as n→∞.
This means SGD wastes ~50% of its step on gauge directions for square layers.
Muon, by construction, steps only in physical directions.
"""

import numpy as np

np.random.seed(42)

# ─── Utilities ───────────────────────────────────────────────────────────────

def random_stiefel(m, n):
    """Generate a random point Q ∈ St(m,n) via QR decomposition."""
    A = np.random.randn(m, n)
    Q, R = np.linalg.qr(A)
    # Fix sign ambiguity to get uniform distribution on Stiefel
    Q = Q @ np.diag(np.sign(np.diag(R)))
    return Q


def sym(A):
    """Symmetric part of a square matrix."""
    return (A + A.T) / 2


def project_tangent_normal(Q, X):
    """
    Project X onto tangent and normal spaces of Stiefel at Q.

    Tangent space T_Q St(m,n) = {Z : Q^T Z is skew-symmetric}
    Normal space N_Q St(m,n) = {Q S : S ∈ Sym(n)}

    Decomposition: X = Z + Q·sym(Q^T X)
        where Z = X - Q·sym(Q^T X)  (tangent component)
              N = Q·sym(Q^T X)       (normal component)

    For the full Stiefel tangent space when m > n, the tangent space also
    includes the component in the orthogonal complement of Q's column space.
    The correct projection is:
        Z = (I - QQ^T)X + Q·skew(Q^T X)   [tangent]
        N = Q·sym(Q^T X)                    [normal]
    """
    m, n = Q.shape
    QtX = Q.T @ X
    S = sym(QtX)           # symmetric part → normal direction
    N = Q @ S              # normal component (gauge)
    Z = X - N              # tangent component (physical)
    return Z, N


def verify_tangent(Q, Z, tol=1e-10):
    """Verify Z is in tangent space: Q^T Z + Z^T Q should be zero (skew condition)."""
    check = Q.T @ Z + Z.T @ Q
    return np.max(np.abs(check)) < tol


