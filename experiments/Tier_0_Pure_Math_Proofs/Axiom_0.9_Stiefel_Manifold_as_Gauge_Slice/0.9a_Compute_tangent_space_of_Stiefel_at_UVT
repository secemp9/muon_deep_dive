print("=" * 72)
print()

for m, n in [(4, 4), (8, 4), (10, 5)]:
    Q = random_stiefel(m, n)
    X = np.random.randn(m, n)
    Z, N = project_tangent_normal(Q, X)

    # Verify decomposition
    recon_err = np.linalg.norm(Z + N - X) / np.linalg.norm(X)

    # Verify Z is tangent: Q^T Z should be skew-symmetric
    QtZ = Q.T @ Z
    skew_err = np.max(np.abs(QtZ + QtZ.T))

    # Verify N is normal: N = QS for symmetric S
    # S = sym(Q^T X), check N = Q @ S
    S = sym(Q.T @ X)
    normal_err = np.linalg.norm(N - Q @ S)

    # Verify orthogonality of tangent and normal components
    # In the Frobenius inner product: <Z, N>_F = tr(Z^T N) = tr(Z^T Q S)
    # = tr((Q^T Z)^T S) = tr(skew(Q^TX)^T · S) = 0 (skew ⊥ sym)
    ortho = np.abs(np.trace(Z.T @ N))

    print(f"  Shape {m}×{n}:")
    print(f"    Reconstruction error:  {recon_err:.2e}")
    print(f"    Skew-symmetry of Q^TZ: {skew_err:.2e}")
    print(f"    Normal form error:     {normal_err:.2e}")
    print(f"    Orthogonality <Z,N>:   {ortho:.2e}")
    is_tangent = verify_tangent(Q, Z)
    print(f"    Z in tangent space:    {is_tangent}")
    print()

