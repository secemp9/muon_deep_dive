    print(f"  {name:>10s}  {c_spec:>14.6f}  {c_frob:>14.6f}  {t_dec:>16.6f}  {eff_spec:>12.6f}  {eff_frob:>12.6f}")
print()

spec_eff_sgd = total_dec_sgd / cum_spec_sgd if cum_spec_sgd > 1e-30 else 0.0
