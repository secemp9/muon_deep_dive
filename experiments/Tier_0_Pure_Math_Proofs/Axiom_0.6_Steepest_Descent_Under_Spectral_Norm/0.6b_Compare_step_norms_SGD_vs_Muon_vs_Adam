muon_converges = all(losses_muon[i+1] <= losses_muon[i] + tol for i in range(n_steps))
adam_converges = all(losses_adam[i+1] <= losses_adam[i] + tol for i in range(n_steps))

check(sgd_converges, "SGD loss is monotonically decreasing (exact line search)")
check(muon_converges, "Muon loss is monotonically decreasing (exact line search)")
check(adam_converges, "Adam loss is monotonically decreasing (exact line search)")
print()

# Total loss decrease
total_dec_sgd = losses_sgd[0] - losses_sgd[-1]
total_dec_muon = losses_muon[0] - losses_muon[-1]
total_dec_adam = losses_adam[0] - losses_adam[-1]
