# Per-step norms
print(f"  Per-step spectral norms:")
print(f"  {'Step':>6s}  {'||D_SGD||_op':>14s}  {'||D_Muon||_op':>14s}  {'||D_Adam||_op':>14s}")
print(f"  {'-' * 6}  {'-' * 14}  {'-' * 14}  {'-' * 14}")
for step in range(n_steps):
    print(f"  {step:>6d}  {spec_norms_sgd[step]:>14.8f}  {spec_norms_muon[step]:>14.8f}  {spec_norms_adam[step]:>14.8f}")
