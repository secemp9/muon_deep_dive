sep("SECTION 6: Multi-step trajectory (10 steps)")

print("  Starting from the same W_init, take 10 gradient steps with each optimizer.")
print("  For fair comparison, every optimizer uses a per-step line search to find")
print("  the LR that minimizes the loss at each step.  This ensures each optimizer")
print("  is doing its BEST, so we measure the geometry advantage purely.")
print()

n_steps = 10

# Use a moderately ill-conditioned A
kappa_multi = 10.0
s_multi = np.linspace(1.0, kappa_multi, 5)
A_multi = U_base @ np.diag(s_multi) @ V_base.T
B_multi = rng.standard_normal((5, 5))
W_multi_init = rng.standard_normal((5, 5))

print(f"  A condition number: {kappa_multi}")
print(f"  A singular values: {s_multi}")
print(f"  Initial loss: {quadratic_loss(A_multi, W_multi_init, B_multi):.6f}")
print()

def exact_line_search_quadratic(A, B, W, direction):
    """For f(W) = ||AW-B||^2_F, find optimal eta for W - eta*D.
    f(W - eta*D) = f(W) - eta*tr(G^T D) + eta^2 * ||AD||^2_F
    Minimized at eta* = tr(G^T D) / (2 * ||AD||^2_F)."""
    G_ls = quadratic_grad(A, W, B)
    numerator = np.sum(G_ls * direction)
    denominator = 2.0 * np.sum((A @ direction) ** 2)
    if denominator < 1e-30:
        return 0.0
    return numerator / denominator

# Run trajectories with per-step exact line search
losses_sgd = np.zeros(n_steps + 1)
losses_muon = np.zeros(n_steps + 1)
losses_adam = np.zeros(n_steps + 1)

spec_norms_sgd = np.zeros(n_steps)
spec_norms_muon = np.zeros(n_steps)
spec_norms_adam = np.zeros(n_steps)

frob_norms_sgd = np.zeros(n_steps)
frob_norms_muon = np.zeros(n_steps)
frob_norms_adam = np.zeros(n_steps)

W_sgd = W_multi_init.copy()
W_muon = W_multi_init.copy()
W_adam = W_multi_init.copy()

losses_sgd[0] = quadratic_loss(A_multi, W_sgd, B_multi)
losses_muon[0] = quadratic_loss(A_multi, W_muon, B_multi)
losses_adam[0] = quadratic_loss(A_multi, W_adam, B_multi)

for step in range(n_steps):
    # SGD with exact line search
    G_s = quadratic_grad(A_multi, W_sgd, B_multi)
    dir_s = G_s
    lr_s = exact_line_search_quadratic(A_multi, B_multi, W_sgd, dir_s)
    Delta_s = lr_s * dir_s
    W_sgd = W_sgd - Delta_s
    losses_sgd[step + 1] = quadratic_loss(A_multi, W_sgd, B_multi)
    spec_norms_sgd[step] = np.linalg.svd(Delta_s, compute_uv=False)[0]
    frob_norms_sgd[step] = np.linalg.norm(Delta_s, 'fro')

    # Muon with exact line search
    G_m = quadratic_grad(A_multi, W_muon, B_multi)
    dir_m = ortho(G_m)
    lr_m = exact_line_search_quadratic(A_multi, B_multi, W_muon, dir_m)
    Delta_m = lr_m * dir_m
    W_muon = W_muon - Delta_m
    losses_muon[step + 1] = quadratic_loss(A_multi, W_muon, B_multi)
    spec_norms_muon[step] = np.linalg.svd(Delta_m, compute_uv=False)[0]
    frob_norms_muon[step] = np.linalg.norm(Delta_m, 'fro')

    # Adam with exact line search on the Adam direction
    G_a = quadratic_grad(A_multi, W_adam, B_multi)
    dir_a = adam_direction(G_a, eps_adam)
    lr_a = exact_line_search_quadratic(A_multi, B_multi, W_adam, dir_a)
    Delta_a = lr_a * dir_a
    W_adam = W_adam - Delta_a
    losses_adam[step + 1] = quadratic_loss(A_multi, W_adam, B_multi)
    spec_norms_adam[step] = np.linalg.svd(Delta_a, compute_uv=False)[0]
    frob_norms_adam[step] = np.linalg.norm(Delta_a, 'fro')

# Print loss trajectory
subsep("Loss trajectory (exact line search at each step)")
print(f"  {'Step':>6s}  {'Loss SGD':>14s}  {'Loss Muon':>14s}  {'Loss Adam':>14s}")
print(f"  {'-' * 6}  {'-' * 14}  {'-' * 14}  {'-' * 14}")
for step in range(n_steps + 1):
