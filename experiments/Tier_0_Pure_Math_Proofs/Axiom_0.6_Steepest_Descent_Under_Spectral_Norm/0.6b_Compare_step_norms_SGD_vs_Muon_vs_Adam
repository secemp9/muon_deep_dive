#!/usr/bin/env python3
"""
Axiom 0.6b -- Compare step norms: ||Delta_SGD||_F vs ||Delta_Muon||_F vs ||Delta_Adam||_F
                for the SAME loss decrease

For a quadratic loss f(W) = ||AW - B||^2_F with known A, B, we compute the
gradient G = 2 A^T (AW - B) and then form the update step under three optimizers:

    SGD:   Delta = eta_sgd  * G
    Muon:  Delta = eta_muon * ortho(G)          (polar factor UV^T)
    Adam:  Delta = eta_adam * G / (sqrt(G^2) + eps)

We match learning rates so that the first-order loss decrease  tr(G^T Delta)
is IDENTICAL for all three.  Then we measure the cost of that step under
several matrix norms:  Frobenius, spectral (operator), nuclear, and
element-wise max.

Hypothesis:
  - Muon achieves the same loss decrease with the smallest spectral norm
    (||Delta_Muon||_op < ||Delta_SGD||_op).
  - SGD achieves the same loss decrease with the smallest Frobenius norm
    (||Delta_SGD||_F < ||Delta_Muon||_F).
  - Adam achieves the smallest element-wise max norm.
  - Each optimizer is optimal in its own geometry.
  - For gradients with more spread singular values, Muon's spectral
    advantage grows.

Sections:
  1. Setup and single-step comparison (matched first-order loss decrease)
  2. Actual (exact) loss decrease -- second-order effects
  3. Condition number sweep  kappa in {1, 2, 5, 10, 50, 100, 1000}
  4. Efficiency ratios (spectral vs Frobenius) across kappa
  5. Rectangular weight matrices (8x5 -> 5x3 -> 8x3)
  6. Multi-step trajectory (10 steps)
  7. Statistical validation across 50 random problems
  8. Final verdict
"""

import numpy as np

# ---------------------------------------------------------------------------
#  Helpers
# ---------------------------------------------------------------------------

def sep(title: str) -> None:
    """Print a section separator."""
    print(f"\n{'=' * 76}")
    print(f"  {title}")
    print(f"{'=' * 76}\n")


def subsep(title: str) -> None:
    """Print a subsection separator."""
    print(f"\n  {'-' * 70}")
    print(f"    {title}")
    print(f"  {'-' * 70}\n")


def mat(name: str, A: np.ndarray) -> None:
    """Pretty-print a labelled matrix."""
    rows, cols = A.shape
    print(f"  {name}  (shape {rows}x{cols}):")
    show_r = min(rows, 6)
    show_c = min(cols, 6)
    for i in range(show_r):
        vals = "  ".join(f"{A[i, j]: .8f}" for j in range(show_c))
        suffix = "  ..." if cols > show_c else ""
        print(f"    [{vals}{suffix}]")
    if rows > show_r:
        print(f"    ... ({rows - show_r} more rows)")
    print()


def ortho(M: np.ndarray) -> np.ndarray:
    """Compute the polar factor Q = U V^T via thin SVD."""
    U, _s, Vt = np.linalg.svd(M, full_matrices=False)
    return U @ Vt


def pf(ok: bool) -> str:
    """Return PASS or FAIL string."""
    return "PASS" if ok else "FAIL"


# Global tracking
all_pass = True
total_checks = 0
total_failures = 0


def check(condition: bool, label: str) -> bool:
    """Record a pass/fail check."""
    global all_pass, total_checks, total_failures
    total_checks += 1
    if not condition:
        all_pass = False
        total_failures += 1
    print(f"    [{pf(condition)}]  {label}")
    return condition


rng = np.random.default_rng(42)
tol = 1e-8
eps_adam = 1e-8  # Adam epsilon


# ---------------------------------------------------------------------------
#  Core routines for the experiment
# ---------------------------------------------------------------------------

def quadratic_loss(A, W, B):
    """f(W) = ||AW - B||^2_F"""
    R = A @ W - B
    return np.sum(R ** 2)


def quadratic_grad(A, W, B):
    """Gradient: G = 2 A^T (AW - B)"""
    return 2.0 * A.T @ (A @ W - B)


def adam_direction(G, eps=1e-8):
    """Adam-like direction: G / (sqrt(G^2) + eps).  Single-step approximation
    where the second-moment estimate v = G^2 (no history)."""
    return G / (np.sqrt(G ** 2) + eps)


def match_lr_for_target(G, direction, target_decrease):
    """Find learning rate eta such that tr(G^T (eta * direction)) = target_decrease.
    Returns eta.  If tr(G^T direction) ~ 0, returns 0."""
    inner = np.sum(G * direction)
    if abs(inner) < 1e-30:
        return 0.0
    return target_decrease / inner


def compute_all_norms(Delta):
    """Return dict of matrix norms for a step Delta."""
    sv = np.linalg.svd(Delta, compute_uv=False)
    return {
        "frob": np.linalg.norm(Delta, 'fro'),
        "op": sv[0],
        "nuc": np.sum(sv),
        "max": np.max(np.abs(Delta)),
    }


def run_single_step_comparison(A, B, W, target_decrease=None):
    """Run the three-optimizer comparison at a single point W.
    Returns a dict of results for each optimizer."""
    G = quadratic_grad(A, W, B)
    loss_init = quadratic_loss(A, W, B)

    # Compute raw directions
    dir_sgd = G
    dir_muon = ortho(G)
    dir_adam = adam_direction(G, eps_adam)

    # First-order loss decrease for unit-lr step: tr(G^T direction)
    fo_sgd = np.sum(G * dir_sgd)

    # Choose target = first-order decrease from SGD at a small lr
    if target_decrease is None:
        target_decrease = 0.01 * fo_sgd  # small step for linearity

    # Match learning rates
    eta_sgd = match_lr_for_target(G, dir_sgd, target_decrease)
    eta_muon = match_lr_for_target(G, dir_muon, target_decrease)
    eta_adam = match_lr_for_target(G, dir_adam, target_decrease)

    # Compute actual steps
    Delta_sgd = eta_sgd * dir_sgd
    Delta_muon = eta_muon * dir_muon
    Delta_adam = eta_adam * dir_adam

    # Verify first-order decrease matches
    fo_check_sgd = np.sum(G * Delta_sgd)
    fo_check_muon = np.sum(G * Delta_muon)
    fo_check_adam = np.sum(G * Delta_adam)

    # Compute norms of each step
    norms_sgd = compute_all_norms(Delta_sgd)
    norms_muon = compute_all_norms(Delta_muon)
    norms_adam = compute_all_norms(Delta_adam)

    # Compute actual loss after step (exact for quadratic)
    loss_sgd = quadratic_loss(A, W - Delta_sgd, B)
    loss_muon = quadratic_loss(A, W - Delta_muon, B)
    loss_adam = quadratic_loss(A, W - Delta_adam, B)

    actual_dec_sgd = loss_init - loss_sgd
    actual_dec_muon = loss_init - loss_muon
    actual_dec_adam = loss_init - loss_adam

    return {
        "G": G,
        "loss_init": loss_init,
        "target_decrease": target_decrease,
        "fo_check": {"sgd": fo_check_sgd, "muon": fo_check_muon, "adam": fo_check_adam},
        "eta": {"sgd": eta_sgd, "muon": eta_muon, "adam": eta_adam},
        "Delta": {"sgd": Delta_sgd, "muon": Delta_muon, "adam": Delta_adam},
        "norms": {"sgd": norms_sgd, "muon": norms_muon, "adam": norms_adam},
        "actual_decrease": {"sgd": actual_dec_sgd, "muon": actual_dec_muon, "adam": actual_dec_adam},
    }


# ===================================================================
#  SECTION 1 -- Setup and single-step comparison
# ===================================================================

sep("SECTION 1: Setup and single-step comparison (matched first-order loss decrease)")

print("  Quadratic loss: f(W) = ||AW - B||^2_F")
print("  Gradient:       G = 2 A^T (AW - B)")
print()
print("  For each optimizer, we find learning rate eta so that the first-order")
print("  loss decrease tr(G^T Delta) is identical.  Then we compare the cost")
print("  of that step under different matrix norms.")
print()

# Setup: 5x5 problem
m, n = 5, 5
A = rng.standard_normal((m, n))
B = rng.standard_normal((m, n))
W_init = rng.standard_normal((n, n))

mat("A", A)
mat("B", B)
mat("W_init", W_init)

G = quadratic_grad(A, W_init, B)
mat("G = gradient at W_init", G)

# Show gradient singular values (important for understanding geometry)
sv_G = np.linalg.svd(G, compute_uv=False)
print(f"  Singular values of G: {sv_G}")
print(f"  Condition number of G: {sv_G[0] / sv_G[-1]:.2f}")
print()

# Run comparison
res = run_single_step_comparison(A, B, W_init)

# Verify first-order decreases match
subsep("First-order decrease matching")
print(f"  Target first-order decrease: {res['target_decrease']:.8f}")
print(f"  SGD  first-order decrease:   {res['fo_check']['sgd']:.8f}")
print(f"  Muon first-order decrease:   {res['fo_check']['muon']:.8f}")
print(f"  Adam first-order decrease:   {res['fo_check']['adam']:.8f}")
print()
print(f"  Learning rates: eta_sgd = {res['eta']['sgd']:.8e}")
print(f"                  eta_muon = {res['eta']['muon']:.8e}")
print(f"                  eta_adam = {res['eta']['adam']:.8e}")
print()

check(abs(res['fo_check']['sgd'] - res['target_decrease']) / res['target_decrease'] < 1e-10,
      "SGD first-order decrease matches target")
check(abs(res['fo_check']['muon'] - res['target_decrease']) / res['target_decrease'] < 1e-10,
      "Muon first-order decrease matches target")
check(abs(res['fo_check']['adam'] - res['target_decrease']) / res['target_decrease'] < 1e-10,
      "Adam first-order decrease matches target")
print()

# Compare norms
subsep("Step norms for matched first-order decrease")

header = f"  {'Optimizer':>10s}  {'||D||_F':>12s}  {'||D||_op':>12s}  {'||D||_*':>12s}  {'||D||_max':>12s}"
print(header)
print(f"  {'-' * 10}  {'-' * 12}  {'-' * 12}  {'-' * 12}  {'-' * 12}")
for opt in ["sgd", "muon", "adam"]:
    nm = res["norms"][opt]
    print(f"  {opt.upper():>10s}  {nm['frob']:>12.8f}  {nm['op']:>12.8f}  {nm['nuc']:>12.8f}  {nm['max']:>12.8f}")
print()

# Check the hypothesis: Muon has smallest spectral norm
check(res["norms"]["muon"]["op"] < res["norms"]["sgd"]["op"],
      f"||Delta_Muon||_op < ||Delta_SGD||_op  ({res['norms']['muon']['op']:.8f} < {res['norms']['sgd']['op']:.8f})")
check(res["norms"]["muon"]["op"] < res["norms"]["adam"]["op"],
      f"||Delta_Muon||_op < ||Delta_Adam||_op  ({res['norms']['muon']['op']:.8f} < {res['norms']['adam']['op']:.8f})")

# Check: SGD has smallest Frobenius norm
check(res["norms"]["sgd"]["frob"] < res["norms"]["muon"]["frob"],
      f"||Delta_SGD||_F < ||Delta_Muon||_F  ({res['norms']['sgd']['frob']:.8f} < {res['norms']['muon']['frob']:.8f})")

# Check: Adam has smallest element-wise max norm
check(res["norms"]["adam"]["max"] < res["norms"]["sgd"]["max"],
      f"||Delta_Adam||_max < ||Delta_SGD||_max  ({res['norms']['adam']['max']:.8f} < {res['norms']['sgd']['max']:.8f})")
check(res["norms"]["adam"]["max"] < res["norms"]["muon"]["max"],
      f"||Delta_Adam||_max < ||Delta_Muon||_max  ({res['norms']['adam']['max']:.8f} < {res['norms']['muon']['max']:.8f})")
print()

print("  Interpretation:")
print("    For the SAME first-order loss decrease:")
print("    - Muon uses the smallest spectral norm (fewest 'loud' singular values).")
print("      This is the Von Neumann trace inequality: ortho(G) maximizes tr(G^T D)")
print("      per unit ||D||_op, so matching the decrease requires the smallest ||D||_op.")
print("    - SGD uses the smallest Frobenius norm (smallest total 'energy').")
print("      The gradient direction maximizes tr(G^T D) per unit ||D||_F.")
print("    - Adam uses the smallest element-wise max (no single parameter moves far).")
print("      The sign-like direction maximizes tr(G^T D) per unit ||D||_inf.")
print("    Each optimizer is optimal in its OWN geometry.")
print()


# ===================================================================
#  SECTION 2 -- Actual loss decrease (second-order effects)
# ===================================================================

sep("SECTION 2: Actual loss decrease (exact, not just first-order)")

print("  For the quadratic f(W) = ||AW - B||^2_F, we can compute the exact loss")
print("  after each step.  The actual decrease may differ from the first-order")
print("  prediction due to curvature (the Hessian term).")
print()
print("  f(W - Delta) = f(W) - tr(G^T Delta) + ||A Delta||^2_F")
print("  actual_decrease = tr(G^T Delta) - ||A Delta||^2_F")
print("                  = first_order_decrease - second_order_penalty")
print()

fo_target = res["target_decrease"]
print(f"  Matched first-order decrease:  {fo_target:.8f}")
print()

header2 = f"  {'Optimizer':>10s}  {'1st-order':>14s}  {'2nd-order penalty':>18s}  {'Actual decrease':>16s}  {'Ratio actual/1st':>18s}"
print(header2)
print(f"  {'-' * 10}  {'-' * 14}  {'-' * 18}  {'-' * 16}  {'-' * 18}")
for opt in ["sgd", "muon", "adam"]:
    Delta = res["Delta"][opt]
    second_order = np.sum((A @ Delta) ** 2)
    actual = res["actual_decrease"][opt]
    ratio_fo = actual / fo_target if abs(fo_target) > 1e-30 else 0.0
    print(f"  {opt.upper():>10s}  {fo_target:>14.8f}  {second_order:>18.8f}  {actual:>16.8f}  {ratio_fo:>18.6f}")
print()

# The actual decrease differs from first-order because of the second-order term
# For small steps, all three should be close
print("  For small steps (eta << 1), the second-order penalty is negligible")
print("  and all three optimizers achieve nearly the same actual decrease.")
print()

# Check: all actual decreases are positive (the step actually helps)
for opt in ["sgd", "muon", "adam"]:
    check(res["actual_decrease"][opt] > 0,
          f"{opt.upper()} actual decrease > 0  ({res['actual_decrease'][opt]:.8f})")
print()

# Show second-order differences
second_order_sgd = np.sum((A @ res["Delta"]["sgd"]) ** 2)
second_order_muon = np.sum((A @ res["Delta"]["muon"]) ** 2)
second_order_adam = np.sum((A @ res["Delta"]["adam"]) ** 2)

print(f"  Second-order penalties:")
print(f"    SGD:  ||A Delta_SGD||^2_F  = {second_order_sgd:.8e}")
print(f"    Muon: ||A Delta_Muon||^2_F = {second_order_muon:.8e}")
print(f"    Adam: ||A Delta_Adam||^2_F = {second_order_adam:.8e}")
print()
print("  The second-order penalty depends on how the step interacts with A,")
print("  not just on the step norm.  This is where 'matching the loss landscape'")
print("  matters -- the optimal geometry depends on the curvature structure.")
print()


# ===================================================================
#  SECTION 3 -- Condition number sweep
# ===================================================================

sep("SECTION 3: Condition number sweep")

print("  We construct A with controlled condition number kappa and repeat the")
print("  single-step comparison.  The gradient G = 2 A^T(AW-B) inherits structure")
print("  from A.  We use a TINY step (0.1% of ||G||^2_F) to stay in the linear regime.")
print()
print("  Analytical derivation of the spectral advantage ratio:")
print()
print("    SGD step:  Delta_SGD = eta_s * G")
print("      ||Delta_SGD||_op = eta_s * sigma_1(G)")
print("      tr(G^T Delta_SGD) = eta_s * ||G||_F^2")
print()
print("    Muon step: Delta_Muon = eta_m * ortho(G)")
print("      ||Delta_Muon||_op = eta_m * 1 = eta_m")
print("      tr(G^T Delta_Muon) = eta_m * ||G||_*  (nuclear norm)")
print()
print("    Matching: eta_s * ||G||_F^2 = eta_m * ||G||_*")
print("    =>  eta_s = eta_m * ||G||_* / ||G||_F^2")
print()
print("    Ratio of spectral norms:")
print("      ||D_SGD||_op / ||D_Muon||_op = eta_s * sigma_1(G) / eta_m")
print("        = (||G||_* / ||G||_F^2) * sigma_1(G)")
print("        = ||G||_* * sigma_1(G) / ||G||_F^2")
print()

kappas = [1, 2, 5, 10, 50, 100, 1000]

# Generate fixed random orthogonal bases
U_base, _ = np.linalg.qr(rng.standard_normal((5, 5)))
V_base, _ = np.linalg.qr(rng.standard_normal((5, 5)))
B_sweep = rng.standard_normal((5, 5))
W_sweep = rng.standard_normal((5, 5))

header3 = (f"  {'kappa':>7s}  {'||D_S||_op':>12s}  {'||D_M||_op':>12s}  {'||D_A||_op':>12s}  "
           f"{'||D_S||_F':>12s}  {'||D_M||_F':>12s}  {'||D_A||_F':>12s}  "
           f"{'op ratio':>10s}")
print(header3)
print(f"  {'-' * 7}  {'-' * 12}  {'-' * 12}  {'-' * 12}  {'-' * 12}  {'-' * 12}  {'-' * 12}  {'-' * 10}")

sweep_results = {}
for kappa in kappas:
    # Construct A with given condition number
    s_vals = np.linspace(1.0, float(kappa), 5)
    A_kappa = U_base @ np.diag(s_vals) @ V_base.T

    # Use a tiny target decrease: 1% of the optimal SGD step's first-order decrease.
    # For f(W) = ||AW-B||^2_F, the Lipschitz constant is L = 2*sigma_max(A)^2.
    # The safe SGD step eta=1/L gives first-order decrease = ||G||^2_F / L.
    # We use 1% of that to stay deep in the linear regime.
    G_k = quadratic_grad(A_kappa, W_sweep, B_sweep)
    L_k = 2.0 * s_vals[-1] ** 2
    safe_fo_decrease = np.sum(G_k ** 2) / L_k
    tiny_target = 0.01 * safe_fo_decrease
    res_k = run_single_step_comparison(A_kappa, B_sweep, W_sweep, target_decrease=tiny_target)
    sweep_results[kappa] = res_k

    n_s = res_k["norms"]["sgd"]
    n_m = res_k["norms"]["muon"]
    n_a = res_k["norms"]["adam"]
    op_ratio = n_s["op"] / n_m["op"] if n_m["op"] > 1e-30 else float('inf')

    print(f"  {kappa:>7d}  {n_s['op']:>12.6f}  {n_m['op']:>12.6f}  {n_a['op']:>12.6f}  "
          f"{n_s['frob']:>12.6f}  {n_m['frob']:>12.6f}  {n_a['frob']:>12.6f}  "
          f"{op_ratio:>10.4f}x")

print()

# Check: Muon always has smallest spectral norm
subsep("Verification: Muon spectral optimality across condition numbers")
for kappa in kappas:
    res_k = sweep_results[kappa]
    muon_op = res_k["norms"]["muon"]["op"]
    sgd_op = res_k["norms"]["sgd"]["op"]
    check(muon_op <= sgd_op + tol,
          f"kappa={kappa:>5d}: ||D_Muon||_op ({muon_op:.8f}) <= ||D_SGD||_op ({sgd_op:.8f})")
print()

# Check: SGD always has smallest Frobenius norm
subsep("Verification: SGD Frobenius optimality across condition numbers")
for kappa in kappas:
    res_k = sweep_results[kappa]
    sgd_frob = res_k["norms"]["sgd"]["frob"]
    muon_frob = res_k["norms"]["muon"]["frob"]
    check(sgd_frob <= muon_frob + tol,
          f"kappa={kappa:>5d}: ||D_SGD||_F ({sgd_frob:.8f}) <= ||D_Muon||_F ({muon_frob:.8f})")
print()

# Verify the analytical formula for the spectral advantage ratio
subsep("Analytical verification of spectral advantage ratio")
print("  The ratio ||D_SGD||_op / ||D_Muon||_op should equal")
print("  ||G||_* * sigma_1(G) / ||G||_F^2  (derived above).")
print()

for kappa in kappas:
    res_k = sweep_results[kappa]
    G_k = res_k["G"]
    sv_k = np.linalg.svd(G_k, compute_uv=False)
    nuc_k = np.sum(sv_k)
    frob_k = np.linalg.norm(G_k, 'fro')
    op_k = sv_k[0]
    theoretical = nuc_k * op_k / (frob_k ** 2)
    empirical = res_k["norms"]["sgd"]["op"] / res_k["norms"]["muon"]["op"]
    rel_err = abs(empirical - theoretical) / theoretical
    print(f"    kappa(A) = {kappa:>5d}:  empirical = {empirical:.8f}  "
          f"theoretical = {theoretical:.8f}  rel_error = {rel_err:.2e}")
    check(rel_err < 1e-8,
          f"kappa={kappa:>5d}: empirical matches analytical formula (rel err = {rel_err:.2e})")

print()
print("  The spectral advantage ratio is EXACTLY ||G||_* * sigma_1(G) / ||G||_F^2.")
print("  This is always >= 1 (by Cauchy-Schwarz applied to singular values).")
print("  It is largest when G has many significant singular values (spread spectrum).")
print()


# ===================================================================
#  SECTION 4 -- Efficiency ratios
# ===================================================================

sep("SECTION 4: Efficiency ratios across condition numbers")

print("  Define:")
print("    Spectral efficiency  = actual_loss_decrease / ||Delta||_op")
print("    Frobenius efficiency = actual_loss_decrease / ||Delta||_F")
print()
print("  Muon should have the BEST spectral efficiency (by Von Neumann).")
print("  SGD should have the BEST Frobenius efficiency (by Cauchy-Schwarz).")
print()
print("  We use the tiny-step results from Section 3, which are well within")
print("  the linear regime (actual decrease ~ first-order decrease).")
print()

header4 = (f"  {'kappa':>7s}  {'Spec eff SGD':>14s}  {'Spec eff Muon':>14s}  {'Spec eff Adam':>14s}  "
           f"{'Frob eff SGD':>14s}  {'Frob eff Muon':>14s}  {'Frob eff Adam':>14s}")
print(header4)
print(f"  {'-' * 7}  {'-' * 14}  {'-' * 14}  {'-' * 14}  {'-' * 14}  {'-' * 14}  {'-' * 14}")

muon_best_spec_count = 0
sgd_best_frob_count = 0

for kappa in kappas:
    res_k = sweep_results[kappa]
    eff = {}
    for opt in ["sgd", "muon", "adam"]:
        ad = res_k["actual_decrease"][opt]
        n = res_k["norms"][opt]
        eff[opt] = {
            "spec": ad / n["op"] if n["op"] > 1e-30 else 0.0,
            "frob": ad / n["frob"] if n["frob"] > 1e-30 else 0.0,
        }
    print(f"  {kappa:>7d}  {eff['sgd']['spec']:>14.6f}  {eff['muon']['spec']:>14.6f}  {eff['adam']['spec']:>14.6f}  "
          f"{eff['sgd']['frob']:>14.6f}  {eff['muon']['frob']:>14.6f}  {eff['adam']['frob']:>14.6f}")

    if eff['muon']['spec'] >= eff['sgd']['spec'] - tol and eff['muon']['spec'] >= eff['adam']['spec'] - tol:
        muon_best_spec_count += 1
    if eff['sgd']['frob'] >= eff['muon']['frob'] - tol and eff['sgd']['frob'] >= eff['adam']['frob'] - tol:
        sgd_best_frob_count += 1

print()
check(muon_best_spec_count == len(kappas),
      f"Muon has best spectral efficiency in {muon_best_spec_count}/{len(kappas)} cases")
check(sgd_best_frob_count == len(kappas),
      f"SGD has best Frobenius efficiency in {sgd_best_frob_count}/{len(kappas)} cases")
print()

print("  Each optimizer wins in its own geometry:")
print("    - Muon: best loss decrease per unit spectral norm (by Von Neumann)")
