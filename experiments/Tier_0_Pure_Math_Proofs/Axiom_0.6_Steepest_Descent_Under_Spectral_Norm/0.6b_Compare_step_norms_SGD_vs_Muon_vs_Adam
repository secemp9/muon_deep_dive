subsep("Cumulative step norms over trajectory")
print(f"  {'Optimizer':>10s}  {'Sum ||D||_op':>14s}  {'Sum ||D||_F':>14s}  {'Total loss dec':>16s}  {'Dec/sum_op':>12s}  {'Dec/sum_F':>12s}")
print(f"  {'-' * 10}  {'-' * 14}  {'-' * 14}  {'-' * 16}  {'-' * 12}  {'-' * 12}")
for name, t_dec, c_spec, c_frob in [
    ("SGD",  total_dec_sgd,  cum_spec_sgd,  cum_frob_sgd),
