    print("  [1c] Identity and negative identity matrices")
    for n in [2, 3, 5, 10]:
        ok, mx, fr = run_test_svd(f"I_{n}", np.eye(n))
        svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
        svd_max_frob = max(svd_max_frob, fr); svd_count += 1
    for n in [3, 5]:
        ok, mx, fr = run_test_svd(f"-I_{n}", -np.eye(n))
        svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
        svd_max_frob = max(svd_max_frob, fr); svd_count += 1

    # --- 1d. Diagonal matrices ---
    print()
    print("  [1d] Diagonal matrices")
    for n in [3, 5, 10]:
        d = np.random.randn(n)
        ok, mx, fr = run_test_svd(f"diag(randn({n}))", np.diag(d))
        svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
        svd_max_frob = max(svd_max_frob, fr); svd_count += 1
    ok, mx, fr = run_test_svd("diag([3,-2,0.5,-7,1e-8])",
                               np.diag([3.0, -2.0, 0.5, -7.0, 1e-8]))
    svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
    svd_max_frob = max(svd_max_frob, fr); svd_count += 1

    # --- 1e. Near-singular and rank-deficient ---
    print()
    print("  [1e] Near-singular and rank-deficient matrices")
    for n in [3, 5, 10]:
        M = np.random.randn(n, n)
        U, S, Vt = np.linalg.svd(M)
        S[-1] = 1e-15
        M_ns = U @ np.diag(S) @ Vt
        ok, mx, fr = run_test_svd(f"near-singular {n}x{n} (sv_min=1e-15)", M_ns)
        svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
        svd_max_frob = max(svd_max_frob, fr); svd_count += 1
    u = np.random.randn(5, 1); v = np.random.randn(5, 1)
    ok, mx, fr = run_test_svd("rank-1  5x5", u @ v.T)
    svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
    svd_max_frob = max(svd_max_frob, fr); svd_count += 1

    # --- 1f. Already-orthogonal matrices ---
    print()
    print("  [1f] Already-orthogonal matrices (should be exact fixed points)")
    for n in [3, 5, 10]:
        Q, _ = np.linalg.qr(np.random.randn(n, n))
        ok, mx, fr = run_test_svd(f"random orthogonal Q ({n}x{n})", Q)
        svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
        svd_max_frob = max(svd_max_frob, fr); svd_count += 1
