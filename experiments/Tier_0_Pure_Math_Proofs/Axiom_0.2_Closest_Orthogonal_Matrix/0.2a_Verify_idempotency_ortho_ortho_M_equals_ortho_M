        Q_svd = ortho_svd(M)
        QQ_svd = ortho_svd(Q_svd)
        svd_idems.append(np.linalg.norm(QQ_svd - Q_svd, 'fro'))

        # NS directional idempotency
        Q_ns = ortho_ns(M)
        QQ_ns = ortho_ns(Q_ns)
        P1 = ortho_svd(Q_ns)
        P2 = ortho_svd(QQ_ns)
        ns_dir_idems.append(np.linalg.norm(P2 - P1, 'fro'))

        # NS raw idempotency
        ns_raw_idems.append(np.linalg.norm(QQ_ns - Q_ns, 'fro'))

        # NS direction accuracy (does NS find the same UV^T as SVD?)
        P_direct = ortho_svd(M)
        ns_direction_accuracy.append(np.linalg.norm(P1 - P_direct, 'fro'))

    svd_idems = np.array(svd_idems)
    ns_dir_idems = np.array(ns_dir_idems)
    ns_raw_idems = np.array(ns_raw_idems)
    ns_direction_accuracy = np.array(ns_direction_accuracy)

    print(f"  SVD idempotency ||ortho_svd^2(M) - ortho_svd(M)||_F:")
    print(f"    mean={svd_idems.mean():.2e}  max={svd_idems.max():.2e}  "
          f"median={np.median(svd_idems):.2e}")
    print()
    print(f"  NS DIRECTIONAL idempotency ||svd(NS^2(M)) - svd(NS(M))||_F:")
    print(f"    mean={ns_dir_idems.mean():.2e}  max={ns_dir_idems.max():.2e}  "
          f"median={np.median(ns_dir_idems):.2e}")
    print()
    print(f"  NS RAW idempotency ||NS^2(M) - NS(M)||_F  (expected large):")
    print(f"    mean={ns_raw_idems.mean():.4f}  max={ns_raw_idems.max():.4f}  "
          f"median={np.median(ns_raw_idems):.4f}")
    print()
    print(f"  NS direction accuracy ||svd(NS(M)) - svd(M)||_F:")
    print(f"    mean={ns_direction_accuracy.mean():.2e}  max={ns_direction_accuracy.max():.2e}  "
          f"median={np.median(ns_direction_accuracy):.2e}")

    ns_dir_ok = ns_dir_idems.max() < 1e-10
    ns_acc_ok = ns_direction_accuracy.max() < 1e-10
    print()
    print(f"  NS directional idempotency (max < 1e-10):  {'PASS' if ns_dir_ok else 'FAIL'}")
    print(f"  NS direction accuracy (max < 1e-10):       {'PASS' if ns_acc_ok else 'FAIL'}")

    # ==================================================================
    # PART 5: STEP COUNT SENSITIVITY
    # ==================================================================
    print()
    print("-" * 95)
    print("  PART 5: NS STEP COUNT SENSITIVITY")
    print("-" * 95)
    print()

    np.random.seed(42)
    M_test = np.random.randn(10, 10)
    print(f"  Test matrix: randn(10,10)")
    print(f"  Measuring directional idempotency and singular value range vs step count")
    print()
    for k in range(1, 11):
        Q = ortho_ns(M_test, steps=k)
        QQ = ortho_ns(Q, steps=k)
        P1 = ortho_svd(Q)
        P2 = ortho_svd(QQ)
        dir_err = np.linalg.norm(P2 - P1, 'fro')
        raw_err = np.linalg.norm(QQ - Q, 'fro')
        sv = np.linalg.svd(Q, compute_uv=False)
        print(f"  steps={k:>2d}:  dir_idem={dir_err:.2e}  raw_idem={raw_err:.4f}  "
              f"sv=[{sv.min():.4f}, {sv.max():.4f}]")

    print()
    print("  Directional idempotency is near machine-eps for all step counts >= 1.")
    print("  Raw idempotency never converges because NS does not produce sv=1.")
    print("  This is by design: Muon prioritizes speed over exactness.")

    # ==================================================================
    # SUMMARY
    # ==================================================================
    print()
    print(SEP)
    print("SUMMARY")
    print(SEP)
    print()
    total_svd = svd_count
    total_ns = ns_count
    total = total_svd + total_ns
    overall = svd_all_passed and ns_all_passed and ns_dir_ok and ns_acc_ok

    print(f"  SVD exact tests:         {total_svd:>4d}   "
          f"{'ALL PASSED' if svd_all_passed else 'SOME FAILED'}   "
          f"max Frobenius error: {svd_max_frob:.2e}")
    print(f"  NS directional tests:    {total_ns:>4d}   "
          f"{'ALL PASSED' if ns_all_passed else 'SOME FAILED'}   "
          f"max Frobenius error: {ns_max_frob:.2e}")
    print(f"  Total tests:             {total:>4d}")
    print(f"  Overall:                 {'ALL PASSED' if overall else 'SOME FAILED'}")

    print()
    print(SEP)
    if overall:
        print("CONCLUSION")
        print(SEP)
        print()
        print("  1. EXACT (SVD): ortho_svd(ortho_svd(M)) = ortho_svd(M) to machine precision.")
        print("     The SVD polar factor is a true idempotent projection.  QED.")
        print()
        print("  2. APPROXIMATE (Newton-Schulz, Muon's 5th-order, 5 steps):")
        print("     a) RAW idempotency FAILS: ortho_ns(ortho_ns(M)) != ortho_ns(M).")
        print("        This is because NS does not produce orthogonal matrices -- the")
        print("        output has singular values in ~[0.68, 1.13], and the normalization")
        print("        step remaps them differently each time.")
        print()
        print("     b) DIRECTIONAL idempotency HOLDS to machine precision:")
        print("        ortho_svd(NS(NS(M))) = ortho_svd(NS(M))")
        print("        Both applications produce the SAME polar factor UV^T.")
        print("        The gauge-fixing DIRECTION is idempotent.")
        print()
        print("     c) NS finds the EXACT same direction as SVD:")
        print("        ortho_svd(NS(M)) = ortho_svd(M) to machine precision.")
        print("        NS is a perfect direction finder, just an imperfect scaler.")
        print()
        print("  GAUGE THEORY INTERPRETATION:")
        print("    The gauge-fixing map selects a direction on the Stiefel manifold.")
        print("    Exact SVD is idempotent in both direction and scale (true projection).")
        print("    Muon's NS is idempotent in DIRECTION -- the gauge choice is the same")
        print("    after one or two applications.  The singular value oscillation is")
        print("    irrelevant because Muon rescales the update afterward:")
        print("      update *= sqrt(max(m,n)/min(m,n))")
        print("    The gauge slice is fixed.  Once you choose the right UV^T, you stay.")
    else:
        print("WARNING: Some tests failed. Investigate above.")

    print()
