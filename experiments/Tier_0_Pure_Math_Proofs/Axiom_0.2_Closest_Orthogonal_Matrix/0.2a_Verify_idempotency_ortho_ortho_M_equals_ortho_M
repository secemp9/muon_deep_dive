        ns_all_passed &= (max_err < 1e-10)
        ns_count += 1

    # ==================================================================
    # PART 3: WHY NS IS NOT RAW-IDEMPOTENT (educational)
    # ==================================================================
    print()
    print("-" * 95)
    print("  PART 3: WHY NS IS NOT RAW-IDEMPOTENT (educational analysis)")
    print("-" * 95)
    print()

    np.random.seed(77)
    print("  The NS iteration maps singular values to ~[0.68, 1.13], not exactly 1.")
    print("  When reapplied, the normalization X/||X||_F remaps these to ~[0.3, 0.5],")
    print("  and the iteration maps them BACK to [0.68, 1.13] at different values.")
    print("  The DIRECTION (UV^T) is preserved, but the SCALE (S) oscillates.")
    print()
    print("  Singular values after ortho_ns(M):")
