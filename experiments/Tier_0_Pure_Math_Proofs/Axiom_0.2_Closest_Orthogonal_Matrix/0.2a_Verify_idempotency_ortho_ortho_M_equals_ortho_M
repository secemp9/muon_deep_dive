    print("  Directional idempotency error ||ortho_svd(NS^2(M)) - ortho_svd(NS(M))||_F:")
    for (r, c) in [(5, 5), (10, 10), (32, 32)]:
        M = np.random.randn(r, c)
        Q1 = ortho_ns(M)
        Q2 = ortho_ns(Q1)
        P1 = ortho_svd(Q1)
        P2 = ortho_svd(Q2)
        dir_err = np.linalg.norm(P2 - P1, 'fro')
        print(f"    randn({r:>2d},{c:>2d}): ||err||_F = {dir_err:.2e}  (machine precision)")

