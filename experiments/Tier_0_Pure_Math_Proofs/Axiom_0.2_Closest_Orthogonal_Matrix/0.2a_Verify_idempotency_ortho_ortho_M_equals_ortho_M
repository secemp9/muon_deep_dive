    ok, mx, fr = run_test_svd("permutation 5x5", P)
    svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
    svd_max_frob = max(svd_max_frob, fr); svd_count += 1
    v = np.random.randn(4); v = v / np.linalg.norm(v)
    H = np.eye(4) - 2 * np.outer(v, v)
    ok, mx, fr = run_test_svd("Householder reflection 4x4", H)
    svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
    svd_max_frob = max(svd_max_frob, fr); svd_count += 1

    # --- 1g. Special structure ---
    print()
    print("  [1g] Special structure matrices")
    for (r, c) in [(3, 3), (4, 6)]:
        ok, mx, fr = run_test_svd(f"ones({r},{c})", np.ones((r, c)))
        svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
        svd_max_frob = max(svd_max_frob, fr); svd_count += 1
    ok, mx, fr = run_test_svd("randn(5,5)*1e10", np.random.randn(5, 5) * 1e10)
    svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
    svd_max_frob = max(svd_max_frob, fr); svd_count += 1
    ok, mx, fr = run_test_svd("randn(5,5)*1e-10", np.random.randn(5, 5) * 1e-10)
    svd_all_passed &= ok; svd_max_dev = max(svd_max_dev, mx)
    svd_max_frob = max(svd_max_frob, fr); svd_count += 1

    # --- 1h. Sanity: ortho_svd output is actually orthogonal ---
    print()
    print("  [1h] Sanity check: ortho_svd(M) is orthogonal / semi-orthogonal")
    for (r, c) in [(5, 5), (3, 7), (7, 3)]:
        M = np.random.randn(r, c)
        Q = ortho_svd(M)
        orth_err = check_orthogonality(Q)
        status = "PASS" if orth_err < 1e-12 else "FAIL"
        k = min(r, c)
        label = "Q^TQ" if r >= c else "QQ^T"
        print(f"  [{status}]  {label}=I_{k} for randn({r},{c}){'':<22s}  "
              f"max|err|={orth_err:.2e}")
        svd_all_passed &= (orth_err < 1e-12)
        svd_count += 1

    # ==================================================================
    # PART 2: NEWTON-SCHULZ (Muon) -- DIRECTIONAL IDEMPOTENCY
    # ==================================================================
    print()
    print("-" * 95)
    print("  PART 2: NEWTON-SCHULZ (Muon) -- DIRECTIONAL IDEMPOTENCY")
    print("  5th-order iteration, coefficients a=3.4445, b=-4.7750, c=2.0315, 5 steps")
    print()
    print("  Key insight: Muon's NS does NOT produce orthogonal matrices.")
    print("  Output has singular values in ~[0.68, 1.13], not exactly 1.")
    print("  So raw idempotency ortho_ns(ortho_ns(M)) = ortho_ns(M) does NOT hold.")
    print()
    print("  BUT: the DIRECTION (polar factor UV^T) is preserved perfectly.")
    print("  Test: ortho_svd(ortho_ns^2(M)) = ortho_svd(ortho_ns(M)) to machine eps.")
    print("  Tolerance: 1e-10")
    print("-" * 95)

    # --- 2a. Random matrices of various shapes ---
    print()
    print("  [2a] Random Gaussian matrices (various shapes)")
    print("       directional idempotency: ||ortho_svd(NS^2(M)) - ortho_svd(NS(M))||_F")
    for (r, c) in [(2, 2), (3, 3), (5, 5), (10, 10), (32, 32),
                    (3, 5), (5, 3), (8, 4), (4, 8), (20, 3), (3, 20)]:
        M = np.random.randn(r, c)
        ok, mx, fr = run_test_ns_directional(f"randn({r},{c})", M)
        ns_all_passed &= ok; ns_max_dev = max(ns_max_dev, mx)
        ns_max_frob = max(ns_max_frob, fr); ns_count += 1

    # --- 2b. 100 random matrices (statistical sweep) ---
    print()
    print("  [2b] 100 random matrices (mixed shapes, directional idempotency)")
    np.random.seed(123)
    shapes_ns = [(np.random.randint(2, 33), np.random.randint(2, 33)) for _ in range(100)]
    worst_ns_max = 0.0
    worst_ns_frob = 0.0
    all_ok_ns = True
    for r, c in shapes_ns:
        M = np.random.randn(r, c)
        Q1 = ortho_ns(M)
        Q2 = ortho_ns(Q1)
        P1 = ortho_svd(Q1)
        P2 = ortho_svd(Q2)
        mx = np.max(np.abs(P2 - P1))
        fr = np.linalg.norm(P2 - P1, 'fro')
        worst_ns_max = max(worst_ns_max, mx)
        worst_ns_frob = max(worst_ns_frob, fr)
        if mx >= 1e-10:
            all_ok_ns = False
    status = "PASS" if all_ok_ns else "FAIL"
    print(f"  [{status}]  100 random matrices (shapes 2..32)        "
          f"worst max|err|={worst_ns_max:.2e}  worst ||err||_F={worst_ns_frob:.2e}")
    ns_all_passed &= all_ok_ns
    ns_max_dev = max(ns_max_dev, worst_ns_max)
    ns_max_frob = max(ns_max_frob, worst_ns_frob)
    ns_count += 100

    # --- 2c. Identity and negative identity ---
    print()
    print("  [2c] Identity and negative identity matrices")
    for n in [2, 3, 5, 10]:
        ok, mx, fr = run_test_ns_directional(f"I_{n}", np.eye(n))
        ns_all_passed &= ok; ns_max_dev = max(ns_max_dev, mx)
        ns_max_frob = max(ns_max_frob, fr); ns_count += 1
    for n in [3, 5]:
        ok, mx, fr = run_test_ns_directional(f"-I_{n}", -np.eye(n))
        ns_all_passed &= ok; ns_max_dev = max(ns_max_dev, mx)
        ns_max_frob = max(ns_max_frob, fr); ns_count += 1

    # --- 2d. Already-orthogonal matrices ---
    print()
    print("  [2d] Already-orthogonal matrices")
    np.random.seed(42)
    for n in [3, 5, 10, 20, 32]:
        Q, _ = np.linalg.qr(np.random.randn(n, n))
        ok, mx, fr = run_test_ns_directional(f"random orthogonal Q ({n}x{n})", Q)
        ns_all_passed &= ok; ns_max_dev = max(ns_max_dev, mx)
        ns_max_frob = max(ns_max_frob, fr); ns_count += 1
    P = np.eye(5)[np.random.permutation(5)]
    ok, mx, fr = run_test_ns_directional("permutation 5x5", P)
    ns_all_passed &= ok; ns_max_dev = max(ns_max_dev, mx)
    ns_max_frob = max(ns_max_frob, fr); ns_count += 1
    v = np.random.randn(4); v = v / np.linalg.norm(v)
    H = np.eye(4) - 2 * np.outer(v, v)
    ok, mx, fr = run_test_ns_directional("Householder reflection 4x4", H)
    ns_all_passed &= ok; ns_max_dev = max(ns_max_dev, mx)
    ns_max_frob = max(ns_max_frob, fr); ns_count += 1

    # --- 2e. Matrices with controlled condition number ---
    print()
    print("  [2e] Matrices with controlled condition number (simulating Muon's regime)")
    np.random.seed(55)
    for (r, c) in [(5, 5), (10, 10), (8, 4), (4, 8), (16, 16), (32, 32)]:
        M = np.random.randn(r, c)
        U_m, S_m, Vt_m = np.linalg.svd(M, full_matrices=False)
        k = min(r, c)
        S_new = np.linspace(1.0, 3.0, k)
        M_cond = U_m @ np.diag(S_new) @ Vt_m
        ok, mx, fr = run_test_ns_directional(f"cond~3 ({r}x{c})", M_cond)
        ns_all_passed &= ok; ns_max_dev = max(ns_max_dev, mx)
        ns_max_frob = max(ns_max_frob, fr); ns_count += 1

    # --- 2f. Verify NS finds the correct direction (matches SVD) ---
    print()
    print("  [2f] Direction accuracy: ortho_svd(ortho_ns(M)) = ortho_svd(M)")
    print("       (NS finds the same polar factor as exact SVD)")
    np.random.seed(88)
    for (r, c) in [(5, 5), (10, 10), (3, 7), (7, 3), (32, 32)]:
        M = np.random.randn(r, c)
        Q_ns = ortho_ns(M)
        P_ns = ortho_svd(Q_ns)
        P_direct = ortho_svd(M)
        frob_err = np.linalg.norm(P_ns - P_direct, 'fro')
        max_err = np.max(np.abs(P_ns - P_direct))
        status = "PASS" if max_err < 1e-10 else "FAIL"
        print(f"  [{status}]  randn({r},{c}){'':<36s}  shape=({r:>2d},{c:>2d})  "
