#!/usr/bin/env python3
"""
Axiom 0.2a -- Verify idempotency: ortho(ortho(M)) = ortho(M)

TWO implementations of the orthogonal projection are tested:

  1. EXACT (SVD):  ortho_svd(M) = U @ V^T   where M = U S V^T
     All singular values of UV^T are 1, so reapplying is a no-op.

  2. APPROXIMATE (Newton-Schulz, as used by Muon):
     ortho_ns(M, steps=5) uses the 5th-order NS iteration with
     Muon-specific coefficients  a=3.4445, b=-4.7750, c=2.0315:
       A = X @ X^T;  B = b*A + c*A@A;  X = a*X + B@X
     starting from X_0 = M / (||M||_F + eps), with transpose when rows > cols.

     CRITICAL NUANCE (discovered empirically):
     Muon's NS does NOT produce an orthogonal matrix. Per its own docstring:
     "does not produce UV^T but rather something like US'V^T where S' is
     diagonal with S_{ii}' ~ Uniform(0.5, 1.5)."  The singular values land
     in roughly [0.68, 1.13], NOT at 1.0.

     Consequently, ortho_ns is NOT idempotent in the raw sense:
       ortho_ns(ortho_ns(M)) != ortho_ns(M)
     because the re-normalization step changes the singular value starting
     point each time.

     HOWEVER, ortho_ns IS directionally idempotent:
       ortho_svd(ortho_ns(ortho_ns(M))) = ortho_svd(ortho_ns(M))
     to machine precision.  Both applications produce the SAME polar factor
     UV^T -- the same rotation/reflection.  Only the singular value SCALE
     differs, not the direction.

Hypothesis (from Flywheel node, refined by experiment):
  - Exact SVD: idempotency to machine epsilon (~1e-14).
  - Newton-Schulz: DIRECTIONAL idempotency to machine epsilon.  The polar
    factor (gauge direction) is fixed after one application.  The singular
    values (gauge scale) oscillate but this does not affect Muon because
    the update is later rescaled anyway.

Gauge theory interpretation:
  The gauge-fixing map selects a DIRECTION on the orthogonal manifold.
  Exact SVD projection is idempotent in both direction and scale.
  Muon's NS approximation is idempotent in DIRECTION -- the gauge choice
  is the same after one or two applications.  The scale variation is
  irrelevant because Muon rescales the update by sqrt(max(m,n)/min(m,n))
  after the NS step anyway.
"""

import numpy as np


# ======================================================================
# Core projection functions
# ======================================================================

def ortho_svd(M):
    """Exact closest orthogonal (semi-orthogonal) matrix via SVD polar factor."""
    U, _, Vt = np.linalg.svd(M, full_matrices=False)
    return U @ Vt


def ortho_ns(M, steps=5):
    """Newton-Schulz approximation to the orthogonal polar factor (Muon's method).

    Uses the 5th-order iteration with Muon-specific coefficients:
        A = X @ X^T;  B = b*A + c*A@A;  X = a*X + B@X
    where a=3.4445, b=-4.7750, c=2.0315.

    This is an exact replica of Muon's zeropower_via_newtonschulz5, except
    in float64 instead of bfloat16.

    IMPORTANT: The output is NOT orthogonal. Singular values land in roughly
    [0.68, 1.13]. But the polar factor (U, V direction) matches the exact SVD
    to machine precision.
    """
    a, b, c = 3.4445, -4.7750, 2.0315
    X = M.copy().astype(np.float64)
    transposed = False
    if M.shape[0] > M.shape[1]:
        X = X.T
        transposed = True
    norm = np.linalg.norm(X, 'fro')
    if norm < 1e-30:
        return np.zeros_like(M, dtype=np.float64)
    # Normalize so that spectral norm <= 1 (since sigma_max <= ||M||_F)
    X = X / (norm + 1e-7)
    for _ in range(steps):
        A = X @ X.T
        B = b * A + c * A @ A
        X = a * X + B @ X
    if transposed:
        X = X.T
    return X


# ======================================================================
# Test helpers
# ======================================================================

def run_test_svd(name, M, tol=1e-12):
    """Idempotency check for exact SVD projection."""
    Q = ortho_svd(M)
    QQ = ortho_svd(Q)
    frob_err = np.linalg.norm(QQ - Q, 'fro')
    max_err = np.max(np.abs(QQ - Q))
    passed = max_err < tol
    status = "PASS" if passed else "FAIL"
    r, c = M.shape
    print(f"  [{status}]  {name:42s}  shape=({r:>2d},{c:>2d})  "
          f"max|err|={max_err:.2e}  ||err||_F={frob_err:.2e}")
    return passed, max_err, frob_err


def run_test_ns_directional(name, M, tol=1e-10):
    """Directional idempotency check for Newton-Schulz.

    Tests: ortho_svd(ortho_ns(ortho_ns(M))) = ortho_svd(ortho_ns(M))
    i.e., both applications produce the same polar factor.
    """
    Q1 = ortho_ns(M)
    Q2 = ortho_ns(Q1)
    P1 = ortho_svd(Q1)
    P2 = ortho_svd(Q2)
    frob_err = np.linalg.norm(P2 - P1, 'fro')
    max_err = np.max(np.abs(P2 - P1))
    passed = max_err < tol
    status = "PASS" if passed else "FAIL"
    r, c = M.shape
    print(f"  [{status}]  {name:42s}  shape=({r:>2d},{c:>2d})  "
          f"max|err|={max_err:.2e}  ||err||_F={frob_err:.2e}")
    return passed, max_err, frob_err


def check_orthogonality(Q):
    """Return max deviation of Q from being (semi-)orthogonal."""
    r, c = Q.shape
    if r >= c:
        prod = Q.T @ Q
        I = np.eye(c)
    else:
        prod = Q @ Q.T
        I = np.eye(r)
    return np.max(np.abs(prod - I))


