        svd_all_passed &= ok
        svd_max_dev = max(svd_max_dev, mx)
        svd_max_frob = max(svd_max_frob, fr)
        svd_count += 1

    # --- 1b. 100 random matrices (statistical sweep) ---
    print()
    print("  [1b] 100 random matrices (mixed shapes, statistical sweep)")
    shapes_100 = [(np.random.randint(2, 33), np.random.randint(2, 33)) for _ in range(100)]
    worst_100_max = 0.0
    worst_100_frob = 0.0
    all_ok_100 = True
    for r, c in shapes_100:
        M = np.random.randn(r, c)
        Q = ortho_svd(M)
        QQ = ortho_svd(Q)
        mx = np.max(np.abs(QQ - Q))
        fr = np.linalg.norm(QQ - Q, 'fro')
        worst_100_max = max(worst_100_max, mx)
        worst_100_frob = max(worst_100_frob, fr)
        if mx >= 1e-12:
            all_ok_100 = False
    status = "PASS" if all_ok_100 else "FAIL"
    print(f"  [{status}]  100 random matrices (shapes 2..32)        "
          f"worst max|err|={worst_100_max:.2e}  worst ||err||_F={worst_100_frob:.2e}")
    svd_all_passed &= all_ok_100
    svd_max_dev = max(svd_max_dev, worst_100_max)
    svd_max_frob = max(svd_max_frob, worst_100_frob)
    svd_count += 100

    # --- 1c. Identity and negative identity ---
