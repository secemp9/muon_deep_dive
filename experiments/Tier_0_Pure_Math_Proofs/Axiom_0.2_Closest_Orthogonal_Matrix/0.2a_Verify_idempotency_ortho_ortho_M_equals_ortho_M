    print("  Raw idempotency error ||ortho_ns(ortho_ns(M)) - ortho_ns(M)||_F:")
    for (r, c) in [(5, 5), (10, 10), (32, 32)]:
        M = np.random.randn(r, c)
        Q1 = ortho_ns(M)
        Q2 = ortho_ns(Q1)
