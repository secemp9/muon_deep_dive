print()


# ===================================================================
#  SECTION 6 -- Statistical sweep
# ===================================================================

sep("SECTION 6: Statistical sweep (500 matrices x 6 shapes)")

sweep_shapes = [(4, 4), (10, 3), (3, 10), (100, 5), (5, 100), (50, 50)]
n_trials = 500
sweep_tol = 1e-9  # slightly relaxed for large-scale sweep

print(f"  Running {n_trials} trials per shape...\n")

for (m, n) in sweep_shapes:
    k = min(m, n)
    shape_type = "tall" if m > n else ("wide" if m < n else "square")

    worst_op_dev = 0.0
    worst_semi_orth_dev = 0.0
    worst_frob_dev = 0.0
    n_pass = 0
    n_fail = 0

    for trial in range(n_trials):
        M = rng.standard_normal((m, n))
        Q = ortho(M)

        # Operator norm check
        sv = np.linalg.svd(Q, compute_uv=False)
        op_dev = abs(sv[0] - 1.0)
        worst_op_dev = max(worst_op_dev, op_dev)

        # Semi-orthogonality check
        if m >= n:
            semi_dev = np.max(np.abs(Q.T @ Q - np.eye(n)))
        else:
            semi_dev = np.max(np.abs(Q @ Q.T - np.eye(m)))
        worst_semi_orth_dev = max(worst_semi_orth_dev, semi_dev)

        # Frobenius norm check
        frob_dev = abs(np.linalg.norm(Q, 'fro') - np.sqrt(k))
        worst_frob_dev = max(worst_frob_dev, frob_dev)

        trial_ok = (op_dev < sweep_tol and semi_dev < sweep_tol
                    and frob_dev < sweep_tol)
        if trial_ok:
            n_pass += 1
        else:
            n_fail += 1

    print(f"  Shape {m:>4d}x{n:<4d} ({shape_type:>6s}):  "
          f"{n_pass}/{n_trials} passed")
    print(f"    Worst ||Q||_op deviation from 1:        {worst_op_dev:.2e}")
    print(f"    Worst semi-orthogonality deviation:     {worst_semi_orth_dev:.2e}")
    print(f"    Worst ||Q||_F deviation from sqrt(k):   {worst_frob_dev:.2e}")

    all_ok = (worst_op_dev < sweep_tol and worst_semi_orth_dev < sweep_tol
              and worst_frob_dev < sweep_tol)
    check(all_ok,
          f"All {n_trials} trials pass for {m}x{n} (worst deviations above)")
    print()


