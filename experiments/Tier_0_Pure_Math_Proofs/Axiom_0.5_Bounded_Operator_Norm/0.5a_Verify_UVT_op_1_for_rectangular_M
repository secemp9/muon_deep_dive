# -----------------------------------------------------------------------
#  7b. Exact (cubic) NS iteration for comparison
# -----------------------------------------------------------------------

subsep("7b. Exact cubic NS iteration (converges to UV^T, 15 steps)")

ns_exact_tol = 1e-4

for (m, n, shape_type) in ns_shapes:
    M = rng.standard_normal((m, n))
    k = min(m, n)

    Q_svd = ortho(M)
    Q_exact_ns = newton_schulz_exact(M, n_steps=15)

    sv_exact = np.linalg.svd(Q_exact_ns, compute_uv=False)
    op_norm_exact = sv_exact[0]
    op_dev = abs(op_norm_exact - 1.0)

    # Semi-orthogonality
    if m >= n:
        semi_dev = np.max(np.abs(Q_exact_ns.T @ Q_exact_ns - np.eye(n)))
    else:
        semi_dev = np.max(np.abs(Q_exact_ns @ Q_exact_ns.T - np.eye(m)))

    frob_dist = np.linalg.norm(Q_exact_ns - Q_svd, 'fro')

    print(f"  {m:>4d}x{n:<4d} ({shape_type:>6s}): "
          f"||Q||_op = {op_norm_exact:.8f}  "
          f"semi_orth = {semi_dev:.2e}  "
          f"||Q_NS - Q_SVD||_F = {frob_dist:.2e}")
    check(op_dev < ns_exact_tol,
          f"||Q_NS||_op ~ 1 for {m}x{n}  (dev = {op_dev:.2e})")
    check(semi_dev < ns_exact_tol,
          f"NS output semi-orthogonal for {m}x{n}  (dev = {semi_dev:.2e})")

print()


