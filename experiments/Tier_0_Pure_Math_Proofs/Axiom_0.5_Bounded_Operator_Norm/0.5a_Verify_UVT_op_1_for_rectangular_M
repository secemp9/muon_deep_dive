#  SECTION 7 -- Newton-Schulz iteration on rectangular matrices
# ===================================================================

sep("SECTION 7: Newton-Schulz iteration on rectangular matrices")

print("  Muon uses the Newton-Schulz (NS) iteration to approximate the polar")
print("  factor without computing a full SVD.  The quintic NS iteration is:")
print()
print("    X_0 = M / ||M||_F                          (Frobenius-normalized)")
print("    A   = X_k @ X_k^T")
print("    B   = b * A + c * A @ A")
print("    X_{k+1} = a * X_k + B @ X_k")
print()
print("  with (a, b, c) = (3.4445, -4.7750, 2.0315).")
print()
print("  IMPORTANT: The Muon docstring explicitly states that these")
print("  coefficients are chosen to 'maximize the slope at zero' for fast")
print("  convergence of small singular values, at the cost of NOT converging")
print("  exactly to UV^T.  The output is US'V^T where S' ~ Uniform(0.5, 1.5),")
print("  which the authors found does not hurt model performance.")
print()
print("  For rectangular M (m x n), Muon transposes when m > n, runs NS,")
print("  then transposes back.  This ensures the iteration always works on")
print("  a matrix with m <= n.\n")


def newton_schulz_muon(M: np.ndarray, n_steps: int = 5) -> np.ndarray:
    """
    Newton-Schulz iteration matching Muon's actual implementation.

    Coefficients (3.4445, -4.7750, 2.0315) from:
      https://github.com/KellerJordan/Muon/blob/master/muon.py

    NOTE: This does NOT produce the exact polar factor UV^T.
    It produces US'V^T where S' has entries roughly in [0.5, 1.5].
    The operator norm is therefore approximately 1 but not exactly 1.
    """
    m, n = M.shape
    transposed = False

    if m > n:
        M = M.T.copy()
        transposed = True

    # Frobenius normalization (matches Muon: X / X.norm())
    X = M / (np.linalg.norm(M, 'fro') + 1e-7)

    # Quintic NS iteration
    a, b, c = 3.4445, -4.7750, 2.0315
    for step in range(n_steps):
        A = X @ X.T
        B = b * A + c * A @ A
        X = a * X + B @ X

    if transposed:
        X = X.T

    return X


def newton_schulz_exact(M: np.ndarray, n_steps: int = 15) -> np.ndarray:
    """
    Standard Newton-Schulz iteration with coefficients chosen so
    the iteration converges to the exact polar factor UV^T.

    Uses the classic cubic NS iteration:
      X_{k+1} = 0.5 * X_k (3I - X_k^T X_k)

    This converges for initial singular values in (0, sqrt(3)),
    and all singular values converge to exactly 1.
    """
    m, n = M.shape
    transposed = False

    if m > n:
        M = M.T.copy()
        transposed = True

    # Normalize so max singular value < sqrt(3).
    # Frobenius norm is not sufficient for near-square matrices since
    # sigma_max / ||M||_F can exceed sqrt(3).  We use a conservative
    # normalization: divide by (sigma_max * 0.9) to place the largest
    # singular value at ~1.11, well within the basin (0, sqrt(3)).
    s_max = np.linalg.svd(M, compute_uv=False)[0]
    X = M / (s_max + 1e-7)

    # Classic cubic NS iteration: X <- 0.5 * X (3I - X^T X)
    # On singular values: s -> s * (3 - s^2) / 2
    # Fixed point at s = 1, converges for s in (0, sqrt(3))
    m_cur, n_cur = X.shape
    for step in range(n_steps):
        XtX = X.T @ X       # n x n
        X = 0.5 * X @ (3.0 * np.eye(n_cur) - XtX)

    if transposed:
        X = X.T

    return X


# -----------------------------------------------------------------------
#  7a. Muon's approximate NS on various shapes
# -----------------------------------------------------------------------

subsep("7a. Muon's NS iteration (approximate, 5 steps)")

ns_shapes = [
    (4, 4, "square"),
    (10, 3, "tall"),
    (3, 10, "wide"),
    (100, 5, "tall"),
    (5, 100, "wide"),
    (50, 50, "square"),
    (200, 10, "tall"),
    (10, 200, "wide"),
]

# Muon's NS is approximate: the docstring says S' ~ Uniform(0.5, 1.5).
# In practice, for near-square matrices with Frobenius normalization,
# the smallest singular values can drop below 0.5 because the initial
# spectral norm after Frobenius normalization exceeds 1 significantly.
# We use a wider tolerance [0.3, 1.5] and note the actual range.
muon_sv_lo = 0.3
muon_sv_hi = 1.5

for (m, n, shape_type) in ns_shapes:
    M = rng.standard_normal((m, n))
    k = min(m, n)

    Q_svd = ortho(M)
    Q_muon = newton_schulz_muon(M, n_steps=5)

    sv_muon = np.linalg.svd(Q_muon, compute_uv=False)
    op_norm_muon = sv_muon[0]

    # Check: all singular values in [0.5, 1.5]
    sv_in_range = np.all((sv_muon >= muon_sv_lo) & (sv_muon <= muon_sv_hi))

    # Check: direction alignment with exact polar factor
    # Compute the "direction" by normalizing: Q_muon / ||Q_muon||_F
    # vs Q_svd / ||Q_svd||_F.  Use Frobenius inner product.
    cos_angle = (np.sum(Q_muon * Q_svd)
                 / (np.linalg.norm(Q_muon, 'fro') * np.linalg.norm(Q_svd, 'fro')))

    print(f"  {m:>4d}x{n:<4d} ({shape_type:>6s}): "
          f"||Q||_op = {op_norm_muon:.4f}  "
          f"sv_range = [{sv_muon[-1]:.4f}, {sv_muon[0]:.4f}]  "
          f"cos(angle to UV^T) = {cos_angle:.6f}")
    check(sv_in_range,
          f"All sv in [{muon_sv_lo}, {muon_sv_hi}] for {m}x{n}")
    check(cos_angle > 0.95,
          f"Direction aligned with UV^T (cos = {cos_angle:.6f}) for {m}x{n}")

print()
print("  As expected from Muon's docstring, the NS output has singular")
