sep("SECTION 4: Operator norm comparison -- M vs ortho(M)")

print("  For random M of various shapes, compare ||M||_op vs ||ortho(M)||_op.\n")
print("  The key property: ortho() always normalizes the operator norm to 1.")
print("  This is the 'bounded operator norm' property -- Muon's updates")
print("  never blow up regardless of the gradient magnitude.\n")

print(f"  {'Shape':>12s}  {'||M||_op':>12s}  {'||ortho(M)||_op':>18s}  {'|dev from 1|':>14s}  Result")
