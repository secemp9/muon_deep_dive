# Transpose because tall, then iterate
M_work = M_demo.T.copy()
s_max_demo = np.linalg.svd(M_work, compute_uv=False)[0]
X = M_work / (s_max_demo + 1e-7)
n_cur = M_work.shape[1]

print(f"  {'Step':>4s}  {'||Q||_op':>12s}  {'dev from 1':>12s}  "
      f"{'||Q^TQ - I||':>14s}  {'||Q - Q_svd||_F':>20s}")
print(f"  {'-' * 4}  {'-' * 12}  {'-' * 12}  {'-' * 14}  {'-' * 20}")

# Initial state
Q_step = X.T
sv_x = np.linalg.svd(Q_step, compute_uv=False)
semi_x = np.max(np.abs(Q_step.T @ Q_step - np.eye(5)))
dist_x = np.linalg.norm(Q_step - Q_svd_demo, 'fro')
print(f"  {0:>4d}  {sv_x[0]:>12.8f}  {abs(sv_x[0] - 1.0):>12.2e}  "
      f"{semi_x:>14.2e}  {dist_x:>20.6f}")

for step in range(15):
    XtX = X.T @ X
    X = 0.5 * X @ (3.0 * np.eye(n_cur) - XtX)

    Q_step = X.T
    sv_x = np.linalg.svd(Q_step, compute_uv=False)
    semi_x = np.max(np.abs(Q_step.T @ Q_step - np.eye(5)))
    dist_x = np.linalg.norm(Q_step - Q_svd_demo, 'fro')
    print(f"  {step + 1:>4d}  {sv_x[0]:>12.8f}  {abs(sv_x[0] - 1.0):>12.2e}  "
          f"{semi_x:>14.2e}  {dist_x:>20.6f}")

