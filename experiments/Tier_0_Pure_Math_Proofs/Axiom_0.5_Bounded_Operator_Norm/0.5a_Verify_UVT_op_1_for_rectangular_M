#!/usr/bin/env python3
"""
Axiom 0.5a -- Verify: ||UV^T||_op = 1 for rectangular M (partial isometry)

For M in R^{m x n} with m > n (tall), the thin SVD gives U in R^{m x n},
V in R^{n x n}.  The polar factor Q = U V^T in R^{m x n} has n singular
values all equal to 1 and m - n zero singular values.  Therefore
||Q||_op = 1, but Q is NOT a square orthogonal matrix -- it is a partial
isometry.

We verify:
  1. ||Q||_op = 1 for specific shapes (100x5, 1000x3, 50x50)
  2. Partial isometry properties (Q^T Q = I_n but Q Q^T != I_m for tall)
  3. Real-network layer shapes (embedding, attention, MLP)
  4. Operator norm comparison: ||M||_op varies, ||ortho(M)||_op = 1 always
  5. Frobenius norm: ||UV^T||_F = sqrt(min(m,n))
  6. Statistical sweep: 500 matrices across 6 shapes
  7. Newton-Schulz iteration on rectangular matrices
"""

import numpy as np

# ---------------------------------------------------------------------------
#  Helpers
# ---------------------------------------------------------------------------

def sep(title: str) -> None:
    """Print a section separator."""
    print(f"\n{'=' * 72}")
    print(f"  {title}")
    print(f"{'=' * 72}\n")


def subsep(title: str) -> None:
    """Print a subsection separator."""
    print(f"\n  {'-' * 66}")
    print(f"    {title}")
    print(f"  {'-' * 66}\n")


def mat(name: str, A: np.ndarray) -> None:
    """Pretty-print a labelled matrix (truncated for large matrices)."""
    rows, cols = A.shape
    print(f"  {name}  (shape {rows}x{cols}):")
    show_r = min(rows, 6)
    show_c = min(cols, 6)
    for i in range(show_r):
        vals = "  ".join(f"{A[i, j]: .8f}" for j in range(show_c))
        suffix = "  ..." if cols > show_c else ""
        print(f"    [{vals}{suffix}]")
    if rows > show_r:
        print(f"    ... ({rows - show_r} more rows)")
    print()


def ortho(M: np.ndarray) -> np.ndarray:
    """Compute the polar factor Q = U V^T via thin SVD."""
    U, _s, Vt = np.linalg.svd(M, full_matrices=False)
    return U @ Vt


def pf(ok: bool) -> str:
    """Return PASS or FAIL string."""
    return "PASS" if ok else "FAIL"


# Global tracking
all_pass = True
total_checks = 0
total_failures = 0


def check(condition: bool, label: str) -> bool:
    """Record a pass/fail check."""
    global all_pass, total_checks, total_failures
    total_checks += 1
    if not condition:
        all_pass = False
        total_failures += 1
    print(f"    [{pf(condition)}]  {label}")
    return condition


# ===================================================================
#  SECTION 1 -- Basic verification on specific shapes
# ===================================================================

sep("SECTION 1: Basic verification on specific shapes")

rng = np.random.default_rng(42)
tol = 1e-10

shapes = [(100, 5), (1000, 3), (50, 50)]

for (m, n) in shapes:
    subsep(f"M in R^{{{m} x {n}}}")
    k = min(m, n)

    M = rng.standard_normal((m, n))
    U, s, Vt = np.linalg.svd(M, full_matrices=False)
    Q = U @ Vt  # polar factor, shape (m, k) @ (k, n) = (m, n)

    print(f"  SVD shapes: U is {U.shape}, S has {len(s)} values, V^T is {Vt.shape}")
    print(f"  Q = U @ V^T has shape {Q.shape}")
    print()

    # Singular values of Q
    sv_Q = np.linalg.svd(Q, compute_uv=False)
    op_norm = sv_Q[0]

    print(f"  Singular value spectrum of Q (all {len(sv_Q)} values):")
    if len(sv_Q) <= 10:
        for i, sv in enumerate(sv_Q):
            print(f"    sigma_{i+1} = {sv:.12f}")
    else:
        for i in range(5):
            print(f"    sigma_{i+1} = {sv_Q[i]:.12f}")
        print(f"    ... ({len(sv_Q) - 10} more) ...")
        for i in range(len(sv_Q) - 5, len(sv_Q)):
            print(f"    sigma_{i+1} = {sv_Q[i]:.12f}")
    print()

    # Count unit and zero singular values
    n_unit = np.sum(np.abs(sv_Q - 1.0) < tol)
    n_zero = np.sum(np.abs(sv_Q) < tol)
    expected_unit = k
    expected_zero = abs(m - n) if m != n else 0
    # For thin SVD, sv_Q has min(m,n) values, all should be 1
    # To see m-n zeros, we need full SVD of Q
    if m != n:
        sv_Q_full = np.linalg.svd(Q, compute_uv=False)
        n_unit_full = np.sum(np.abs(sv_Q_full - 1.0) < tol)
        n_zero_full = np.sum(np.abs(sv_Q_full) < tol)
        print(f"  Full singular value count: {len(sv_Q_full)} values")
        print(f"    Unit singular values (|sigma - 1| < {tol}): {n_unit_full}")
        print(f"    Zero singular values (|sigma| < {tol}):     {n_zero_full}")
        # For a thin m x n matrix with m > n, full SVD gives min(m,n) values
        # since the matrix rank is at most min(m,n)
        check(n_unit_full == k, f"Q has exactly min(m,n) = {k} unit singular values")
    else:
        print(f"  Unit singular values: {n_unit}  (expected {expected_unit})")
        check(n_unit == expected_unit, f"Q has exactly {expected_unit} unit singular values")

    check(abs(op_norm - 1.0) < tol,
          f"||Q||_op = {op_norm:.15f} = 1  (dev = {abs(op_norm - 1.0):.2e})")
    print()


# ===================================================================
#  SECTION 2 -- Partial isometry properties
# ===================================================================

sep("SECTION 2: Partial isometry properties")

print("  For a partial isometry Q in R^{m x n}:")
print("    - Tall  (m > n):  Q^T Q = I_n  (right semi-orthogonal)")
print("                      Q Q^T != I_m  (only rank-n projection)")
print("    - Wide  (m < n):  Q Q^T = I_m  (left semi-orthogonal)")
print("                      Q^T Q != I_n  (only rank-m projection)")
print("    - Square (m = n): Q^T Q = Q Q^T = I_n  (full orthogonal)")
print()

test_shapes = [
    (100, 5, "tall"),
    (1000, 3, "tall"),
    (5, 100, "wide"),
    (3, 1000, "wide"),
    (50, 50, "square"),
    (10, 10, "square"),
]

for (m, n, shape_type) in test_shapes:
    subsep(f"M in R^{{{m} x {n}}}  ({shape_type})")

    M = rng.standard_normal((m, n))
    Q = ortho(M)
    k = min(m, n)

    QtQ = Q.T @ Q   # n x n
    QQt = Q @ Q.T   # m x m

    dev_QtQ = np.max(np.abs(QtQ - np.eye(n)))
    dev_QQt = np.max(np.abs(QQt - np.eye(m)))

    print(f"  Q shape: {Q.shape}")
    print(f"  ||Q^T Q - I_{n}||_max = {dev_QtQ:.2e}")
    print(f"  ||Q Q^T - I_{m}||_max = {dev_QQt:.2e}")
    print()

    if shape_type == "tall":
        check(dev_QtQ < tol,
              f"Q^T Q = I_{n}  (right semi-orthogonal)")
        check(dev_QQt > 0.1,
              f"Q Q^T != I_{m}  (deviation = {dev_QQt:.4f}, Q Q^T is rank-{k} projection)")
        # Verify Q Q^T is a projection: (QQ^T)^2 = QQ^T
        proj = QQt
        proj_dev = np.max(np.abs(proj @ proj - proj))
        check(proj_dev < tol,
              f"(Q Q^T)^2 = Q Q^T  (orthogonal projection, dev = {proj_dev:.2e})")

    elif shape_type == "wide":
        check(dev_QQt < tol,
              f"Q Q^T = I_{m}  (left semi-orthogonal)")
        check(dev_QtQ > 0.1,
              f"Q^T Q != I_{n}  (deviation = {dev_QtQ:.4f}, Q^T Q is rank-{k} projection)")
        # Verify Q^T Q is a projection: (Q^TQ)^2 = Q^TQ
        proj = QtQ
        proj_dev = np.max(np.abs(proj @ proj - proj))
        check(proj_dev < tol,
              f"(Q^T Q)^2 = Q^T Q  (orthogonal projection, dev = {proj_dev:.2e})")

    elif shape_type == "square":
        check(dev_QtQ < tol,
              f"Q^T Q = I_{n}  (full orthogonal)")
        check(dev_QQt < tol,
              f"Q Q^T = I_{m}  (full orthogonal)")
        det_Q = np.linalg.det(Q)
        check(abs(abs(det_Q) - 1.0) < tol,
              f"|det(Q)| = {abs(det_Q):.12f} = 1")

    print()


