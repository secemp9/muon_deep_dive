sep("SECTION 5: Frobenius norm of ortho(M)")

print("  Theory:  ||UV^T||_F = sqrt(min(m,n))")
print("  Because UV^T has min(m,n) singular values all = 1,")
print("  and ||A||_F = sqrt(sum of squared singular values).\n")
print("  Note: ||UV^T||_F != 1 for non-square matrices!\n")

print(f"  {'Shape':>12s}  {'min(m,n)':>8s}  {'sqrt(min)':>10s}  "
