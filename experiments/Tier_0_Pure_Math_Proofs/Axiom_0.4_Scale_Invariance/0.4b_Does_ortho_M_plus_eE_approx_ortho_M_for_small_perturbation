# PART 7: Connection to training (educational commentary)
# ===================================================================

sep("PART 7: Connection to training -- when does gauge fixing break?")

print("  In training, M is the gradient or momentum accumulator.")
print()
print("  Scenario 1: Large batch, well-conditioned gradient")
print("    - Gradient G has all singular values well above zero")
print("    - sigma_min(G) is large => Lipschitz constant is small")
print("    - ortho(G) is stable under noise => Muon works well")
print()
print("  Scenario 2: Tiny batch, noisy gradient")
print("    - Gradient G has small singular values (noise dominates signal)")
print("    - sigma_min(G) ~ 0 => Lipschitz constant ~ infinity")
print("    - ortho(G) is UNSTABLE: tiny perturbation flips orthogonal factor")
print("    - Gauge fixing amplifies noise => Muon may degrade")
print()
print("  Scenario 3: Early training (random weights)")
print("    - Gradient structure is weak, singular values may be small")
print("    - Similar to tiny batch: ortho is sensitive to noise")
print()
print("  This connects to Experiment 4.3 (tiny batch):")
print("    When batch size is too small, gradient singular values approach zero,")
print("    and Muon's polar projection amplifies the noise. The batch size must")
print("    be large enough that sigma_min(gradient) >> 0.")
print()

# Numerical demonstration: batch-size effect on singular values
print("  Numerical demonstration: batch-size effect on gradient singular values")
print("  (Gradient = (1/B) * sum of B rank-1 outer products)")
print()

dim_sim = 8
batch_sizes = [1, 2, 4, 8, 16, 32, 64, 128, 256]

print(f"  {'batch_size':>12s}  {'sigma_min':>12s}  {'sigma_max':>12s}  "
      f"{'kappa':>12s}  {'1/sig_min':>12s}  {'full rank?'}")
print(f"  {'-'*12}  {'-'*12}  {'-'*12}  {'-'*12}  {'-'*12}  {'-'*10}")

for B in batch_sizes:
    G = np.zeros((dim_sim, dim_sim))
    for _ in range(B):
        x = RNG.standard_normal(dim_sim)
        y = RNG.standard_normal(dim_sim)
        G += np.outer(x, y)
    G /= B

    sigmas_G = np.linalg.svd(G, compute_uv=False)
    smin_G = sigmas_G[-1]
    smax_G = sigmas_G[0]
    full_rank = smin_G > 1e-10
    kappa_G = smax_G / smin_G if full_rank else float('inf')
    lip_G = 1.0 / smin_G if full_rank else float('inf')

    print(f"  {B:12d}  {smin_G:12.4e}  {smax_G:12.4f}  "
          f"{kappa_G:12.1f}  {lip_G:12.1f}  "
          f"{'YES' if full_rank else 'NO (rank-deficient)'}")

print()
print("  Observation: Small batches (B < min(m,n) = 8) produce rank-deficient")
print("  gradients with sigma_min ~ 0, making Muon's polar map Lipschitz constant")
print("  infinite. For B >= min(m,n), the gradient is generically full-rank.")
print()
print("  Practical rule: batch size should be >= min(m,n) for stable gauge fixing.")
print()


