sep("PART 8: Does Muon's Frobenius normalization help stability?")

print("  Muon normalizes M by ||M||_F before Newton-Schulz:")
print("    M_normalized = M / ||M||_F")
print()
print("  After normalization:")
print("    sigma_min(M_norm) = sigma_min(M) / ||M||_F")
print("    sigma_max(M_norm) = sigma_max(M) / ||M||_F")
print("    kappa(M_norm) = kappa(M)  -- condition number is PRESERVED")
print()
print("  So normalization does NOT help with ill-conditioning.")
print("  It only ensures singular values are in the convergence basin of NS.")
print()

print("  Numerical verification:")
print()
print(f"  {'kappa':>8s}  {'sig_min(M)':>12s}  {'sig_min(Mn)':>12s}  "
      f"{'kappa(M)':>10s}  {'kappa(Mn)':>10s}  {'Same?'}")
print(f"  {'-'*8}  {'-'*12}  {'-'*12}  {'-'*10}  {'-'*10}  {'-'*6}")

part8_pass = True
kappas_ns = [1, 5, 10, 100, 1000, 1e6]

for kappa in kappas_ns:
    Mi = make_matrix_with_condition((5, 5), kappa, rng=RNG)
    sigmas_i = np.linalg.svd(Mi, compute_uv=False)
    smin_i = sigmas_i[-1]
    smax_i = sigmas_i[0]
    kappa_i = smax_i / smin_i

    Mi_norm = Mi / np.linalg.norm(Mi, 'fro')
    sigmas_norm = np.linalg.svd(Mi_norm, compute_uv=False)
    smin_norm = sigmas_norm[-1]
    kappa_norm = sigmas_norm[0] / smin_norm

    kappa_match = abs(kappa_i - kappa_norm) / kappa_i < 1e-10
    if not kappa_match:
        part8_pass = False

    print(f"  {kappa:8.0f}  {smin_i:12.2e}  {smin_norm:12.2e}  "
          f"{kappa_i:10.2f}  {kappa_norm:10.2f}  "
          f"{'PASS' if kappa_match else 'FAIL'}")

print()

# Compare SVD vs NS Lipschitz at moderate condition number
# where NS converges well with 50 iterations
print("  Lipschitz comparison: SVD vs Newton-Schulz (kappa=100):")
print()

M_comp = make_matrix_with_condition((5, 5), kappa=100, rng=RNG)
sigmas_comp = np.linalg.svd(M_comp, compute_uv=False)
smin_comp = sigmas_comp[-1]
O_svd_comp = ortho_svd(M_comp)
O_ns_comp = ortho_ns(M_comp)

base_agreement = np.linalg.norm(O_svd_comp - O_ns_comp, 'fro')
print(f"  M: 5x5, kappa = 100, sigma_min = {smin_comp:.2e}")
print(f"  ||ortho_SVD(M) - ortho_NS(M)||_F = {base_agreement:.2e}")
print(f"  Theoretical bound 1/sigma_min = {1.0/smin_comp:.2f}")
print()

eps_ns = 1e-6
svd_lips = []
ns_lips = []

for _ in range(100):
    Ei = random_unit_perturbation((5, 5), RNG)
    Mi_pert = M_comp + eps_ns * Ei

    O_svd_pert = ortho_svd(Mi_pert)
    svd_lips.append(np.linalg.norm(O_svd_pert - O_svd_comp, 'fro') / eps_ns)

    O_ns_pert = ortho_ns(Mi_pert)
    ns_lips.append(np.linalg.norm(O_ns_pert - O_ns_comp, 'fro') / eps_ns)

svd_max_lip = np.max(svd_lips)
ns_max_lip = np.max(ns_lips)
svd_ns_ratio = ns_max_lip / svd_max_lip if svd_max_lip > 0 else float('inf')

print(f"  Lipschitz (SVD):  mean = {np.mean(svd_lips):.2f}, "
      f"max = {svd_max_lip:.2f}")
print(f"  Lipschitz (NS):   mean = {np.mean(ns_lips):.2f}, "
      f"max = {ns_max_lip:.2f}")
print(f"  NS/SVD ratio: {svd_ns_ratio:.4f}")
print()

similar = 0.1 < svd_ns_ratio < 10.0
part8_pass = part8_pass and similar

print(f"  Same order of magnitude (0.1 < ratio < 10): "
      f"{'PASS' if similar else 'FAIL'}")
print()
print("  INTERPRETATION: Frobenius normalization does NOT reduce the condition")
print("  number. It ensures NS convergence, but the polar map's sensitivity")
print("  to additive noise is determined by kappa(M), which normalization")
print("  preserves. For ill-conditioned M, both SVD and NS amplify noise.")
print()
print(f"  RESULT: Normalization preserves condition number. "
      f"{'PASS' if part8_pass else 'FAIL'}")
print()


