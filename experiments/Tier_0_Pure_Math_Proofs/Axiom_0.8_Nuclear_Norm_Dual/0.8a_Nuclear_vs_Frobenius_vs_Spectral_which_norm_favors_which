def test_one_line_proof():
    print("=" * 80)
    print("TEST 1: One-line proof on sigma = [10, 1, 0.1]")
    print("=" * 80)

    sigmas = np.array([10.0, 1.0, 0.1])
    n = len(sigmas)
    M = np.diag(sigmas)

    print(f"\n  M = diag({sigmas})")
    print(f"  Nuclear norm:   ||M||_* = sum(sigma) = {np.sum(sigmas):.4f}")
    print(f"  Frobenius norm: ||M||_F = sqrt(sum(sigma^2)) = {np.linalg.norm(M, 'fro'):.4f}")
    print(f"  Spectral norm:  ||M||_op = max(sigma) = {np.linalg.norm(M, 2):.4f}")

    # SGD step: proportional to M
    sgd_step = M  # eta * M, eta cancels in ratio
    sgd_conc = energy_concentration(sgd_step)
    sgd_expected = sigmas[0]**2 / np.sum(sigmas**2)

    # Muon step: proportional to UV^T = I (for diagonal positive M)
    muon_step = polar_factor(M)  # = I for diagonal positive
    muon_conc = energy_concentration(muon_step)
    muon_expected = 1.0 / n

    # Adam step: sign(M) for diagonal positive = I (all entries positive)
    # But for general M, Adam normalizes by running variance. For diagonal:
    # sign(M) = diag(sign(sigmas)) = I (since all positive)
    # Actually Adam divides by sqrt(v) element-wise. For M = diag([10,1,0.1]):
    # Adam step ~ M / |M| element-wise = sign(M) = I (for one step)
    adam_step = np.sign(M)  # sign of each element
    adam_conc = energy_concentration(adam_step)
    adam_expected = 1.0 / n  # sign(diag(positive)) = I, so same as Muon for diagonal

    print(f"\n  {'Optimizer':<12} {'Step':<20} {'Top-dir energy':<20} {'Expected':<15} {'Status'}")
    print(f"  {'─'*12} {'─'*20} {'─'*20} {'─'*15} {'─'*8}")
    print(f"  {'SGD':<12} {'eta * M':<20} {sgd_conc:<20.6f} {sgd_expected:<15.6f} "
          f"{'[PASS]' if abs(sgd_conc - sgd_expected) < 1e-10 else '[FAIL]'}")
    print(f"  {'Muon':<12} {'eta * UV^T = I':<20} {muon_conc:<20.6f} {muon_expected:<15.6f} "
          f"{'[PASS]' if abs(muon_conc - muon_expected) < 1e-10 else '[FAIL]'}")
    print(f"  {'Adam(sign)':<12} {'eta * sign(M) = I':<20} {adam_conc:<20.6f} {adam_expected:<15.6f} "
          f"{'[PASS]' if abs(adam_conc - adam_expected) < 1e-10 else '[FAIL]'}")

    print(f"\n  INTERPRETATION:")
    print(f"    SGD puts {sgd_conc*100:.1f}% of step energy into the sigma=10 direction")
    print(f"    Muon puts {muon_conc*100:.1f}% in each direction (1/{n} = {100/n:.1f}%)")
    print(f"    For diagonal positive M, Adam(sign) = Muon = democratic")

    # Now with a NON-diagonal M to show Adam differs from Muon
    print(f"\n  --- Non-diagonal case: random 3x3 with sigma=[10,1,0.1] ---")
    U_rand, _ = np.linalg.qr(np.random.randn(3, 3))
    V_rand, _ = np.linalg.qr(np.random.randn(3, 3))
    M_nd = U_rand @ np.diag(sigmas) @ V_rand.T

    sgd_step_nd = M_nd
    muon_step_nd = polar_factor(M_nd)
    adam_step_nd = np.sign(M_nd)  # element-wise sign

    sgd_conc_nd = energy_concentration(sgd_step_nd)
    muon_conc_nd = energy_concentration(muon_step_nd)
    adam_conc_nd = energy_concentration(adam_step_nd)

    print(f"    SGD  top-dir energy: {sgd_conc_nd:.6f} (expected: {sgd_expected:.6f})")
    print(f"    Muon top-dir energy: {muon_conc_nd:.6f} (expected: {muon_expected:.6f})")
    print(f"    Adam top-dir energy: {adam_conc_nd:.6f} (depends on element structure)")
    print(f"    NOTE: Adam's sign() is NOT rotationally equivariant!")
    print(f"          It depends on the element basis, not the singular direction basis.")

    pass1 = abs(sgd_conc - sgd_expected) < 1e-10
    pass2 = abs(muon_conc - muon_expected) < 1e-10
    pass3 = abs(muon_conc_nd - muon_expected) < 1e-10  # Muon is equivariant
    return pass1 and pass2 and pass3


