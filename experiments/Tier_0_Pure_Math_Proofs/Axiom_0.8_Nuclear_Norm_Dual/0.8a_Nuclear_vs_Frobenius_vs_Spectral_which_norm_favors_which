# =============================================================================

def test_democratic_updating():
    print("\n" + "=" * 80)
    print("TEST 4: Effective learning rates per singular direction")
    print("=" * 80)

    sigmas = np.array([10.0, 5.0, 2.0, 1.0, 0.1])
    n = len(sigmas)
    norm_F = np.linalg.norm(sigmas)

    print(f"\n  Singular values: {sigmas}")
    print(f"  ||sigma||_F = {norm_F:.4f}")
    print(f"\n  EFFECTIVE LEARNING RATE per direction:")
    print(f"  (How much does each singular direction change, relative to step size)")
    print(f"\n  {'Direction i':<14} {'sigma_i':<10} {'SGD eff LR':<14} {'Muon eff LR':<14} "
          f"{'Ratio SGD/Muon':<16}")
    print(f"  {'─'*14} {'─'*10} {'─'*14} {'─'*14} {'─'*16}")

    all_pass = True
    for i, si in enumerate(sigmas):
        # SGD effective LR for direction i: contribution is eta*sigma_i,
        # normalized by total step size eta*||sigma||_F
        # -> effective fractional LR = sigma_i / ||sigma||_F
        sgd_eff = si / norm_F

        # Muon effective LR for direction i: contribution is eta*1 (from UV^T),
        # normalized by total step size eta*sqrt(n)
        # -> effective fractional LR = 1 / sqrt(n)
        muon_eff = 1.0 / np.sqrt(n)

        # The ratio tells us: SGD over-learns in top direction by this factor
        ratio = sgd_eff / muon_eff

        print(f"  {i:<14} {si:<10.2f} {sgd_eff:<14.6f} {muon_eff:<14.6f} {ratio:<16.4f}")

    print(f"\n  INTERPRETATION:")
    print(f"    SGD's effective LR for direction 0 (sigma=10): {sigmas[0]/norm_F:.4f}")
    print(f"    SGD's effective LR for direction 4 (sigma=0.1): {sigmas[-1]/norm_F:.6f}")
    print(f"    Ratio: {sigmas[0]/sigmas[-1]:.0f}x — SGD learns the top direction "
          f"{sigmas[0]/sigmas[-1]:.0f}x faster!")
    print(f"    Muon treats ALL directions equally: effective LR = 1/sqrt({n}) = {1/np.sqrt(n):.4f}")
    print(f"\n    This IS the 'removal of gauge redundancy' restated:")
    print(f"    - SGD step norm in direction i is proportional to sigma_i")
    print(f"    - The gradient's large sigma_i might reflect gauge redundancy, not loss curvature")
    print(f"    - Muon removes this bias by equalizing all directions")

    # Verify numerically with actual matrices
    print(f"\n  --- Numerical verification (5x5 diagonal) ---")
    M = np.diag(sigmas)
    sgd_step = M
    muon_step = polar_factor(M)  # = I for diagonal positive

    sgd_dist = energy_distribution(sgd_step)
    muon_dist = energy_distribution(muon_step)

    print(f"    SGD energy per direction:  {sgd_dist}")
    print(f"    Muon energy per direction: {muon_dist}")

    # Check SGD matches sigma_i^2/sum(sigma_j^2)
    expected_sgd = sigmas**2 / np.sum(sigmas**2)
    if np.allclose(sgd_dist, expected_sgd, atol=1e-10):
        print(f"    [PASS] SGD energy = sigma_i^2/sum(sigma_j^2)")
    else:
        print(f"    [FAIL] SGD energy mismatch")
        all_pass = False

    # Check Muon is uniform
    if np.allclose(muon_dist, np.ones(n)/n, atol=1e-10):
        print(f"    [PASS] Muon energy = 1/n for all directions")
    else:
        print(f"    [FAIL] Muon energy not uniform")
        all_pass = False

    return all_pass


# =============================================================================
# TEST 5: When is democratic updating WORSE?
# =============================================================================

def test_when_democratic_is_worse():
    print("\n" + "=" * 80)
    print("TEST 5: When democratic updating is WORSE")
    print("        (Loss only cares about top direction)")
    print("=" * 80)

    n = 5
    # Scenario: the loss gradient points ENTIRELY in the top singular direction
    # of some weight matrix W. SGD should be better here because it naturally
    # puts more energy where the gradient is large.

    # Construct: W has large sigma_1, and the gradient G is aligned with
    # the top left/right singular vectors of W
    sigmas_W = np.array([10.0, 5.0, 2.0, 1.0, 0.5])
    U_W, _ = np.linalg.qr(np.random.randn(n, n))
    V_W, _ = np.linalg.qr(np.random.randn(n, n))
    W = U_W @ np.diag(sigmas_W) @ V_W.T

    # Gradient that only cares about direction 0 (rank-1)
    G_rank1 = 5.0 * np.outer(U_W[:, 0], V_W[:, 0])  # rank-1 gradient

    # Full-rank gradient (all directions matter equally)
    G_full = U_W @ np.diag(np.ones(n)) @ V_W.T  # ortho factor direction

    print(f"\n  Scenario A: Rank-1 gradient (loss cares about ONE direction only)")
    print(f"  G = 5 * u_1 @ v_1^T  (rank 1)")
    print(f"  True loss-relevant subspace: direction 0 only")

    # For this gradient:
    # SGD step = eta * G = rank-1, ALL energy in direction 0
    # Muon step = eta * polar(G) = eta * u_1 @ v_1^T (same for rank-1!)
    # Actually for rank-1, polar factor is the same rank-1 matrix!
    # For rectangular polar: UV^T where G=USV^T. Since G is rank-1,
    # the "polar factor" in the full sense requires full_matrices=False SVD.

    sgd_step_A = G_rank1
    muon_step_A = polar_factor(G_rank1)

    sgd_conc_A = energy_concentration(sgd_step_A)
    muon_conc_A = energy_concentration(muon_step_A)

    print(f"    SGD  energy in top direction: {sgd_conc_A:.6f}")
    print(f"    Muon energy in top direction: {muon_conc_A:.6f}")
    print(f"    (For rank-1 G, polar factor = u1*v1^T, so Muon also rank-1!)")

    # More interesting: gradient is rank-1 but embedded in higher-rank noise
    print(f"\n  Scenario B: Rank-1 signal + full-rank noise")
    noise_level = 0.1
    G_noisy = G_rank1 + noise_level * np.random.randn(n, n)

    sgd_step_B = G_noisy
    muon_step_B = polar_factor(G_noisy)

    sgd_conc_B = energy_concentration(sgd_step_B)
    muon_conc_B = energy_concentration(muon_step_B)

    # "Useful energy" = energy in the true signal direction (u_1, v_1)
    # Project step onto signal direction
    def useful_fraction(step, u, v):
        """Fraction of step's energy in the direction u @ v^T."""
        proj = np.sum(step * np.outer(u, v))  # inner product with rank-1 direction
        return proj**2 / np.sum(step**2)

    sgd_useful_B = useful_fraction(sgd_step_B, U_W[:, 0], V_W[:, 0])
    muon_useful_B = useful_fraction(muon_step_B, U_W[:, 0], V_W[:, 0])

    print(f"    Noise level: {noise_level}")
    print(f"    SGD  top-SV energy: {sgd_conc_B:.6f}, useful energy: {sgd_useful_B:.6f}")
    print(f"    Muon top-SV energy: {muon_conc_B:.6f}, useful energy: {muon_useful_B:.6f}")

    if sgd_useful_B > muon_useful_B:
        print(f"    [CONFIRMED] SGD puts MORE useful energy in the signal direction")
        print(f"    Muon 'wastes' {(1-muon_useful_B)*100:.1f}% of its step on noise directions")
    else:
        print(f"    [SURPRISE] Muon has more useful energy despite being democratic")

    # Scenario C: ALL directions matter equally
    print(f"\n  Scenario C: All directions matter equally (G is full-rank, sigma ~ uniform)")
    G_uniform = U_W @ np.diag(np.ones(n) + 0.1*np.random.randn(n)) @ V_W.T

    sgd_step_C = G_uniform
    muon_step_C = polar_factor(G_uniform)

    sgd_conc_C = energy_concentration(sgd_step_C)
    muon_conc_C = energy_concentration(muon_step_C)

    print(f"    SGD  concentration:  {sgd_conc_C:.6f}")
    print(f"    Muon concentration:  {muon_conc_C:.6f} (ideal: {1/n:.6f})")
    print(f"    When all directions matter equally, Muon's democracy is optimal!")

    print(f"\n  CONCLUSION:")
    print(f"    - Democratic (Muon) is BETTER when many spectral directions are loss-relevant")
