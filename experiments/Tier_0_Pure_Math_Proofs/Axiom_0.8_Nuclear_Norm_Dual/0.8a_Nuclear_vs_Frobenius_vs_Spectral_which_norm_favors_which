# TEST 3: Does Muon's ACTUAL NS output remain democratic?
# =============================================================================

def test_ns_democracy():
    print("\n" + "=" * 80)
    print("TEST 3: Does Muon's actual NS output (5 steps) remain democratic?")
    print("        (The 11-degree error question)")
    print("=" * 80)

    sizes = [5, 50, 200]
    n_trials = 20
    all_pass = True

    for n in sizes:
        exact_concs = []
        ns_concs = []
        angles = []

        for _ in range(n_trials):
            # Random matrix with condition number ~100
            U_r, _ = np.linalg.qr(np.random.randn(n, n))
            V_r, _ = np.linalg.qr(np.random.randn(n, n))
            sigmas = np.exp(np.linspace(0, np.log(100), n))  # log-spaced from 1 to 100
            M = U_r @ np.diag(sigmas) @ V_r.T

            # Exact polar factor
            Q_exact = polar_factor(M)
            exact_conc = energy_concentration(Q_exact)
            exact_concs.append(exact_conc)

            # NS approximation
            Q_ns = newton_schulz_5steps(M)
            ns_conc = energy_concentration(Q_ns)
            ns_concs.append(ns_conc)

            # Angular error
            # Frobenius angle between Q_ns and Q_exact
            cos_angle = np.sum(Q_ns * Q_exact) / (np.linalg.norm(Q_ns, 'fro') *
                                                    np.linalg.norm(Q_exact, 'fro'))
            cos_angle = np.clip(cos_angle, -1.0, 1.0)
            angle_deg = np.degrees(np.arccos(cos_angle))
            angles.append(angle_deg)

        exact_mean = np.mean(exact_concs)
        ns_mean = np.mean(ns_concs)
        ns_std = np.std(ns_concs)
        angle_mean = np.mean(angles)
        expected = 1.0 / n

        print(f"\n  n = {n}x{n} (expected democratic concentration: 1/{n} = {expected:.6f}):")
        print(f"    Exact polar:  mean conc = {exact_mean:.6f} (should be {expected:.6f})")
        print(f"    NS (5 steps): mean conc = {ns_mean:.6f} +/- {ns_std:.6f}")
        print(f"    Angular error: {angle_mean:.2f} degrees (mean)")
        print(f"    NS deviation from democratic: {abs(ns_mean - expected)/expected * 100:.2f}%")

        # The exact polar is always exactly 1/n
        if abs(exact_mean - expected) > 1e-6:
            print(f"    [FAIL] Exact polar not democratic!")
            all_pass = False
        else:
            print(f"    [PASS] Exact polar is perfectly democratic")

        # NS: how far from democratic?
        # Allow 10% relative deviation for the approximation
        if abs(ns_mean - expected) / expected < 0.10:
            print(f"    [PASS] NS output is approximately democratic (<10% deviation)")
        elif abs(ns_mean - expected) / expected < 0.25:
            print(f"    [WARN] NS output has moderate deviation ({abs(ns_mean - expected)/expected*100:.1f}%)")
            print(f"           The spectral clipping interpretation may still hold approximately")
        else:
            print(f"    [FAIL] NS output is NOT democratic ({abs(ns_mean - expected)/expected*100:.1f}% off)")
            print(f"           The 11-degree error DOES reintroduce concentration!")
            all_pass = False

    # Detailed singular value distribution of NS output
    print(f"\n  --- Detailed SVD of NS output (n=50, one example) ---")
    n = 50
    U_r, _ = np.linalg.qr(np.random.randn(n, n))
    V_r, _ = np.linalg.qr(np.random.randn(n, n))
    sigmas = np.exp(np.linspace(0, np.log(100), n))
    M = U_r @ np.diag(sigmas) @ V_r.T
    Q_ns = newton_schulz_5steps(M)
    ns_svs = np.linalg.svd(Q_ns, compute_uv=False)
    print(f"    NS output singular values (first 10): {ns_svs[:10]}")
    print(f"    NS output singular values (last 10):  {ns_svs[-10:]}")
    print(f"    Range: [{ns_svs[-1]:.6f}, {ns_svs[0]:.6f}]")
    print(f"    If perfectly orthogonal, all should be 1.0")
    print(f"    Max deviation from 1: {np.max(np.abs(ns_svs - 1.0)):.6f}")

    # The energy distribution of NS output
    ns_energy_dist = ns_svs**2 / np.sum(ns_svs**2)
    print(f"    Energy dist std: {np.std(ns_energy_dist):.6e} (0 = perfectly democratic)")
    print(f"    Max energy fraction: {np.max(ns_energy_dist):.6f} vs ideal {1/n:.6f}")

    return all_pass


