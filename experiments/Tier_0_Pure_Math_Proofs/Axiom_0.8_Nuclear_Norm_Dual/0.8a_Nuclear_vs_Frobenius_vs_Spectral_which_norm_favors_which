def test_effective_rank_interaction():
    print("\n" + "=" * 80)
    print("TEST 7: Effective rank interaction — Muon's potential failure mode")
    print("        (What if gradient is low-rank? Muon wastes energy on noise)")
    print("=" * 80)

    n = 20
    all_pass = True

    print(f"\n  Setup: n={n}x{n} gradient with effective rank k << n")
    print(f"  'Useful energy fraction' = energy in top-k directions of TRUE gradient")
    print(f"\n  {'eff_rank k':<12} {'SGD useful':<14} {'Muon useful':<14} {'Winner':<10} {'Margin'}")
    print(f"  {'─'*12} {'─'*14} {'─'*14} {'─'*10} {'─'*10}")

    for k in [1, 2, 5, 10, 15, 20]:
        # Construct gradient with effective rank k:
        # Top k singular values are 1.0, remaining are noise_level
        signal_strength = 1.0
        noise_level = 0.01
        sigmas_G = np.full(n, noise_level)
        sigmas_G[:k] = signal_strength

        # Random rotation
        U_G, _ = np.linalg.qr(np.random.randn(n, n))
        V_G, _ = np.linalg.qr(np.random.randn(n, n))
        G = U_G @ np.diag(sigmas_G) @ V_G.T

        # Steps
        sgd_step = G
        muon_step = polar_factor(G)

        # Useful energy = energy in top-k directions of G
        # These are columns 0..k-1 of U_G and V_G
        def useful_energy_topk(step, U, V, k_top):
            """Fraction of step energy in the top-k singular directions of G."""
            total_energy = np.sum(step**2)
            useful = 0.0
            for i in range(k_top):
                # Project onto rank-1 component u_i @ v_i^T
                proj = np.sum(step * np.outer(U[:, i], V[:, i]))
                useful += proj**2
            return useful / total_energy

        sgd_useful = useful_energy_topk(sgd_step, U_G, V_G, k)
        muon_useful = useful_energy_topk(muon_step, U_G, V_G, k)

        winner = "SGD" if sgd_useful > muon_useful else "Muon"
        margin = abs(sgd_useful - muon_useful)

        print(f"  {k:<12} {sgd_useful:<14.6f} {muon_useful:<14.6f} {winner:<10} {margin:.6f}")

    print(f"\n  INTERPRETATION:")
    print(f"    - For k << n (low-rank gradient): SGD concentrates in useful directions")
    print(f"      while Muon spreads equally across ALL n directions, wasting {100*(1-1):.0f}%--")
    print(f"      Muon puts k/n of its energy in useful directions, SGD puts ~k*sigma^2/sum")
    print(f"    - For k ~ n (full-rank gradient): Muon's democracy is optimal")
    print(f"    - FAILURE MODE: if true gradient is rank-1 but Muon spreads energy across")
    print(f"      all n directions, it wastes (n-1)/n of its step budget on noise!")

    # Detailed analysis: What happens with actual NN gradient statistics?
    print(f"\n  --- Simulating 'realistic' gradient spectra ---")
    print(f"  (Power-law decay: sigma_i ~ i^(-alpha))")
    print(f"\n  {'alpha':<8} {'eff_rank':<12} {'SGD useful@k5':<16} {'Muon useful@k5':<16} {'Winner'}")
    print(f"  {'─'*8} {'─'*12} {'─'*16} {'─'*16} {'─'*10}")

    for alpha in [0.0, 0.5, 1.0, 1.5, 2.0, 3.0]:
        sigmas_G = np.array([(i+1)**(-alpha) for i in range(n)])
        # Effective rank (Shannon entropy-based)
        p = sigmas_G**2 / np.sum(sigmas_G**2)
        eff_rank = np.exp(-np.sum(p * np.log(p + 1e-30)))

        U_G, _ = np.linalg.qr(np.random.randn(n, n))
        V_G, _ = np.linalg.qr(np.random.randn(n, n))
        G = U_G @ np.diag(sigmas_G) @ V_G.T

        sgd_step = G
        muon_step = polar_factor(G)

        k_test = 5
        sgd_useful = useful_energy_topk(sgd_step, U_G, V_G, k_test)
        muon_useful = useful_energy_topk(muon_step, U_G, V_G, k_test)

        winner = "SGD" if sgd_useful > muon_useful else "Muon"
        print(f"  {alpha:<8.1f} {eff_rank:<12.2f} {sgd_useful:<16.6f} {muon_useful:<16.6f} {winner}")

    # Helper defined locally for this test
    def useful_energy_topk(step, U, V, k_top):
        total_energy = np.sum(step**2)
        useful = 0.0
        for i in range(k_top):
            proj = np.sum(step * np.outer(U[:, i], V[:, i]))
            useful += proj**2
        return useful / total_energy

    print(f"\n  CONCLUSION:")
    print(f"    - When gradient spectrum decays fast (alpha > 1, low effective rank):")
    print(f"      SGD naturally focuses on the important directions. Muon 'wastes' energy.")
    print(f"    - When gradient spectrum is flat (alpha ~ 0, full effective rank):")
    print(f"      Muon's equal distribution is exactly what's needed.")
    print(f"    - The 'gauge-fixing' interpretation: in the flat-spectrum case, all directions")
    print(f"      are equally important, and SGD's bias toward top directions is pure gauge.")
    print(f"    - The potential FAILURE: in the steep-spectrum case, SGD's concentration")
    print(f"      is NOT gauge — it reflects genuine loss curvature. Muon may underperform here.")
    print(f"    - CRITICAL QUESTION: do real NN gradients have flat or steep spectra?")
    print(f"      (Evidence suggests: moderately steep early, flatter later in training)")

    return True  # Interpretive test


