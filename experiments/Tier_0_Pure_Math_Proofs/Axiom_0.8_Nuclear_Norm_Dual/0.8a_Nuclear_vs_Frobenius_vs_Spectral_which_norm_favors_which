def test_condition_number_sweep():
    print("\n" + "=" * 80)
    print("TEST 2: Energy concentration vs condition number")
    print("=" * 80)

    n = 5
    kappas = [1, 2, 5, 10, 100, 1000, 1e6]
    all_pass = True

    print(f"\n  {'kappa':<10} {'SGD conc':<12} {'Muon conc':<12} {'Adam conc':<12} "
          f"{'SGD exp':<12} {'Muon exp':<12}")
    print(f"  {'─'*10} {'─'*12} {'─'*12} {'─'*12} {'─'*12} {'─'*12}")

    for kappa in kappas:
        # Evenly spaced singular values from 1 to kappa
        sigmas = np.linspace(1.0, kappa, n)
        M = np.diag(sigmas)

        sgd_conc = energy_concentration(M)
        muon_conc = energy_concentration(polar_factor(M))
        adam_conc = energy_concentration(np.sign(M))

        sgd_expected = sigmas[-1]**2 / np.sum(sigmas**2)  # top = largest = last
        # Wait: for linspace(1, kappa), last is the largest. But SVD orders descending.
        # energy_concentration picks svs[0] which is the largest.
        # For diag matrix with positive values, largest singular value IS max(sigmas).
        sgd_expected = max(sigmas)**2 / np.sum(sigmas**2)
        muon_expected = 1.0 / n

        print(f"  {kappa:<10.0f} {sgd_conc:<12.6f} {muon_conc:<12.6f} {adam_conc:<12.6f} "
              f"{sgd_expected:<12.6f} {muon_expected:<12.6f}")

        # Verify
        if abs(sgd_conc - sgd_expected) > 1e-8:
            print(f"    [FAIL] SGD concentration mismatch")
            all_pass = False
        if abs(muon_conc - muon_expected) > 1e-8:
            print(f"    [FAIL] Muon concentration mismatch")
            all_pass = False

    print(f"\n  PATTERN:")
    print(f"    SGD: goes from 1/{n} = {1/n:.4f} (kappa=1) to ~1.0 (kappa->inf)")
    print(f"    Muon: ALWAYS exactly 1/{n} = {1/n:.4f} (perfectly democratic)")
    print(f"    Adam(sign): for diagonal positive, always 1/{n} (but NOT for general M!)")

    # Also show with random rotation
    print(f"\n  --- With random rotation (non-diagonal, 5x5) ---")
    print(f"  {'kappa':<10} {'SGD conc':<12} {'Muon conc':<12} {'Adam conc':<12}")
    print(f"  {'─'*10} {'─'*12} {'─'*12} {'─'*12}")

    for kappa in kappas:
        sigmas = np.linspace(1.0, kappa, n)
        U_r, _ = np.linalg.qr(np.random.randn(n, n))
        V_r, _ = np.linalg.qr(np.random.randn(n, n))
        M = U_r @ np.diag(sigmas) @ V_r.T

        sgd_conc = energy_concentration(M)
        muon_conc = energy_concentration(polar_factor(M))
        adam_conc = energy_concentration(np.sign(M))

        print(f"  {kappa:<10.0f} {sgd_conc:<12.6f} {muon_conc:<12.6f} {adam_conc:<12.6f}")

        # Key check: Muon always 1/n regardless of rotation
        if abs(muon_conc - 1.0/n) > 1e-8:
            print(f"    [FAIL] Muon not democratic after rotation!")
            all_pass = False

    print(f"\n  KEY FINDING: Adam's concentration depends on the element basis.")
    print(f"  Muon is invariant under rotation (gauge-equivariant).")
    print(f"  Adam is NOT — it's democratic in the element basis, not the spectral basis.")

    return all_pass


