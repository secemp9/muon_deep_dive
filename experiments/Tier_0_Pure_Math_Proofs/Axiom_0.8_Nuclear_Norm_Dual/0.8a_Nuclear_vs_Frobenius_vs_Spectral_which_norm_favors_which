#!/usr/bin/env python3
"""
Experiment 0.8a — Nuclear vs Frobenius vs Spectral: which norm favors which directions?
========================================================================================

For M with singular values sigma = [10, 1, 0.1]:
  - Nuclear norm: ||M||_* = sum(sigma) = 11.1
  - Frobenius norm: ||M||_F = sqrt(sum(sigma^2)) = sqrt(101.01) ~ 10.05
  - Spectral norm: ||M||_op = max(sigma) = 10

The key question: how does each optimizer distribute step energy across singular directions?

  SGD step: Delta = eta*M  -->  energy fraction in direction i = sigma_i^2 / sum(sigma_j^2)
    => Concentrates 99% in the dominant direction ("rich get richer")

  Muon step: Delta = eta*ortho(M) = eta*UV^T  -->  energy fraction = 1/min(m,n)
    => Democratic: every direction gets equal energy ("socialism for singular values")

  Adam step: Delta = eta*sign(M)  -->  equal magnitude per ELEMENT (different from spectral democracy)

CRITICAL CONTEXT from recent findings:
  - From 0.7b: Muon's NS doesn't actually converge to UV^T for large matrices (~11 deg error)
  - From H4: maybe Muon's benefit is "democratic energy distribution" (spectral clipping),
    not exact gauge fixing
  - This experiment tests: does the ACTUAL NS output (not exact polar) also distribute energy
    equally? Or does the ~11 deg error reintroduce concentration?

PASS/FAIL criteria:
  - SGD concentration -> sigma_1^2/sum(sigma_i^2) for diagonal case
  - Muon (exact polar) concentration = exactly 1/n
  - Muon (NS approx) concentration ~ 1/n (how close?)
  - Democratic updating is NOT always better: if loss only cares about top direction, SGD wins
"""

import numpy as np
import sys

np.random.seed(42)

# Muon's quintic NS coefficients
A_MUON, B_MUON, C_MUON = 3.4445, -4.7750, 2.0315


# =============================================================================
# Utility functions
# =============================================================================

def newton_schulz_5steps(M):
    """Muon's actual Newton-Schulz iteration: 5 steps with quintic polynomial."""
    a, b, c = A_MUON, B_MUON, C_MUON
    X = M.copy()
    # Normalize so spectral norm < sqrt(3) for convergence
    norm = np.linalg.norm(X, ord=2)
    if norm < 1e-12:
        return X
    X = X / norm
    for _ in range(5):
        A_mat = X @ X.T
        # X_{k+1} = (aI + bA + cA^2) X
        X = (a * X + b * (A_mat @ X) + c * (A_mat @ A_mat @ X))
    return X


def energy_concentration(step_matrix):
    """Compute the fraction of Frobenius energy in the top singular direction.

    Returns: fraction in [0, 1]. 1/n = perfectly democratic, 1.0 = fully concentrated.
    """
    svs = np.linalg.svd(step_matrix, compute_uv=False)
    total_energy = np.sum(svs**2)
    if total_energy < 1e-30:
        return 0.0
    return svs[0]**2 / total_energy


def energy_distribution(step_matrix):
    """Return the full distribution of Frobenius energy across singular directions."""
    svs = np.linalg.svd(step_matrix, compute_uv=False)
    total = np.sum(svs**2)
    if total < 1e-30:
        return svs * 0
    return svs**2 / total


def polar_factor(M):
    """Exact polar factor: U @ V^T from SVD."""
    U, S, Vt = np.linalg.svd(M, full_matrices=False)
    return U @ Vt


