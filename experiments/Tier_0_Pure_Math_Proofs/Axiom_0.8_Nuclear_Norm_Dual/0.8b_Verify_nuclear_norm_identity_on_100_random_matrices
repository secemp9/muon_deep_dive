# =============================================================================
# TEST 5: Algebraic proof — step by step on a concrete matrix
# =============================================================================

def test_algebraic_proof():
    print("\n" + "=" * 80)
    print("TEST 5: Algebraic proof (step by step on a concrete matrix)")
    print("        tr(M^T * UV^T) = tr(V Sigma U^T * U V^T) = tr(Sigma) = ||M||_*")
    print("=" * 80)

    rng = np.random.default_rng(202)

    # Use a small 3x3 matrix for readable output
    M = rng.standard_normal((3, 3))
    U, S, Vt = np.linalg.svd(M, full_matrices=False)
    V = Vt.T

    print(f"\n  Given: M = U Sigma V^T (SVD)")
    print(f"  Singular values: sigma = {S}")
    print(f"\n  Step 1: ortho(M) = U V^T")
    Q = U @ Vt
    print(f"    Q = U @ V^T =")
    for row in Q:
        print(f"      [{', '.join(f'{x:8.5f}' for x in row)}]")

    print(f"\n  Step 2: <M, Q> = tr(M^T Q)")
    MtQ = M.T @ Q
    ip = np.trace(MtQ)
    print(f"    M^T Q =")
    for row in MtQ:
        print(f"      [{', '.join(f'{x:8.5f}' for x in row)}]")
    print(f"    tr(M^T Q) = {ip:.10f}")

    print(f"\n  Step 3: Expand M^T = (U Sigma V^T)^T = V Sigma U^T")
    print(f"    M^T Q = V Sigma U^T * U V^T")

    VSigUt = V @ np.diag(S) @ U.T
    print(f"    V Sigma U^T =")
    for row in VSigUt:
        print(f"      [{', '.join(f'{x:8.5f}' for x in row)}]")

    print(f"\n  Step 4: U^T U = I (orthonormality)")
    UtU = U.T @ U
    print(f"    U^T U = I? Max deviation: {np.max(np.abs(UtU - np.eye(3))):.2e}")
    print(f"    So: V Sigma U^T * U V^T = V Sigma V^T")

    VSigVt = V @ np.diag(S) @ Vt
    print(f"    V Sigma V^T =")
    for row in VSigVt:
        print(f"      [{', '.join(f'{x:8.5f}' for x in row)}]")

    print(f"\n  Step 5: tr(V Sigma V^T) = tr(Sigma V^T V) = tr(Sigma)")
    VtV = Vt @ V
    print(f"    V^T V = I? Max deviation: {np.max(np.abs(VtV - np.eye(3))):.2e}")
    print(f"    tr(Sigma) = sum(sigma_i) = {np.sum(S):.10f}")

    print(f"\n  Step 6: Verify chain of equalities:")
    print(f"    tr(M^T * UV^T) = {ip:.10f}")
    print(f"    tr(V Sigma V^T) = {np.trace(VSigVt):.10f}")
    print(f"    sum(sigma_i)    = {np.sum(S):.10f}")
    print(f"    ||M||_*         = {nuclear_norm(M):.10f}")

    dev = abs(ip - np.sum(S))
