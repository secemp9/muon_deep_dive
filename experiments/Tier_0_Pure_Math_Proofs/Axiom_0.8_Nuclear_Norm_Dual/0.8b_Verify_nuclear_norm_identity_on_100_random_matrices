#!/usr/bin/env python3
"""
Experiment 0.8b — Verify: <M, ortho(M)> = ||M||_* on 100 random matrices
=========================================================================

Nuclear norm duality: the inner product <M, UV^T> achieves the maximum of <M, X>
over all X with ||X||_op <= 1, and that maximum equals ||M||_* = sum(sigma_i).

This is the same Von Neumann trace inequality verified in 0.6a with 8M samples.
Here we focus on:
  1. The identity itself (exhaustive per-matrix verification)
  2. Uniqueness of the maximizer (when sigma are distinct)
  3. What happens when sigma are NOT distinct (non-unique maximizer -> gauge ambiguity)

HYPOTHESIS:
  - All 100 matrices satisfy <M, ortho(M)> = ||M||_* to 1e-14 precision
  - All 100,000 random X samples satisfy <M, X> < ||M||_* (strictly)
  - The maximizer is unique when singular values are distinct
  - Takes < 1 second total on CPU

PASS/FAIL: Clear numerical verification with machine-precision tolerances.
"""

import numpy as np
import time
import sys

np.random.seed(42)


# =============================================================================
# Utility functions
# =============================================================================

def ortho(M):
    """Compute the orthogonal (polar) factor UV^T via SVD."""
    U, S, Vt = np.linalg.svd(M, full_matrices=False)
    return U @ Vt


def nuclear_norm(M):
    """Compute ||M||_* = sum of singular values."""
    return np.sum(np.linalg.svd(M, compute_uv=False))


def inner_product(A, B):
    """Compute <A, B> = tr(A^T B) = sum(A * B)."""
    return np.sum(A * B)


def random_operator_norm_leq1(shape, rng):
    """Generate a random matrix X with ||X||_op <= 1.

    Method: generate random matrix, compute SVD, clip singular values to [0, 1].
    """
    G = rng.standard_normal(shape)
    U, S, Vt = np.linalg.svd(G, full_matrices=False)
    S_clipped = S / np.maximum(S.max(), 1.0)  # scale so max SV = 1
    # Actually, to get random X with ||X||_op <= 1, we can just
    # generate random U, random V, and random S in [0,1]
    S_rand = rng.uniform(0, 1, size=len(S))
    return U @ np.diag(S_rand) @ Vt


# =============================================================================
# TEST 1: Main verification — 100 matrices x 4 sizes
# =============================================================================

def test_nuclear_norm_identity():
    print("=" * 80)
    print("TEST 1: <M, ortho(M)> = ||M||_* on 100 random matrices x 4 sizes")
    print("=" * 80)

    sizes = [(2, 2), (5, 5), (10, 10), (3, 7)]
    n_matrices = 100
    rng = np.random.default_rng(123)

    all_pass = True
    worst_deviation = 0.0
    worst_case_info = ""

    for (m, n) in sizes:
        deviations = []
        for trial in range(n_matrices):
            M = rng.standard_normal((m, n))
            Q = ortho(M)

            # <M, ortho(M)> = tr(M^T UV^T)
            ip = inner_product(M, Q)
            # ||M||_* = sum of singular values
            nn = nuclear_norm(M)

            dev = abs(ip - nn)
            deviations.append(dev)

            if dev > worst_deviation:
                worst_deviation = dev
                worst_case_info = f"size={m}x{n}, trial={trial}"

        max_dev = max(deviations)
        mean_dev = np.mean(deviations)
        # For larger matrices, allow slightly more tolerance due to floating point
        # accumulation: O(n * eps) where eps ~ 2.2e-16
        tol = max(1e-14, min(m, n) * 2.3e-15)
        passed = max_dev < tol

        status = "[PASS]" if passed else "[FAIL]"
        print(f"\n  Size {m}x{n}: {status}")
        print(f"    Max deviation:  {max_dev:.2e} (tolerance: {tol:.2e})")
        print(f"    Mean deviation: {mean_dev:.2e}")

        if not passed:
            all_pass = False

    print(f"\n  WORST CASE across all 400 matrices:")
    print(f"    Deviation = {worst_deviation:.2e} at {worst_case_info}")
    final_tol = 1e-13  # Overall tolerance: well within machine precision regime
    print(f"    Overall tolerance = {final_tol:.0e}")
    passed_overall = worst_deviation < final_tol
    print(f"    {'[PASS]' if passed_overall else '[FAIL]'} "
          f"Identity holds to machine precision")

    if not passed_overall:
        all_pass = False

    return all_pass


