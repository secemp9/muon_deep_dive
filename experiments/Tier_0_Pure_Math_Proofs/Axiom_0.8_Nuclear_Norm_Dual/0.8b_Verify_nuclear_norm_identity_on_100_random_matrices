def test_uniqueness_distinct_sv():
    print("\n" + "=" * 80)
    print("TEST 3: Uniqueness of maximizer when singular values are distinct")
    print("        (Perturb ortho(M) on the Stiefel manifold -> inner product decreases)")
    print("=" * 80)

    rng = np.random.default_rng(789)
    n_matrices = 50
    n_perturbations = 20
    all_pass = True

    sizes = [(5, 5), (10, 10), (3, 7)]

    for (m, n) in sizes:
        k = min(m, n)
        violations = 0
        total_tests = 0
        min_decrease = np.inf

        for trial in range(n_matrices):
            # Generate M with DISTINCT singular values
            M = rng.standard_normal((m, n))
            U, S, Vt = np.linalg.svd(M, full_matrices=False)
            # Force distinct singular values
            S = np.sort(rng.uniform(0.5, 10.0, size=k))[::-1]
            # Ensure distinctness
            S = S + np.linspace(0, 1, k)[::-1]
            M = U @ np.diag(S) @ Vt

            Q = ortho(M)  # = U @ Vt, the unique maximizer
            optimal_ip = inner_product(M, Q)

            for _ in range(n_perturbations):
                # Perturb Q on the Stiefel manifold:
                # Q_perturbed = Q @ expm(epsilon * skew-symmetric)
                # For small epsilon, this stays near Q but on the manifold of
                # matrices with operator norm = 1
                epsilon = 0.01
                # Generate random skew-symmetric matrix
                A = rng.standard_normal((k, k))
                skew = (A - A.T) / 2.0
                # Exponential map (for small epsilon, use first-order)
                # expm(eps*skew) ~ I + eps*skew + 0.5*eps^2*skew^2
                from numpy.linalg import matrix_power
                R = np.eye(k) + epsilon * skew + 0.5 * epsilon**2 * (skew @ skew)
                # Reorthogonalize to ensure it's truly orthogonal
                R_orth, _ = np.linalg.qr(R)

                if m <= n:
                    Q_perturbed = R_orth @ Q  # Left perturbation
                else:
                    Q_perturbed = Q @ R_orth.T  # Right perturbation

                # Verify ||Q_perturbed||_op <= 1 (it should be ~1 since Q is orthogonal)
                perturbed_ip = inner_product(M, Q_perturbed)
                decrease = optimal_ip - perturbed_ip
                total_tests += 1

                if decrease < -1e-10:  # Allow numerical noise
                    violations += 1
                if decrease < min_decrease:
                    min_decrease = decrease

        passed = (violations == 0)
        status = "[PASS]" if passed else "[FAIL]"
        print(f"\n  Size {m}x{n}: {status}")
        print(f"    Tests: {total_tests}")
        print(f"    Violations (perturbed > optimal): {violations}")
        print(f"    Minimum decrease from perturbation: {min_decrease:.6e}")
        print(f"    (Positive = perturbation always hurts, confirming unique maximum)")

        if not passed:
            all_pass = False

    print(f"\n  THEOREM: If all sigma_i are distinct, UV^T is the UNIQUE maximizer")
    print(f"  VERIFIED: Every perturbation away from UV^T strictly decreases <M, X>")
    print(f"  {'[PASS]' if all_pass else '[FAIL]'}")

    return all_pass


