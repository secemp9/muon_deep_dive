# TEST 4: Non-uniqueness when singular values repeat (gauge ambiguity)
# =============================================================================

def test_non_uniqueness_repeated_sv():
    print("\n" + "=" * 80)
    print("TEST 4: Non-uniqueness when singular values repeat (gauge ambiguity)")
    print("        (Rank-deficient M: multiple X with ||X||_op<=1 achieve <M,X> = ||M||_*)")
    print("=" * 80)

    all_pass = True
    rng = np.random.default_rng(101)

    # IMPORTANT MATHEMATICAL NOTE:
    # For FULL-RANK M with repeated singular values, the polar factor UV^T is still
    # UNIQUE (it equals M(M^TM)^{-1/2}). The SVD non-uniqueness (rotating within
    # degenerate blocks) does NOT affect UV^T because the same rotation applies to
    # both U and V, canceling in the product.
    #
    # Non-uniqueness of the maximizer occurs for RANK-DEFICIENT M (sigma_i = 0).
    # This is the connection to 0.1b (singular matrices).
    #
    # For rank-deficient M (m x n with m > n or with zero singular values):
    # M = U_r diag(sigma_r) V_r^T where only r < min(m,n) singular values are nonzero.
    # Any X = U_r V_r^T + W where W is in the null space of M achieves the maximum,
    # as long as ||X||_op <= 1.

    # Case 1: Full-rank M with repeated singular values — polar factor IS unique
    print("\n  Case 1: Full-rank with repeated sigma = [3, 3, 1] — polar factor IS unique")
    print("  " + "-" * 60)

    n = 3
    S = np.array([3.0, 3.0, 1.0])
    U, _ = np.linalg.qr(rng.standard_normal((n, n)))
    V, _ = np.linalg.qr(rng.standard_normal((n, n)))
    M = U @ np.diag(S) @ V.T

    nn = nuclear_norm(M)
    Q_standard = ortho(M)
    ip_standard = inner_product(M, Q_standard)

    # Verify the polar factor equals M (M^T M)^{-1/2}
    MtM = M.T @ M
    eigvals, eigvecs = np.linalg.eigh(MtM)
    MtM_inv_sqrt = eigvecs @ np.diag(1.0 / np.sqrt(eigvals)) @ eigvecs.T
    Q_polar_direct = M @ MtM_inv_sqrt

    polar_diff = np.linalg.norm(Q_standard - Q_polar_direct, 'fro')

    print(f"    M has singular values: {S}")
    print(f"    ||M||_* = {nn:.6f}")
    print(f"    <M, ortho(M)> = {ip_standard:.6f}")
    print(f"    ||UV^T - M(M^TM)^{{-1/2}}||_F = {polar_diff:.2e} (unique!)")

    # Try rotating within the degenerate block — show it does NOT help
    n_rotations = 10
    print(f"\n    Testing {n_rotations} rotations in degenerate subspace of SVD:")
    all_match_standard = True
    for trial in range(n_rotations):
        theta = rng.uniform(0, 2 * np.pi)
        R_sub = np.array([[np.cos(theta), -np.sin(theta)],
                          [np.sin(theta),  np.cos(theta)]])
        # Rotate BOTH U and V in degenerate block (valid SVD rotation)
        U_alt = U.copy()
        V_alt = V.copy()
        U_alt[:, :2] = U[:, :2] @ R_sub
        V_alt[:, :2] = V[:, :2] @ R_sub
        # The polar factor from this alternative SVD
        Q_alt = U_alt @ V_alt.T
        diff = np.linalg.norm(Q_alt - Q_standard, 'fro')
        if diff > 1e-12:
            all_match_standard = False

    if all_match_standard:
        print(f"    [PASS] All rotations give the SAME polar factor (unique despite degeneracy)")
        print(f"    Reason: U_alt V_alt^T = U R R^T V^T = U V^T (rotation cancels!)")
    else:
        print(f"    [FAIL] Rotations produced different polar factors")
        all_pass = False

    # Case 2: RANK-DEFICIENT M — non-unique maximizer (true gauge ambiguity)
    print(f"\n  Case 2: Rank-deficient M (5x5 with sigma = [3, 2, 0, 0, 0]) — NON-UNIQUE")
    print("  " + "-" * 60)

    m_size, n_size = 5, 5
    S_rankdef = np.array([3.0, 2.0, 0.0, 0.0, 0.0])
    U_full, _ = np.linalg.qr(rng.standard_normal((m_size, m_size)))
    V_full, _ = np.linalg.qr(rng.standard_normal((n_size, n_size)))
    M_rankdef = U_full @ np.diag(S_rankdef) @ V_full.T

    nn_rd = nuclear_norm(M_rankdef)
    print(f"    ||M||_* = {nn_rd:.6f} (= 3 + 2 = 5)")

    # The standard ortho factor
    Q_rd = ortho(M_rankdef)
    ip_rd = inner_product(M_rankdef, Q_rd)
    print(f"    <M, ortho(M)> = {ip_rd:.6f}")
    print(f"    Match: {abs(ip_rd - nn_rd):.2e}")

    # Construct DIFFERENT maximizers by adding null-space components
    # The null space of M^T is spanned by U_full[:, 2:]
    # We can add any matrix that maps into this null space
    n_alternative = 10
    alternative_ips = []

    for trial in range(n_alternative):
        # Start with the rank-2 part of the polar factor
        # U_r V_r^T where U_r = U_full[:,:2], V_r = V_full[:,:2]
        Q_base = U_full[:, :2] @ V_full[:, :2].T

        # Add a component in the null space: U_null @ R @ V_null^T
        # where U_null = U_full[:, 2:], V_null = V_full[:, 2:]
        # This doesn't affect <M, Q> because M has zero weight there
        # But we need ||Q_base + Q_null||_op <= 1
        R_null = rng.standard_normal((3, 3))
        R_null_orth, _ = np.linalg.qr(R_null)
        Q_null_component = U_full[:, 2:] @ R_null_orth @ V_full[:, 2:].T

        # Scale: we need the combined matrix to have ||.||_op <= 1
        Q_combined = Q_base + Q_null_component
        # Q_combined is actually orthogonal! (orthogonal rows/cols from orthogonal bases)
        # Verify:
        op_norm = np.linalg.norm(Q_combined, ord=2)

        ip_alt = inner_product(M_rankdef, Q_combined)
        alternative_ips.append(ip_alt)
        diff_from_std = np.linalg.norm(Q_combined - Q_rd, 'fro')

        if trial < 3:
            print(f"    Alt {trial}: <M,Q> = {ip_alt:.10f}, ||Q||_op = {op_norm:.6f}, "
                  f"||Q - Q_std||_F = {diff_from_std:.4f}")

    alt_deviations = [abs(ip - nn_rd) for ip in alternative_ips]
    max_alt_dev = max(alt_deviations)
    any_different = any(np.linalg.norm(Q_rd - (U_full[:, :2] @ V_full[:, :2].T +
                        U_full[:, 2:] @ np.linalg.qr(rng.standard_normal((3,3)))[0] @
                        V_full[:, 2:].T), 'fro') > 0.1 for _ in range(1))

    print(f"\n    All {n_alternative} alternatives achieve ||M||_*?")
    print(f"    Max deviation from ||M||_*: {max_alt_dev:.2e}")

    if max_alt_dev < 1e-12:
        print(f"    [PASS] Multiple DISTINCT matrices achieve the same maximum!")
        print(f"    The null-space component is the gauge freedom.")
    else:
        print(f"    [FAIL] Alternative maximizers don't achieve the bound")
        all_pass = False

    # Case 3: Rectangular M (3x7) — always rank-deficient in the "wide" sense
    print(f"\n  Case 3: Wide matrix M (3x7) — multiple maximizers via right null space")
    print("  " + "-" * 60)

    m_r, n_r = 3, 7
    M_wide = rng.standard_normal((m_r, n_r))
    U_w, S_w, Vt_w = np.linalg.svd(M_wide, full_matrices=True)
    V_w = Vt_w.T  # 7x7

    nn_wide = np.sum(S_w)
    Q_wide = U_w @ Vt_w[:m_r, :]  # 3x7 partial isometry (using thin SVD)
    # Actually ortho gives the thin version
    Q_wide = ortho(M_wide)
    ip_wide = inner_product(M_wide, Q_wide)
    print(f"    M is 3x7, rank 3, ||M||_* = {nn_wide:.6f}")
    print(f"    <M, ortho(M)> = {ip_wide:.6f}, match: {abs(ip_wide - nn_wide):.2e}")

    # The right null space of M is V_w[:, 3:] (4-dimensional)
    # We can add any left-orthogonal component mapping into right null space
    n_alt_wide = 10
    wide_ips = []
    for trial in range(n_alt_wide):
        # Q_wide is 3x7 with Q_wide @ Q_wide^T = I_3
        # Extend: add a random component in the right null space
        # Actually for rectangular: the maximizer set is {U V^T + W : W^T U = 0, ||UV^T + W||_op <= 1}
        # Simpler approach: construct alternative via full SVD
        # U_w is 3x3, V_w is 7x7. Thin polar = U_w[:,:3] @ V_w[:,:3]^T
        # Alternative: use different right-null-space fill
        # For a 3x7 matrix with ||.||_op <= 1, the key constraint is singular values <= 1
        # The maximizer is any 3x7 matrix X with X = U_w Vt_w[:3,:] + null component
        # Let's just perturb in the null space:
        null_basis = V_w[:, m_r:]  # 7x4 null space basis
        coeff = rng.standard_normal((m_r, n_r - m_r))  # 3x4 random coefficients
        # We need: Q_alt = Q_wide + U_perturb @ null_basis^T where U_perturb is small enough
        # Actually let's think more carefully.
        # For m<n: the thin SVD gives M = U(3x3) S(3x3) Vt(3x7)
        # Maximizer: any X(3x7) with ||X||_op <= 1 and <M,X> = ||M||_*
        # X = U @ Vt[:3,:] achieves this (the standard ortho).
        # But X = U @ R @ Vt[:3,:] with R orthogonal does NOT (breaks it).
        # The polar factor for a wide matrix IS unique: U_p = U Vt (thin).
        # Non-uniqueness only from "extending" to full 7-column orthogonal.
        # Actually the thin polar IS the unique maximizer among 3x7 matrices with ||.||_op<=1.
        pass

    # Actually for rectangular matrices, the maximizer IS unique (the thin polar factor)
    # when M has full row rank. The non-uniqueness only appears for truly rank-deficient M.
    print(f"    For full-row-rank wide M: the thin polar UV^T IS the unique maximizer")
    print(f"    (No gauge ambiguity for full-rank rectangular matrices)")

    # Demonstrate: perturbing the thin polar always loses
    n_perturb = 20
    all_decrease = True
    for _ in range(n_perturb):
        # Small perturbation that keeps ||.||_op ~ 1
        dX = 0.01 * rng.standard_normal((m_r, n_r))
        Q_pert = Q_wide + dX
        # Project back to ||.||_op <= 1
        U_p, S_p, Vt_p = np.linalg.svd(Q_pert, full_matrices=False)
        S_p = np.minimum(S_p, 1.0)
        Q_pert_proj = U_p @ np.diag(S_p) @ Vt_p
        ip_pert = inner_product(M_wide, Q_pert_proj)
        if ip_pert > ip_wide + 1e-10:
            all_decrease = False

    if all_decrease:
        print(f"    [PASS] Perturbations of thin polar always decrease <M, X>")
    else:
        print(f"    [FAIL] Found perturbation that increases inner product")
        all_pass = False

    # Summary: gauge ambiguity connection
    print(f"\n  GAUGE AMBIGUITY CONNECTION:")
    print(f"    - Full-rank M (even with repeated sigma): polar factor UV^T is UNIQUE")
    print(f"      Reason: UV^T = M(M^TM)^{{-1/2}} is well-defined")
    print(f"    - Rank-DEFICIENT M: multiple X achieve the maximum")
    print(f"      The null-space component is free (gauge freedom)")
    print(f"    - This is the same non-uniqueness found in 0.1b (singular matrices)")
    print(f"    - For Muon in practice: weight matrices are generically full-rank")
