def test_strict_inequality():
    print("\n" + "=" * 80)
    print("TEST 2: <M, X> < ||M||_* for 1000 random X with ||X||_op <= 1")
    print("        (Strict inequality — random X never achieves the bound)")
    print("=" * 80)

    sizes = [(2, 2), (5, 5), (10, 10), (3, 7)]
    n_matrices = 100
    n_random_X = 1000
    rng = np.random.default_rng(456)

    all_pass = True
    overall_min_gap = np.inf

    for (m, n) in sizes:
        violations = 0
        min_gap = np.inf
        total_tests = 0

        for trial in range(n_matrices):
            M = rng.standard_normal((m, n))
            nn = nuclear_norm(M)

            for _ in range(n_random_X):
                X = random_operator_norm_leq1((m, n), rng)
                ip = inner_product(M, X)
                gap = nn - ip
                total_tests += 1

                if gap < 0:
                    violations += 1
                if gap < min_gap:
                    min_gap = gap

        passed = (violations == 0)
        status = "[PASS]" if passed else "[FAIL]"
        print(f"\n  Size {m}x{n}: {status}")
        print(f"    Total tests: {total_tests:,}")
        print(f"    Violations (X >= bound): {violations}")
        print(f"    Minimum gap (||M||_* - <M,X>): {min_gap:.6e}")
        print(f"    (Gap > 0 means strict inequality holds)")

        if not passed:
            all_pass = False
        if min_gap < overall_min_gap:
            overall_min_gap = min_gap

    print(f"\n  OVERALL: {100*n_matrices*n_random_X:,} total (M, X) pairs tested")
    print(f"    Smallest optimality gap: {overall_min_gap:.6e}")
    print(f"    Random X never achieves the bound (probability 0 event)")
    print(f"    {'[PASS]' if all_pass else '[FAIL]'}")

    return all_pass


