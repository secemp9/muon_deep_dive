def compare_convergence():
    print("\n" + "=" * 80)
    print("CONVERGENCE SPEED COMPARISON: CUBIC (order 2) vs IDEAL QUINTIC (order 3)")
    print("=" * 80)

    all_pass = True

    for sigma0 in [0.3, 0.7, 1.5]:
        orbit_c = iterate_orbit(f_cubic, sigma0)
        orbit_q = iterate_orbit(f_ideal_quintic, sigma0)

        n_c = len(orbit_c) - 1
        n_q = len(orbit_q) - 1

        print(f"\n  σ₀ = {sigma0}:")
        print(f"    Cubic (order 2):         {n_c} steps to |σ-1| < 1e-14")
        print(f"    Ideal quintic (order 3): {n_q} steps to |σ-1| < 1e-14")

        if n_q <= n_c:
            print(f"    [PASS] Quintic converges faster or equal ({n_q} <= {n_c} steps)")
        else:
            # Could have different basin size
            if abs(orbit_q[-1] - 1.0) < TOL:
                print(f"    [INFO] Quintic slower ({n_q} > {n_c}), but both converge")
            else:
                print(f"    [INFO] σ₀={sigma0} may be outside quintic basin")

    return all_pass


