# Muon quintic analysis (documenting the non-convergence)
# ─────────────────────────────────────────────────────────────────────────────
def muon_quintic_analysis():
    print("\n" + "=" * 80)
    print("MUON'S ACTUAL QUINTIC ANALYSIS")
    print("=" * 80)

    a, b, c = A_MUON, B_MUON, C_MUON
    print(f"\n  Coefficients: a={a}, b={b}, c={c}")
    print(f"  a + b + c = {a+b+c:.4f} (should be 1 for σ=1 fixed point)")
    print(f"  g(1) = {f_muon(1.0):.6f} ≠ 1  =>  σ=1 is NOT a fixed point!")
    print(f"  g'(1) = {f_muon_deriv(1.0):.6f}")
    print(f"  g'(0) = {f_muon_deriv(0.0):.6f} (|g'(0)| > 1: unstable at 0)")

    # Find actual fixed points: g(σ) = σ ↔ (a-1)σ + bσ³ + cσ⁴ = 0
    # σ[(a-1) + bσ² + cσ⁴] = 0  →  quadratic in u = σ²
    disc = b**2 - 4 * c * (a - 1)
    print(f"\n  Fixed point equation: (a-1) + bσ² + cσ⁴ = 0")
    print(f"  Quadratic in u=σ²: {c}u² + ({b})u + ({a-1:.4f}) = 0")
    print(f"  Discriminant = {disc:.6f}")

    if disc >= 0:
        u1 = (-b + np.sqrt(disc)) / (2 * c)
        u2 = (-b - np.sqrt(disc)) / (2 * c)
        print(f"  u₁ = {u1:.6f} → σ = ±{np.sqrt(abs(u1)):.6f}" + (" (real)" if u1 >= 0 else " (imaginary)"))
        print(f"  u₂ = {u2:.6f} → σ = ±{np.sqrt(abs(u2)):.6f}" + (" (real)" if u2 >= 0 else " (imaginary)"))

        if u1 >= 0:
            s1 = np.sqrt(u1)
            print(f"\n  Fixed point σ = {s1:.6f}: g({s1:.4f}) = {f_muon(s1):.6f}, "
                  f"g'({s1:.4f}) = {f_muon_deriv(s1):.4f}")
        if u2 >= 0:
            s2 = np.sqrt(u2)
            print(f"  Fixed point σ = {s2:.6f}: g({s2:.4f}) = {f_muon(s2):.6f}, "
                  f"g'({s2:.4f}) = {f_muon_deriv(s2):.4f}")

    print("\n  INTERPRETATION: Muon's quintic does NOT converge to sigma=1.")
    print("  Instead it oscillates. But the POLAR FACTOR (direction UV^T) is correct")
    print("  because the matrix iteration X_{n+1} = aX + (bXX^T + c(XX^T)^2)X")
    print("  still drives the directions toward UV^T even if magnitudes oscillate.")
    print("  Muon only uses 5 steps and later rescales, so exact sigma->1 is unnecessary.")


