print("-" * 52)

svals_k = svals.copy()
for k in range(1, 11):
    svals_k = np.array([quintic_iter(s) for s in svals_k])
    # Check if any went negative or diverged
    if np.any(np.isnan(svals_k)) or np.any(np.abs(svals_k) > 100):
        print(f"{k:>3} {'DIVERGED':>12}")
        break
    valid = svals_k[svals_k > 0]
    if len(valid) > 0:
        print(f"{k:>3} {valid.max():>12.6f} {valid.min():>12.6f} "
              f"{valid.max()/valid.min():>10.2f} {valid.max():>12.6f}")
    else:
        print(f"{k:>3} {'ALL<=0':>12}")
        break

