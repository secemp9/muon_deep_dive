# PART 4 — Muon's quintic on full matrices
# ============================================================================

print("=" * 80)
print("PART 4: Muon's quintic on actual matrices — directional convergence")
print("=" * 80)
print()
print("g(sigma) = 3.4445*s - 4.7750*s^3 + 2.0315*s^5")
print(f"g(1) = {quintic_iter(1.0):.6f} (NOT 1 — confirming no scalar fixed point at 1)")
print()

print("Scalar quintic iteration from various starting points:")
print(f"{'sigma_0':>10} {'g(sigma_0)':>12} {'g^2(sigma_0)':>14} {'g^5(sigma_0)':>14}")
print("-" * 54)
for s0 in [0.036, 0.05, 0.1, 0.5, 0.9, 1.0]:
    s = s0
    vals = [s]
    for _ in range(5):
        s = quintic_iter(s)
        vals.append(s)
    print(f"{s0:>10.4f} {vals[1]:>12.6f} {vals[2]:>14.6f} {vals[5]:>14.6f}")
print()

print("Matrix-level quintic: angular error vs polar factor after k steps")
print(f"{'n':>6} {'k=1':>10} {'k=2':>10} {'k=3':>10} {'k=5':>10} {'k=7':>10} {'k=10':>10}")
print("-" * 68)

for n in [4, 16, 64, 256, 768]:
    M = np.random.randn(n, n)
    X = M / (np.linalg.norm(M, 'fro') + 1e-7)
    U_true = polar_factor_svd(M)  # True polar factor

    errors = []
    Y = X.copy()
    for k in range(1, 11):
        Y = matrix_quintic_step(Y)
        # Normalize after each step to prevent blowup
        Y_norm = np.linalg.norm(Y, 'fro')
        if Y_norm > 0:
            err = angular_error(Y, U_true)
        else:
            err = float('nan')
        errors.append(err)

    print(f"{n:>6} {errors[0]:>10.2e} {errors[1]:>10.2e} {errors[2]:>10.2e} "
          f"{errors[4]:>10.2e} {errors[6]:>10.2e} {errors[9]:>10.2e}")

print()
print("NOTE: If angular error grows with n, the quintic's directional accuracy")
print("degrades for large matrices — a potential problem for Muon at scale.")
print()


