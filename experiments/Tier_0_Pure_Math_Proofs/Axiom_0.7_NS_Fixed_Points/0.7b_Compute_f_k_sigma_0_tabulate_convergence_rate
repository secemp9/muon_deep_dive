sigma_0_list = [0.5, 0.9, 0.99, 1.01, 1.1, 1.5]

for s0 in sigma_0_list:
    print(f"--- sigma_0 = {s0} ---")
    print(f"{'k':>3} {'sigma_k':>20} {'|sigma_k - 1|':>15} {'|e_k|/|e_{k-1}|^2':>20}")
    print("-" * 62)

    s = s0
    prev_err = abs(s - 1.0)
    steps_to_14 = None

    for k in range(1, 21):
        s = cubic_iter(s)
        err = abs(s - 1.0)
        if prev_err > 1e-30 and prev_err < 10:
            ratio = err / (prev_err**2) if prev_err**2 > 1e-30 else float('inf')
        else:
            ratio = float('nan')

        if k <= 10 or (steps_to_14 is None and err < 1e-14):
            print(f"{k:>3} {s:>20.15f} {err:>15.2e} {ratio:>20.6f}")

        if err < 1e-14 and steps_to_14 is None:
            steps_to_14 = k

        prev_err = err

    if steps_to_14 is not None:
        print(f"  => Steps to |e| < 1e-14: {steps_to_14}")
    else:
        print(f"  => Did NOT reach |e| < 1e-14 in 20 steps")
    print()

print("VERDICT Part 1: Quadratic convergence ratio should be ~1.5 (= 3/2).")
print("From sigma_0=0.5, hypothesis claims 5 steps for 10-digit accuracy.")
print()


