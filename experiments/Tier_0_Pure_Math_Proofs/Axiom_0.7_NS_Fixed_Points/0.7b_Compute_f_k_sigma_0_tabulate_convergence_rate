# PART 1 — Cubic iteration convergence table (textbook analysis)
# ============================================================================

print("=" * 80)
print("PART 1: Cubic f(s)=(3s-s^3)/2 convergence from standard starting points")
print("=" * 80)
print()
print("Fixed point: sigma* = 1 (stable for |sigma_0| < sqrt(3))")
