print("Full matrix-level NS (correct implementation):")
print("After k quintic steps, Frobenius error ||X_k - U_polar||_F / ||U_polar||_F:")
print(f"{'n':>6} {'k=1':>10} {'k=2':>10} {'k=3':>10} {'k=5':>10}")
print("-" * 42)

for n in [4, 64, 768]:
