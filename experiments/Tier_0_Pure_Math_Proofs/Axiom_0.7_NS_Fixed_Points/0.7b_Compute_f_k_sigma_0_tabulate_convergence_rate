#!/usr/bin/env python3
"""
Experiment 0.7b — Compute f^k(sigma_0) for k=1..10: tabulate convergence rate

Tests:
  Part 1: Cubic iteration f(s)=(3s-s^3)/2 convergence from textbook starting points
  Part 2: What Muon ACTUALLY experiences after Frobenius normalization
  Part 3: Cubic from realistic sigma_0 ~ 0.036 (n=768 post-normalization)
  Part 4: Muon's quintic g(s)=3.4445s-4.7750s^3+2.0315s^5 on full matrices
  Part 5: Why Muon works despite the quintic not converging to 1
  Part 6: How many NS steps does Muon actually need vs matrix size?

CRITICAL CONTEXT:
  - Muon's quintic does NOT have sigma=1 as a fixed point (g(1)=0.701)
  - After Frobenius normalization, singular values are ~ 1/sqrt(n), not ~ 0.5
  - The "5 steps suffices" story applies to the CUBIC from sigma_0=0.5, not Muon's actual use
"""

import numpy as np

np.random.seed(42)

# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

def cubic_iter(sigma):
    """Newton-Schulz cubic: f(s) = (3s - s^3) / 2"""
    return (3.0 * sigma - sigma**3) / 2.0


def quintic_iter(sigma):
    """Muon's quintic: g(s) = 3.4445s - 4.7750s^3 + 2.0315s^5"""
    return 3.4445 * sigma + (-4.7750) * sigma**3 + 2.0315 * sigma**5


def matrix_cubic_step(X):
    """Matrix-level cubic NS step: X_{k+1} = (3X - X X^T X) / 2"""
    return (3.0 * X - X @ X.T @ X) / 2.0


def matrix_quintic_step(X):
    """Matrix-level quintic NS step with Muon's coefficients"""
    a, b, c = 3.4445, -4.7750, 2.0315
    XtX = X.T @ X
    return a * X + b * (X @ XtX) + c * (X @ XtX @ XtX)


def polar_factor_svd(M):
    """Compute the true polar factor U = U_svd @ V_svd^T via SVD"""
    U, S, Vt = np.linalg.svd(M, full_matrices=False)
    return U @ Vt


def angular_error(A, B):
    """
    Angular error between two matrices (treated as vectors in Frobenius norm).
    Returns angle in radians between 0 and pi/2.
    """
    # Normalize both
    A_norm = A / (np.linalg.norm(A, 'fro') + 1e-30)
    B_norm = B / (np.linalg.norm(B, 'fro') + 1e-30)
    cos_angle = np.clip(np.sum(A_norm * B_norm), -1.0, 1.0)
    return np.arccos(np.abs(cos_angle))


def relative_error_polar(X, U_true):
    """Frobenius relative error: ||X - U_true||_F / ||U_true||_F"""
    return np.linalg.norm(X - U_true, 'fro') / np.linalg.norm(U_true, 'fro')


