    steps_1e6 = None
    steps_1e14 = None

    for k in range(1, 51):
        s = cubic_iter(s)
        err = abs(s - 1.0)

        if k <= 15 or err < 1e-14:
            print(f"{k:>3} {s:>20.15f} {err:>15.2e}")

        if err < 0.01 and steps_001 is None:
            steps_001 = k
        if err < 1e-6 and steps_1e6 is None:
            steps_1e6 = k
        if err < 1e-14 and steps_1e14 is None:
            steps_1e14 = k
            break

    print(f"  Steps to |e| < 0.01:  {steps_001 if steps_001 else '>50'}")
    print(f"  Steps to |e| < 1e-6:  {steps_1e6 if steps_1e6 else '>50'}")
    print(f"  Steps to |e| < 1e-14: {steps_1e14 if steps_1e14 else '>50'}")
    print()

print("KEY FINDING: From sigma_0=0.036, the cubic needs MANY more than 5 steps!")
print("The 'linear phase' (before quadratic kicks in) dominates for small sigma_0.")
print("Near sigma=0, f(s) ~ (3/2)*s, so growth is exponential with factor 1.5/step.")
print("From 0.036, reaching ~1 takes ~ log(1/0.036)/log(1.5) ~ 8 linear steps,")
print("then ~4-5 quadratic steps. Total: ~12-13 steps, NOT 5!")
print()


