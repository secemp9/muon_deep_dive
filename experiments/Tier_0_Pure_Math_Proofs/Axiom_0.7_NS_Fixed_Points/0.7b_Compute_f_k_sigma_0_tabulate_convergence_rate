# PART 2 — What does Muon ACTUALLY experience after Frobenius normalization?
# ============================================================================

print("=" * 80)
print("PART 2: Actual singular values after Frobenius normalization")
print("=" * 80)
print()
print("After normalization X = M/||M||_F, singular values become sigma_i/||M||_F")
print("For n x n random Gaussian: ||M||_F ~ sqrt(n^2) = n, sigma_max ~ 2*sqrt(n)")
print("So sigma_i(X) ~ sigma_i(M)/n, with max ~ 2/sqrt(n) and typical ~ 1/sqrt(n)")
print()

print(f"{'n':>6} {'sigma_max(X)':>14} {'sigma_median(X)':>16} {'sigma_min(X)':>14} {'1/sqrt(n)':>12}")
print("-" * 66)

for n in [4, 16, 64, 256, 768, 2048]:
    M = np.random.randn(n, n)
    X = M / np.linalg.norm(M, 'fro')
    svals = np.linalg.svd(X, compute_uv=False)
    inv_sqrt_n = 1.0 / np.sqrt(n)
    print(f"{n:>6} {svals[0]:>14.6f} {np.median(svals):>16.6f} {svals[-1]:>14.6f} {inv_sqrt_n:>12.6f}")

print()
print("OBSERVATION: sigma_max(X) ~ 2/sqrt(n), sigma_min(X) ~ small/sqrt(n)")
print("For n=768: sigma values are around 0.03-0.07, NOT 0.5!")
print()


